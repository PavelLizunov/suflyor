// Shared UI controls.
//
// CloseButton — the ONE window-corner close button used by every window that
// has a corner/​header dismiss "X" (tile, archive, "Написать", help, recover
// offer). Goal: they are pixel-identical instead of five hand-rolled variants.
//
// Look: a clean x.svg glyph in an outlined box — transparent fill at rest
// (NOT a grey-filled box), a 1px border-strong outline, and a uniform
// Theme.danger tint on hover (fill + border + glyph all shift to danger). Size
// defaults to 30×30 with a 16px glyph (the tile-chrome size, the largest /
// reference close); `box` + `glyph` can be overridden only where a row's
// geometry genuinely demands a different size.
//
// NOT used by: the overlay BAR quit (it is one chip in a chip toolbar — must
// match its 8 sibling chips, not a 30px box) and the SETTINGS close (a labelled
// full-width action at the bottom of the nav, not a corner). Those two stay in
// their own contexts but share the same x.svg + danger-hover language.
import { Theme } from "theme.slint";

export component CloseButton inherits Rectangle {
    in property <length> box: 30px;
    in property <length> glyph: 16px;
    callback clicked();

    width: root.box;
    height: root.box;
    horizontal-stretch: 0;
    border-radius: 6px;
    border-width: 1px;
    border-color: cbta.has-hover ? Theme.danger.with-alpha(0.55) : Theme.border-strong;
    background: cbta.has-hover ? Theme.danger.with-alpha(0.16) : transparent;
    animate background, border-color { duration: 120ms; }

    Image {
        source: @image-url("../assets/icons/x.svg");
        colorize: cbta.has-hover ? Theme.danger : Theme.text-secondary;
        width: root.glyph;
        height: root.glyph;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    cbta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// ТЗ 2026-07-03 — selectable read-only text (shared by tiles/summaries/archive
// AND the transcript). Slint's `Text` can't be selected; a read-only `TextInput`
// can — real mouse drag / double-click word / triple-click paragraph / Ctrl+A —
// while still growing to its wrapped content in a layout. A right-click
// ContextMenuArea offers «Copy selection» + «Add selection to memory»; the
// selection's byte offsets ride out through `capture(anchor, cursor)` (Rust slices
// the source text and orders them).
//
// The ContextMenuArea is a CHILD, not the base — `inherits ContextMenuArea` panics
// the Slint compiler (special-lowered in the menu pass, cannot be subclassed).
//
// Root is a Rectangle whose height is bound to the TextInput's wrapped height. A
// ContextMenuArea reports ZERO layout-info (its Menu is lowered to a separate item
// tree BEFORE layout, so a box layout measures the menu cell as 0) — a layout root
// would collapse to 0 and the un-clipped text would paint over the next block
// (the header/code/table overlap bug). A Rectangle root makes the ContextMenuArea a
// non-layout child that fills the root (100%×100%); the TextInput fills that, so
// `ti.preferred-height` = wrapped height at the assigned width, and we bind the root
// to it. This is exactly how std-widgets' TextEditBase sizes its viewport
// (`text-input.preferred-height`). No cycle: preferred-height depends on width only.
export component SelectableText inherits Rectangle {
    height: ti.preferred-height;
    in property <string> text;
    in property <length> font-size: 12px;
    in property <int> font-weight: 400;
    in property <brush> text-color;
    in property <TextWrap> wrap: word-wrap;
    in property <string> mono-family;   // "" = default proportional font
    // (anchor-byte-offset, cursor-byte-offset) of the current selection.
    callback capture(int, int);
    ContextMenuArea {
        Menu {
            MenuItem {
                title: @tr("Copy selection");
                activated => { ti.copy(); }
            }
            MenuItem {
                title: @tr("Add selection to memory");
                activated => { root.capture(ti.anchor-position-byte-offset, ti.cursor-position_byte-offset); }
            }
        }
        ti := TextInput {
            text: root.text;
            read-only: true;
            single-line: false;
            wrap: root.wrap;
            font-size: root.font-size;
            font-weight: root.font-weight;
            font-family: root.mono-family;
            color: root.text-color;
            selection-background-color: Theme.accent.with-alpha(0.35);
            // Cyrillic-layout shim (same as text_ask.slint): Slint binds Ctrl+C/A to
            // the Latin c/a; under a RU layout the physical keys emit с/ф, so the
            // built-in shortcuts die. Latin c/a are handled natively (read-only still
            // allows copy/select-all).
            key-pressed(e) => {
                if (e.modifiers.control && !e.modifiers.shift) {
                    if (e.text == "с" || e.text == "С") { ti.copy(); return accept; }
                    if (e.text == "ф" || e.text == "Ф") { ti.select-all(); return accept; }
                }
                return reject;
            }
        }
    }
}
