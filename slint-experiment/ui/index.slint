// Single compilation root for build.rs — slint_build::compile() only
// emits one output file, so multiple compile() calls clobber each other.
// Importing each component file here and re-exporting them lets each
// binary access whatever it needs via `slint::include_modules!()`.

import { MainWindow, FilterChip, ReplayEvent } from "replay.slint";
import { OverlaySpike } from "overlay_spike.slint";
import { MarkdownSpike } from "markdown_spike.slint";
import { OverlayBarWindow } from "overlay_bar.slint";
import { TileWindow, MarkdownBlock } from "tile.slint";
import { SettingsWindow } from "settings_panel.slint";
import { PaletteWindow, PaletteResult } from "palette.slint";
import { CaptureOverlay } from "capture_overlay.slint";
import { TextAskWindow } from "text_ask.slint";
// Re-export the design-token global so the Rust host can reach it
// (`win.global::<Theme>().set_scheme(n)`) to switch colour schemes live
// across every window instance — Theme is a PER-WINDOW global, so each
// window must be set individually.
import { Theme } from "theme.slint";

export {
    MainWindow, FilterChip, ReplayEvent,
    OverlaySpike,
    MarkdownSpike,
    OverlayBarWindow, TileWindow, MarkdownBlock, SettingsWindow,
    PaletteWindow, PaletteResult,
    CaptureOverlay,
    TextAskWindow,
    Theme,
}
