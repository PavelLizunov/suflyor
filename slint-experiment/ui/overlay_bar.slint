// =====================================================================
// Overlay bar — always-on-top strip above the meeting window.
//
// Phase E6 v15 — integrated Anthropic-design redesign:
//   - StatusPill (left): dot + label, halo pulse when "thinking",
//     red treatment when error-state
//   - LiveChip for mic/sys: filled when active, semantic colour
//     (green mic, orange sys)
//   - Generic Chip: timer, model, cost, aggressive — accent ONLY
//     on border (calm peripheral aesthetic), filled when emphasised
//   - IconBtn ghost icons: tips, bm, stealth, settings, quit
//   - VDivider between groups (instead of just spacing)
//   - "+ tile (N)" is the only primary chip (filled indigo)
//
// Bottom row (Phase E6 v11): live transcript line + AI streaming
// pill so user sees the pipeline working.
//
// Public API (UNCHANGED — overlay_host.rs wires 1:1):
//   props:     status-text, status-color, mic-active, sys-active,
//              timer-label, timer-active, ai-model, cost-label,
//              tiles-spawned, aggressive-active, last-transcript-line,
//              last-transcript-source, ai-streaming
//   callbacks: mic-toggle-clicked, sys-toggle-clicked,
//              timer-toggle-clicked, ai-model-cycle-clicked,
//              spawn-tile-clicked, bookmark-clicked, tips-clicked,
//              stealth-toggle-clicked, aggressive-toggle-clicked,
//              open-settings-clicked, quit-clicked
//
// New optional props (default-safe):
//   error-state  bool — flips StatusPill to red treatment
//   thinking     bool — halo pulse on the status dot
//   cost-warn    bool — cost chip fills yellow when cap exceeded
// =====================================================================

import { Theme } from "tokens.slint";

// ----- StatusPill: dot + text. Halo-pulses when thinking. ------------
component StatusPill inherits Rectangle {
    in property <string> label;
    in property <color>  accent: Theme.text-mute;
    in property <bool>   pulse: false;
    in property <bool>   error-state: false;

    height: 24px;
    border-radius: Theme.r-pill;
    border-width: 1px;
    background: root.error-state
        ? Theme.error.with-alpha(0.12)
        : root.accent.with-alpha(0.10);
    border-color: root.error-state
        ? Theme.error.with-alpha(0.55)
        : root.accent.with-alpha(0.35);

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 6px;
        alignment: start;
        Rectangle {
            width: 8px; height: 8px;
            border-radius: 4px;
            background: root.error-state ? Theme.error : root.accent;
            y: (parent.height - self.height) / 2;
            // Halo
            Rectangle {
                x: -4px; y: -4px;
                width: 16px; height: 16px;
                border-radius: 8px;
                background: parent.background.with-alpha(0.35);
                opacity: root.pulse ? 1.0 : 0;
                animate opacity {
                    duration: 1200ms;
                    iteration-count: -1;
                    easing: ease-in-out;
                    direction: alternate;
                }
            }
        }
        Text {
            text: root.label;
            font-size: Theme.fs-11;
            font-weight: 600;
            color: root.error-state ? Theme.error : root.accent;
            vertical-alignment: center;
        }
    }
}

// ----- LiveChip: chip with leading dot. Active = filled. -------------
component LiveChip inherits Rectangle {
    in property <string> label;
    in property <bool>   active: false;
    in property <color>  accent: Theme.mic;
    callback clicked();

    accessible-role: button;
    accessible-label: label;
    accessible-checkable: true;
    accessible-checked: active;

    height: 24px;
    border-radius: Theme.r-pill;
    border-width: 1px;
    background: root.active
        ? root.accent.with-alpha(0.16)
        : (ta.has-hover ? Theme.bg-3.with-alpha(0.6) : transparent);
    border-color: root.active
        ? root.accent.with-alpha(0.55)
        : Theme.border;
    animate background, border-color { duration: Theme.dur-base; }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 6px;
        Rectangle {
            width: 7px; height: 7px;
            border-radius: 4px;
            background: root.active ? root.accent : Theme.border-strong;
            y: (parent.height - self.height) / 2;
            animate background { duration: Theme.dur-base; }
        }
        Text {
            text: root.label;
            font-size: Theme.fs-11;
            font-weight: 600;
            color: root.active ? root.accent : Theme.text-mute;
            vertical-alignment: center;
            animate color { duration: Theme.dur-base; }
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
    states [
        pressed when ta.pressed: { opacity: 0.7; }
    ]
}

// ----- Generic chip (timer, model, cost, aggressive). Accent on border.
component Chip inherits Rectangle {
    in property <string> label;
    in property <color>  accent: Theme.text-mute;
    in property <bool>   emphasised: false;
    callback clicked();

    accessible-role: button;
    accessible-label: label;

    height: 24px;
    border-radius: Theme.r-pill;
    border-width: 1px;
    background: root.emphasised
        ? root.accent.with-alpha(0.14)
        : (ta.has-hover ? Theme.bg-3.with-alpha(0.55) : transparent);
    border-color: root.emphasised
        ? root.accent.with-alpha(0.5)
        : Theme.border;
    animate background, border-color { duration: Theme.dur-base; }
    horizontal-stretch: 0;

    HorizontalLayout {
        padding-left: 9px;
        padding-right: 10px;
        alignment: center;
        Text {
            text: root.label;
            font-size: Theme.fs-11;
            font-weight: root.emphasised ? 600 : 500;
            color: root.emphasised ? root.accent : Theme.text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
    states [
        pressed when ta.pressed: { opacity: 0.7; }
    ]
}

// ----- Icon-only ghost button (tips/bm/stealth/settings/quit) --------
component IconBtn inherits Rectangle {
    in property <string> glyph;
    in property <color>  hover-accent: Theme.text-mute;
    in property <bool>   destructive: false;
    callback clicked();

    accessible-role: button;
    accessible-label: glyph;

    width: 32px;
    height: 24px;
    border-radius: Theme.r-pill;
    border-width: 1px;
    background: ta.has-hover
        ? (root.destructive
            ? Theme.error.with-alpha(0.12)
            : root.hover-accent.with-alpha(0.10))
        : transparent;
    border-color: ta.has-hover
        ? (root.destructive
            ? Theme.error.with-alpha(0.5)
            : root.hover-accent.with-alpha(0.3))
        : Theme.border-soft;
    animate background, border-color { duration: Theme.dur-base; }

    Text {
        text: root.glyph;
        font-size: Theme.fs-12;
        color: ta.has-hover
            ? (root.destructive ? Theme.error : root.hover-accent)
            : Theme.text-mute;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: Theme.dur-base; }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
    states [
        pressed when ta.pressed: { opacity: 0.7; }
    ]
}

// ----- Vertical separator between chip groups -------------------------
component VDivider inherits Rectangle {
    width: 1px;
    height: 14px;
    background: Theme.border-soft;
}

// =====================================================================
// OverlayBarWindow
// =====================================================================

export component OverlayBarWindow inherits Window {
    title: "overlay-mvp (Slint)";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    // Wider preferred-width so all chips + transcript row fit on
    // primary 1920px screen. Bumped height to fit transcript row.
    preferred-width: 980px;
    preferred-height: 78px;
    min-width: 700px;

    // ===== Public state ===============================================
    in-out property <string> status-text: "idle";
    in-out property <color>  status-color: Theme.text-mute;
    in-out property <bool>   mic-active: false;
    in-out property <bool>   sys-active: false;
    in-out property <string> timer-label: "00:00";
    in-out property <bool>   timer-active: false;
    in-out property <string> ai-model: "sonnet";
    in-out property <string> cost-label: "$0.000";
    in-out property <int>    tiles-spawned: 0;
    in-out property <bool>   aggressive-active: false;
    in-out property <string> last-transcript-line: "";
    in-out property <string> last-transcript-source: "";
    in-out property <bool>   ai-streaming: false;

    // New optional (default-safe):
    in-out property <bool>   error-state: false;
    in-out property <bool>   thinking: false;
    in-out property <bool>   cost-warn: false;

    // ===== Callbacks (unchanged) ======================================
    callback mic-toggle-clicked();
    callback sys-toggle-clicked();
    callback timer-toggle-clicked();
    callback ai-model-cycle-clicked();
    callback spawn-tile-clicked();
    callback bookmark-clicked();
    callback tips-clicked();
    callback stealth-toggle-clicked();
    callback aggressive-toggle-clicked();
    callback open-settings-clicked();
    callback quit-clicked();

    // ---- Shell ------------------------------------------------------
    Rectangle {
        background: Theme.glass;
        border-radius: Theme.r-4;
        border-width: 1px;
        border-color: Theme.glass-border;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000088;
        drop-shadow-offset-y: 8px;

        VerticalLayout {
            padding-left: 8px;
            padding-right: 8px;
            padding-top: 5px;
            padding-bottom: 5px;
            spacing: 3px;

            // === Chip row ==========================================
            HorizontalLayout {
                spacing: 5px;
                alignment: start;

                StatusPill {
                    label: root.status-text;
                    accent: root.status-color;
                    pulse: root.thinking;
                    error-state: root.error-state;
                }

                LiveChip {
                    label: "🎤 mic";
                    active: root.mic-active;
                    accent: Theme.mic;
                    clicked => { root.mic-toggle-clicked(); }
                }

                LiveChip {
                    label: "🔊 sys";
                    active: root.sys-active;
                    accent: Theme.system;
                    clicked => { root.sys-toggle-clicked(); }
                }

                VDivider {}

                // Timer with start-hint (cycle 17).
                Chip {
                    label: root.timer-active
                        ? "⏸ " + root.timer-label
                        : "▶ start";
                    accent: Theme.warn;
                    emphasised: root.timer-active;
                    clicked => { root.timer-toggle-clicked(); }
                }

                Chip {
                    label: "🧠 " + root.ai-model;
                    accent: Theme.info;
                    clicked => { root.ai-model-cycle-clicked(); }
                }

                Chip {
                    label: root.cost-label;
                    accent: Theme.warn;
                    emphasised: root.cost-warn;
                }

                VDivider {}

                // Action glyphs (ghost).
                IconBtn {
                    glyph: "💡"; hover-accent: Theme.warn;
                    clicked => { root.tips-clicked(); }
                }
                IconBtn {
                    glyph: "⭐"; hover-accent: Theme.warn;
                    clicked => { root.bookmark-clicked(); }
                }
                IconBtn {
                    glyph: "🎯"; hover-accent: Theme.ai;
                    clicked => { root.stealth-toggle-clicked(); }
                }
                // Aggressive auto-tile toggle (cycle 15).
                Chip {
                    label: root.aggressive-active ? "🔥 auto-ON" : "🔥 auto";
                    accent: Theme.system;
                    emphasised: root.aggressive-active;
                    clicked => { root.aggressive-toggle-clicked(); }
                }

                // Spring spacer
                Rectangle { horizontal-stretch: 1; min-width: 8px; }

                // + tile (primary action).
                Chip {
                    label: "+ tile (" + root.tiles-spawned + ")";
                    accent: Theme.auto;
                    emphasised: true;
                    clicked => { root.spawn-tile-clicked(); }
                }
                IconBtn {
                    glyph: "⚙"; hover-accent: Theme.text;
                    clicked => { root.open-settings-clicked(); }
                }
                IconBtn {
                    glyph: "X"; hover-accent: Theme.error;
                    destructive: true;
                    clicked => { root.quit-clicked(); }
                }
            }

            // === Live status row (cycle 16) ========================
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 6px;
                Rectangle {
                    width: 8px;
                    height: 8px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 4px;
                    background: root.last-transcript-source == "mic"
                        ? Theme.mic
                        : (root.last-transcript-source == "sys"
                            ? Theme.system
                            : Theme.border-strong);
                }
                Text {
                    text: root.last-transcript-line == ""
                        ? "🎙 ожидаю транскрипт... (mic/sys → STT)"
                        : root.last-transcript-line;
                    font-size: Theme.fs-11;
                    color: root.last-transcript-line == ""
                        ? Theme.text-dim
                        : Theme.text-mute;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Rectangle {
                    width: root.ai-streaming ? 90px : 0px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: root.ai-streaming
                        ? Theme.ai.with-alpha(0.18)
                        : transparent;
                    border-color: Theme.ai;
                    border-width: root.ai-streaming ? 1px : 0px;
                    border-radius: 9px;
                    horizontal-stretch: 0;
                    Text {
                        visible: root.ai-streaming;
                        text: "🧠 AI streaming";
                        font-size: 10px;
                        color: Theme.ai;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}
