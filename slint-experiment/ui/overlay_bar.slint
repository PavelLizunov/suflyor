// Real overlay bar with full chip set.
//
// Ports the structural pattern of src/Overlay.tsx: a horizontal strip
// of small chips on a translucent dark rounded background, drawn
// always on top + transparent + click-through. Each chip is a reusable
// Component so future chips slot in without touching the layout.
//
// Consumed by the `overlay-host` binary (src/bin/overlay_host.rs)
// which wires every callback to real backend modules: audio probe,
// AI ask, KB palette, hotkey dispatch, journal bookmark, etc.

import { Button } from "std-widgets.slint";

// ===== Reusable chip primitives =====

// Generic chip: rounded background + 1px border + small label, with
// an optional active state for the colored variant.
component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> accent: #6cf;

    callback clicked();

    accessible-role: button;
    accessible-label: label;

    background: active ? accent.with-alpha(0.18) : transparent;
    border-color: active ? accent : #3a3c44;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;
    horizontal-stretch: 0;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: label;
            font-size: 11px;
            color: active ? accent : #c8c8cc;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// Active-indicator chip: chip with a small pulsing dot prefix that
// represents an "active" / "live" capture state. Used for mic + sys.
component LiveChip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> accent: #34d399;

    callback clicked();

    accessible-role: button;
    accessible-label: label;
    accessible-checkable: true;
    accessible-checked: active;

    background: active ? accent.with-alpha(0.18) : transparent;
    border-color: active ? accent : #3a3c44;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 8px;
        spacing: 4px;
        // Dot indicator
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: active ? accent : #4a4c54;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: label;
            font-size: 11px;
            color: active ? accent : #c8c8cc;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// Phase E6 v42 — push-to-record button. HOLD to record: pointer-down
// fires `pressed`, pointer-up fires `released` (Slint grabs the pointer
// on press, so `up` lands here even if the cursor drifts off). Rust
// records the chosen source while held, then transcribes + asks AI on
// release. Turns red with a filled dot while `recording` (set by Rust);
// no ⏺ glyph — a Rectangle dot dodges the missing-glyph font issue.
component RecordBtn inherits Rectangle {
    in property <string> label;
    in property <color> accent: #34d399;
    in property <bool> recording: false;
    callback pressed();
    callback released();

    accessible-role: button;
    accessible-label: label;

    background: recording ? #ef444433 : transparent;
    border-color: recording ? #ef4444 : #3a3c44;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;
    horizontal-stretch: 0;
    animate background, border-color { duration: 120ms; }

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 8px;
        spacing: 5px;
        // Record dot: filled red while recording, hollow accent ring idle.
        Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            y: (parent.height - self.height) / 2;
            background: root.recording ? #ef4444 : transparent;
            border-width: root.recording ? 0px : 1px;
            border-color: root.accent;
        }
        Text {
            text: root.label;
            font-size: 11px;
            color: root.recording ? #ef4444 : #c8c8cc;
            vertical-alignment: center;
        }
    }
    TouchArea {
        mouse-cursor: pointer;
        pointer-event(ev) => {
            if (ev.button == PointerEventButton.left) {
                if (ev.kind == PointerEventKind.down) { root.pressed(); }
                if (ev.kind == PointerEventKind.up) { root.released(); }
            }
        }
    }
}

// Phase E6 v44 — thin vertical separator between chip groups. Fixed
// height (Slint forbids `parent.*` inside a component body); the
// HorizontalLayout centres it on the cross axis.
component VDivider inherits Rectangle {
    width: 1px;
    height: 16px;
    background: #3a3c44;
}

// ===== Main overlay bar =====

export component OverlayBarWindow inherits Window {
    title: "overlay-mvp (Slint)";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    // Phase E6 v10 — widened from 720 to 980 so new chip labels
    // (💡 tips, ⭐ bm, 🎯 stealth, 🔥 auto, ⚙ settings, X quit) all
    // fit without truncating the rightmost (X quit) chip.
    // Phase E6 v11 — height bumped 56 → 86 to fit live transcript row.
    // Phase E6 v38 — widened 980 → 1140: the Russian chip labels
    // (подсказки / закладка / скрытность / настройки / выход) are wider
    // than the English originals and were clipping the rightmost chip.
    // Phase E6 v44 — narrowed 1320 → 1000: the grouped layout makes the
    // capture toggles + quick actions icon-only, so the row is far more
    // compact (icons + 3 short labels instead of 15 text chips).
    // E10.2 — 1000 → 1080 after the "close all" chip landed, so the Settings
    // + quit chips never clip; the active-stack readout moved to the bottom
    // status row to keep the action row compact.
    preferred-width: 1080px;
    preferred-height: 86px;
    min-width: 720px;

    // Status pill text (idle / recording / etc).
    in-out property <string> status-text: "idle";
    in-out property <color> status-color: #999;

    // Live capture flags.
    in-out property <bool> mic-active: false;
    in-out property <bool> sys-active: false;

    // Session timer label (formatted by Rust, e.g. "03:42").
    in-out property <string> timer-label: "00:00";
    in-out property <bool> timer-active: false;

    // Phase E10.2 — read-only "active stack" readout: which STT engine +
    // which AI model are actually live, with a 🟢 local / ☁ cloud / ◐ mixed
    // icon. So the user can tell at a glance what's transcribing + answering.
    in-out property <string> active-stack: "";

    // Cumulative session cost (formatted by Rust, e.g. "$0.024").
    in-out property <string> cost-label: "$0.000";

    // Tile counter for the "+ Tile" button.
    in-out property <int> tiles-spawned: 0;

    // #B1 — LIVE count of currently-open tiles (Rust keeps this in sync with
    // the TileWindows vec on every spawn/close). Drives the "+ tile (N)" label
    // and gates the "close all" chip, so closing tiles via their own X buttons
    // updates the bar (tiles-spawned is a CUMULATIVE counter and must NOT be
    // used for these — it never decrements except on close-all).
    in-out property <int> open-tiles: 0;

    // Phase E6 v10 — aggressive (every-line) auto-tile mode flag.
    // When true, the bar shows the "🔥 auto" chip lit; user can
    // toggle to spawn a tile on every transcript line (vs. only on
    // Question/Keyword triggers). Backend already supports it via
    // cfg.auto_tile_every_line; this just surfaces the switch.
    in-out property <bool> aggressive-active: false;
    // E10.2 — stealth on/off, so the 🎯 chip lights up + reflects restored state.
    in-out property <bool> stealth-active: false;

    // Phase E6 v11 — live status indicators. `last-transcript-line`
    // shows the most recent STT output (truncated by Rust to ~120
    // chars) below the chip row so user sees "транскрипция работает".
    // `ai-streaming` lights up the AI model chip background pulse so
    // user sees "AI работает" while a tile is mid-stream.
    in-out property <string> last-transcript-line: "";
    in-out property <bool> ai-streaming: false;
    // Source tag for the transcript line — "mic" / "sys" / "" to
    // colour-code which side of the conversation it came from.
    in-out property <string> last-transcript-source: "";

    // Phase E6 v42 — push-to-record (hold) state. Rust flips these true
    // while the corresponding source is recording so the button glows red.
    in-out property <bool> mic-recording: false;
    in-out property <bool> sys-recording: false;

    // Phase E6 v45 — ⚙ Settings chip lights up while the Settings window
    // is open (Rust flips this on open / close). User: "значок настроек
    // не загорается когда настройки открыты".
    in-out property <bool> settings-open: false;
    // Phase E6 v45 — X quit is two-step: first press arms an inline
    // "Quit? Yes/No" confirm (Rust auto-disarms after a few seconds) so a
    // stray click can't kill the app. User: "крестик моментально всё
    // закрывает без предупреждения".
    in-out property <bool> quit-armed: false;

    // ===== Callbacks =====
    callback mic-toggle-clicked();
    callback sys-toggle-clicked();
    // Phase E6 v42 — push-to-record hold callbacks (down = start, up = stop).
    callback ptt-mic-pressed();
    callback ptt-mic-released();
    callback ptt-sys-pressed();
    callback ptt-sys-released();
    callback timer-toggle-clicked();
    callback spawn-tile-clicked();
    callback close-all-tiles-clicked();
    callback stealth-toggle-clicked();
    callback aggressive-toggle-clicked();
    callback open-settings-clicked();
    callback quit-clicked();   // X pressed → Rust arms the inline confirm
    callback quit-confirm();   // "Yes" → really quit the app
    callback quit-cancel();    // "No" → disarm the confirm
    // Phase E6 v22 — manual cursor-delta drag (replaces modal
    // WM_NCLBUTTONDOWN which left TouchArea stuck pressed). down →
    // drag-start-requested (anchor), move-while-pressed → drag-moved.
    callback drag-start-requested();
    callback drag-moved();

    Rectangle {
        background: #14161eea;
        border-radius: 12px;
        border-width: 1px;
        border-color: #2a2c3a;

        // Phase E6 v21 — bar drag is now SCOPED to the status pill
        // only (see drag-handle TouchArea inside the pill below).
        // Cycle 20's full-background TouchArea stole every chip click
        // because Slint's pointer-event fires for ALL events in the
        // bbox even when children have their own TouchAreas (same
        // root cause as tile chrome cycle 10). User: "интерфейс
        // сразу стал не кликабельным". Now only the ~80px status
        // pill is the drag zone; every chip is freely clickable.

        VerticalLayout {
            padding: 6px;
            spacing: 4px;

        HorizontalLayout {
            padding: 2px;
            spacing: 6px;
            alignment: start;

            // Status pill (left edge) — DOUBLES AS DRAG HANDLE.
            // It has no click action of its own, so a pointer-event
            // TouchArea here is safe: its bbox is only the pill, so
            // it can't shadow the sibling chips' TouchAreas.
            Rectangle {
                background: root.status-color.with-alpha(0.18);
                border-color: root.status-color;
                border-width: 1px;
                border-radius: 10px;
                height: 22px;
                horizontal-stretch: 0;
                // Drag handle — press-and-drag to move the whole bar.
                TouchArea {
                    mouse-cursor: grab;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left
                            && ev.kind == PointerEventKind.down) {
                            root.drag-start-requested();
                        }
                    }
                    moved => {
                        if (self.pressed) { root.drag-moved(); }
                    }
                }
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 0px;
                    // Phase E6 v26 — ":: " grip in accent #6cf (matches
                    // Settings header) so the drag affordance reads the
                    // same in both windows. Status text keeps its
                    // state colour.
                    Text {
                        text: "::";
                        font-size: 11px;
                        font-weight: 600;
                        color: #6cf;
                        vertical-alignment: center;
                    }
                    Text {
                        text: " " + root.status-text;
                        font-size: 11px;
                        font-weight: 600;
                        color: root.status-color;
                        vertical-alignment: center;
                    }
                }
            }

            // Phase E6 v44 — grouped, scannable layout (user: "слишком
            // много надписей в ряд"). Groups separated by VDividers:
            // [state] · [capture toggles] · [push-to-ask] · [session info]
            // · [quick actions] · →spring→ · [primary + system]. Toggles
            // and secondary actions are ICON-ONLY; the push-to-record
            // buttons keep words (the key feature) with a colour-coded
            // record dot (green=mic, cyan=sys).

            // ── Capture toggles (continuous mic / sys) — icon-only + dot ──
            LiveChip {
                label: "🎤";
                active: root.mic-active;
                accent: #34d399;
                clicked => { root.mic-toggle-clicked(); }
            }
            LiveChip {
                label: "🔊";
                active: root.sys-active;
                accent: #6cf;
                clicked => { root.sys-toggle-clicked(); }
            }

            VDivider { }

            // ── Push-to-record (hold to ask) — labelled; dot colour marks
            //    the source: green = mic (your voice), cyan = sys (them).
            RecordBtn {
                label: @tr("ask");
                accent: #34d399;
                recording: root.mic-recording;
                pressed => { root.ptt-mic-pressed(); }
                released => { root.ptt-mic-released(); }
            }
            RecordBtn {
                label: @tr("grab");
                accent: #6cf;
                recording: root.sys-recording;
                pressed => { root.ptt-sys-pressed(); }
                released => { root.ptt-sys-released(); }
            }

            VDivider { }

            // ── Session info (timer / model / cost) ──
            Chip {
                label: root.timer-active
                    ? @tr("⏸ {}", root.timer-label)
                    : @tr("▶ start");
                active: root.timer-active;
                accent: #fbbf24;
                clicked => { root.timer-toggle-clicked(); }
            }
            Chip {
                label: root.cost-label;
                accent: #f59e0b;
                clicked => { /* no-op for now */ }
            }

            VDivider { }

            // ── Quick actions — icon-only (stealth / auto)
            Chip {
                label: "🎯";
                active: root.stealth-active;
                accent: #ec4899;
                clicked => { root.stealth-toggle-clicked(); }
            }
            Chip {
                label: "🔥";
                active: root.aggressive-active;
                accent: #fb923c;
                clicked => { root.aggressive-toggle-clicked(); }
            }

            // Spring spacer — pushes the primary + system cluster right.
            Rectangle { horizontal-stretch: 1; min-width: 12px; }

            // ── Primary + system ──
            // Close-all appears once tiles have been spawned so the user can
            // dismiss a screenful in one click (#110); resets the counter,
            // which also hides this chip again.
            if root.open-tiles > 0 : Chip {
                label: @tr("close all");
                accent: #fb7185;
                clicked => { root.close-all-tiles-clicked(); }
            }
            Chip {
                label: @tr("+ tile ({})", root.open-tiles);
                accent: #f472b6;
                clicked => { root.spawn-tile-clicked(); }
            }
            Chip {
                label: "⚙";
                active: root.settings-open;
                accent: #94a3b8;
                clicked => { root.open-settings-clicked(); }
            }
            // Quit — two-step. Idle: a single ASCII "X" (Unicode ✕ renders
            // as a missing-glyph box on the Slint+skia fallback). Armed:
            // inline "Quit? [Yes] [No]" so a stray click can't kill the app.
            if !root.quit-armed : Chip {
                label: "X";
                accent: #ef4444;
                clicked => { root.quit-clicked(); }
            }
            if root.quit-armed : HorizontalLayout {
                spacing: 4px;
                Text {
                    text: @tr("Quit?");
                    font-size: 11px;
                    font-weight: 600;
                    color: #e8e8ec;
                    vertical-alignment: center;
                }
                Chip {
                    label: @tr("Yes");
                    active: true;
                    accent: #ef4444;
                    clicked => { root.quit-confirm(); }
                }
                Chip {
                    label: @tr("No");
                    accent: #6cf;
                    clicked => { root.quit-cancel(); }
                }
            }
        }

        // ===== Live status row =====
        // Phase E6 v11 — bottom row shows last transcript line + AI
        // streaming indicator. Gives the user immediate visual proof
        // that STT and AI are working without opening a separate
        // window or watching a log file.
        HorizontalLayout {
            padding-left: 4px;
            padding-right: 4px;
            spacing: 6px;
            // Active-stack readout (read-only) — moved here from the top row
            // so Settings + quit fit. Shows local/cloud/mixed · STT · AI model.
            Text {
                text: root.active-stack;
                font-size: 10px;
                font-weight: 600;
                color: #6cf;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            // Source tag — "mic" green dot, "sys" cyan dot, "" gray.
            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: root.last-transcript-source == "mic"
                    ? #34d399
                    : (root.last-transcript-source == "sys" ? #6cf : #3a3c44);
            }
            // The live transcript text — elide when too long.
            Text {
                text: root.last-transcript-line == ""
                    ? "🎙 ожидаю транскрипт... (mic/sys → STT)"
                    : root.last-transcript-line;
                font-size: 11px;
                color: root.last-transcript-line == "" ? #6a6c74 : #c8c8cc;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // AI streaming pulse — visible when an ask is in flight.
            Rectangle {
                width: root.ai-streaming ? 80px : 0px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                background: root.ai-streaming ? #818cf8.with-alpha(0.22) : transparent;
                border-color: #818cf8;
                border-width: root.ai-streaming ? 1px : 0px;
                border-radius: 9px;
                horizontal-stretch: 0;
                Text {
                    visible: root.ai-streaming;
                    text: "🧠 AI streaming";
                    font-size: 10px;
                    color: #818cf8;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
        }
    }
}
