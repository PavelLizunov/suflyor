// Real overlay bar with full chip set.
//
// Ports the structural pattern of src/Overlay.tsx: a horizontal strip
// of small chips on a translucent dark rounded background, drawn
// always on top + transparent + click-through. Each chip is a reusable
// Component so future chips slot in without touching the layout.
//
// Consumed by the `overlay-host` binary (src/bin/overlay_host.rs)
// which wires every callback to real backend modules: audio probe,
// AI ask, KB palette, hotkey dispatch, journal bookmark, etc.

import { Button } from "std-widgets.slint";

// ===== Reusable chip primitives =====

// Generic chip: rounded background + 1px border + small label, with
// an optional active state for the colored variant.
component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> accent: #6cf;

    callback clicked();

    accessible-role: button;
    accessible-label: label;

    background: active ? accent.with-alpha(0.18) : transparent;
    border-color: active ? accent : #3a3c44;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;
    horizontal-stretch: 0;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: label;
            font-size: 11px;
            color: active ? accent : #c8c8cc;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// Active-indicator chip: chip with a small pulsing dot prefix that
// represents an "active" / "live" capture state. Used for mic + sys.
component LiveChip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> accent: #34d399;

    callback clicked();

    accessible-role: button;
    accessible-label: label;
    accessible-checkable: true;
    accessible-checked: active;

    background: active ? accent.with-alpha(0.18) : transparent;
    border-color: active ? accent : #3a3c44;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 8px;
        spacing: 4px;
        // Dot indicator
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: active ? accent : #4a4c54;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: label;
            font-size: 11px;
            color: active ? accent : #c8c8cc;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// ===== Main overlay bar =====

export component OverlayBarWindow inherits Window {
    title: "overlay-mvp (Slint)";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    // Phase E6 v10 — widened from 720 to 980 so new chip labels
    // (💡 tips, ⭐ bm, 🎯 stealth, 🔥 auto, ⚙ settings, X quit) all
    // fit without truncating the rightmost (X quit) chip.
    // Phase E6 v11 — height bumped 56 → 86 to fit live transcript row.
    // Phase E6 v38 — widened 980 → 1140: the Russian chip labels
    // (подсказки / закладка / скрытность / настройки / выход) are wider
    // than the English originals and were clipping the rightmost chip.
    preferred-width: 1140px;
    preferred-height: 86px;
    min-width: 820px;

    // Status pill text (idle / recording / etc).
    in-out property <string> status-text: "idle";
    in-out property <color> status-color: #999;

    // Live capture flags.
    in-out property <bool> mic-active: false;
    in-out property <bool> sys-active: false;

    // Session timer label (formatted by Rust, e.g. "03:42").
    in-out property <string> timer-label: "00:00";
    in-out property <bool> timer-active: false;

    // AI model chip cycle: "sonnet" / "haiku" / "opus".
    in-out property <string> ai-model: "sonnet";

    // Cumulative session cost (formatted by Rust, e.g. "$0.024").
    in-out property <string> cost-label: "$0.000";

    // Tile counter for the "+ Tile" button.
    in-out property <int> tiles-spawned: 0;

    // Phase E6 v10 — aggressive (every-line) auto-tile mode flag.
    // When true, the bar shows the "🔥 auto" chip lit; user can
    // toggle to spawn a tile on every transcript line (vs. only on
    // Question/Keyword triggers). Backend already supports it via
    // cfg.auto_tile_every_line; this just surfaces the switch.
    in-out property <bool> aggressive-active: false;

    // Phase E6 v11 — live status indicators. `last-transcript-line`
    // shows the most recent STT output (truncated by Rust to ~120
    // chars) below the chip row so user sees "транскрипция работает".
    // `ai-streaming` lights up the AI model chip background pulse so
    // user sees "AI работает" while a tile is mid-stream.
    in-out property <string> last-transcript-line: "";
    in-out property <bool> ai-streaming: false;
    // Source tag for the transcript line — "mic" / "sys" / "" to
    // colour-code which side of the conversation it came from.
    in-out property <string> last-transcript-source: "";

    // ===== Callbacks =====
    callback mic-toggle-clicked();
    callback sys-toggle-clicked();
    callback timer-toggle-clicked();
    callback ai-model-cycle-clicked();
    callback spawn-tile-clicked();
    callback bookmark-clicked();
    callback tips-clicked();
    callback stealth-toggle-clicked();
    callback aggressive-toggle-clicked();
    callback open-settings-clicked();
    callback quit-clicked();
    // Phase E6 v22 — manual cursor-delta drag (replaces modal
    // WM_NCLBUTTONDOWN which left TouchArea stuck pressed). down →
    // drag-start-requested (anchor), move-while-pressed → drag-moved.
    callback drag-start-requested();
    callback drag-moved();

    Rectangle {
        background: #14161eea;
        border-radius: 12px;
        border-width: 1px;
        border-color: #2a2c3a;

        // Phase E6 v21 — bar drag is now SCOPED to the status pill
        // only (see drag-handle TouchArea inside the pill below).
        // Cycle 20's full-background TouchArea stole every chip click
        // because Slint's pointer-event fires for ALL events in the
        // bbox even when children have their own TouchAreas (same
        // root cause as tile chrome cycle 10). User: "интерфейс
        // сразу стал не кликабельным". Now only the ~80px status
        // pill is the drag zone; every chip is freely clickable.

        VerticalLayout {
            padding: 6px;
            spacing: 4px;

        HorizontalLayout {
            padding: 2px;
            spacing: 6px;
            alignment: start;

            // Status pill (left edge) — DOUBLES AS DRAG HANDLE.
            // It has no click action of its own, so a pointer-event
            // TouchArea here is safe: its bbox is only the pill, so
            // it can't shadow the sibling chips' TouchAreas.
            Rectangle {
                background: root.status-color.with-alpha(0.18);
                border-color: root.status-color;
                border-width: 1px;
                border-radius: 10px;
                height: 22px;
                horizontal-stretch: 0;
                // Drag handle — press-and-drag to move the whole bar.
                TouchArea {
                    mouse-cursor: grab;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left
                            && ev.kind == PointerEventKind.down) {
                            root.drag-start-requested();
                        }
                    }
                    moved => {
                        if (self.pressed) { root.drag-moved(); }
                    }
                }
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 0px;
                    // Phase E6 v26 — ":: " grip in accent #6cf (matches
                    // Settings header) so the drag affordance reads the
                    // same in both windows. Status text keeps its
                    // state colour.
                    Text {
                        text: "::";
                        font-size: 11px;
                        font-weight: 600;
                        color: #6cf;
                        vertical-alignment: center;
                    }
                    Text {
                        text: " " + root.status-text;
                        font-size: 11px;
                        font-weight: 600;
                        color: root.status-color;
                        vertical-alignment: center;
                    }
                }
            }

            // Live capture chips
            LiveChip {
                label: @tr("🎤 mic");
                active: root.mic-active;
                accent: #34d399;
                clicked => { root.mic-toggle-clicked(); }
            }

            LiveChip {
                label: @tr("🗣 sys");
                active: root.sys-active;
                accent: #6cf;
                clicked => { root.sys-toggle-clicked(); }
            }

            // Session timer — Phase E6 v12: label hints at what the
            // click does. User feedback: "нажать на часики не очень
            // очевидно" — the bare "⏱ 00:00" gave no hint that
            // clicking starts a session. Now shows "▶ start" when
            // idle, "⏸ MM:SS" when recording.
            Chip {
                label: root.timer-active
                    ? @tr("⏸ {}", root.timer-label)
                    : @tr("▶ start");
                active: root.timer-active;
                accent: #fbbf24;
                clicked => { root.timer-toggle-clicked(); }
            }

            // AI model selector
            Chip {
                label: @tr("🧠 {}", root.ai-model);
                accent: #818cf8;
                clicked => { root.ai-model-cycle-clicked(); }
            }

            // Cost display (always shown)
            Chip {
                label: root.cost-label;
                accent: #f59e0b;
                clicked => { /* no-op for now */ }
            }

            // AI tips / followups
            Chip {
                label: @tr("💡 tips");
                accent: #fde68a;
                clicked => { root.tips-clicked(); }
            }

            // Bookmark
            Chip {
                label: @tr("⭐ bm");
                accent: #fcd34d;
                clicked => { root.bookmark-clicked(); }
            }

            // Stealth toggle (hide from screen capture)
            Chip {
                label: @tr("🎯 stealth");
                accent: #ec4899;
                clicked => { root.stealth-toggle-clicked(); }
            }

            // Aggressive auto-tile mode (every transcript line spawns)
            Chip {
                label: root.aggressive-active ? @tr("🔥 auto-ON") : @tr("🔥 auto");
                accent: #fb923c;
                active: root.aggressive-active;
                clicked => { root.aggressive-toggle-clicked(); }
            }

            // Spring spacer
            Rectangle { horizontal-stretch: 1; }

            // Tile counter + spawn (F6 manual ask)
            Chip {
                label: @tr("+ tile ({})", root.tiles-spawned);
                accent: #f472b6;
                clicked => { root.spawn-tile-clicked(); }
            }

            // Settings
            Chip {
                label: @tr("⚙ settings");
                accent: #94a3b8;
                clicked => { root.open-settings-clicked(); }
            }

            // Quit (ASCII X — Unicode ✕ U+2715 renders as missing glyph
            // on some Slint+skia font fallbacks; same root cause as
            // tile close glyph fix in cycle 7)
            Chip {
                label: @tr("X quit");
                accent: #ef4444;
                clicked => { root.quit-clicked(); }
            }
        }

        // ===== Live status row =====
        // Phase E6 v11 — bottom row shows last transcript line + AI
        // streaming indicator. Gives the user immediate visual proof
        // that STT and AI are working without opening a separate
        // window or watching a log file.
        HorizontalLayout {
            padding-left: 4px;
            padding-right: 4px;
            spacing: 6px;
            // Source tag — "mic" green dot, "sys" cyan dot, "" gray.
            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: root.last-transcript-source == "mic"
                    ? #34d399
                    : (root.last-transcript-source == "sys" ? #6cf : #3a3c44);
            }
            // The live transcript text — elide when too long.
            Text {
                text: root.last-transcript-line == ""
                    ? "🎙 ожидаю транскрипт... (mic/sys → STT)"
                    : root.last-transcript-line;
                font-size: 11px;
                color: root.last-transcript-line == "" ? #6a6c74 : #c8c8cc;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // AI streaming pulse — visible when an ask is in flight.
            Rectangle {
                width: root.ai-streaming ? 80px : 0px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                background: root.ai-streaming ? #818cf8.with-alpha(0.22) : transparent;
                border-color: #818cf8;
                border-width: root.ai-streaming ? 1px : 0px;
                border-radius: 9px;
                horizontal-stretch: 0;
                Text {
                    visible: root.ai-streaming;
                    text: "🧠 AI streaming";
                    font-size: 10px;
                    color: #818cf8;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
        }
    }
}
