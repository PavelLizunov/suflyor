// Real overlay bar with full chip set.
//
// Ports the structural pattern of src/Overlay.tsx: a horizontal strip
// of small chips on a translucent dark rounded background, drawn
// always on top + transparent + click-through. Each chip is a reusable
// Component so future chips slot in without touching the layout.
//
// Consumed by the `overlay-host` binary (src/bin/overlay_host.rs)
// which wires every callback to real backend modules: audio probe,
// AI ask, KB palette, hotkey dispatch, journal bookmark, etc.

import { Button, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// ===== Reusable chip primitives =====

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.text-secondary;
    in property <length> glyph-size: 14px;
    in property <length> slot-width: 14px;
    in property <length> slot-height: 22px;
    width: slot-width;
    height: slot-height;
    horizontal-stretch: 0;

    Image {
        source: root.icon;
        colorize: root.tint;
        width: root.glyph-size;
        height: root.glyph-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component BrandStateMark inherits Rectangle {
    in property <bool> assistant-active: false;
    in property <length> mark-size: 22px;
    width: mark-size;
    height: mark-size;
    horizontal-stretch: 0;

    Image {
        source: root.assistant-active
            ? @image-url("../assets/brand-penguin.svg")
            : @image-url("../assets/brand-head.svg");
        colorize: Theme.is-light ? #111827 : #ffffff;
        width: root.mark-size;
        height: root.mark-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

// Generic chip: rounded background + 1px border + small label, with
// an optional active state for the colored variant.
component Chip inherits Rectangle {
    in property <string> label;
    // Design-system icon (skia-safe line SVG, tinted by `colorize` to the
    // chip's semantic colour). When `has-icon` is set, the icon renders in
    // place of (or alongside) the text. Icon-only chips set `a11y` so screen
    // readers still get a word instead of a glyph.
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <string> a11y;
    in property <bool> active: false;
    in property <color> accent: Theme.accent;

    callback clicked();

    accessible-role: button;
    accessible-label: label != "" ? label : a11y;

    // Hover + press feedback so a click is visibly registered. Action chips
    // (Stop / Expand / X …) had NO feedback at all — only the persistent
    // `active` toggle changed the background — so a click looked like nothing
    // happened (reported for the compact Stop). `active` still wins; otherwise
    // pressed flashes the accent, hover lifts a subtle fill.
    background: active
        ? accent.with-alpha(0.18)
        : (ta.pressed
            ? accent.with-alpha(0.34)
            : (ta.has-hover ? Theme.border-strong.with-alpha(0.22) : transparent));
    border-color: active ? accent : (ta.has-hover ? accent.with-alpha(0.6) : Theme.border-strong);
    border-width: 1px;
    border-radius: 10px;
    height: 22px;
    horizontal-stretch: 0;
    animate background { duration: 80ms; }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 4px;
        alignment: center;
        if root.has-icon : IconSlot {
            icon: root.icon;
            tint: active ? accent : Theme.text-secondary;
            glyph-size: 14px;
            slot-width: 14px;
            slot-height: 22px;
        }
        if root.label != "" : Text {
            text: label;
            font-size: 11px;
            color: active ? accent : Theme.text-secondary;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Compact reader-mode action button (design review #5). A 30×30 square icon
// button matching the status-plaque height so the compact pill has ONE control
// height (the shared 22px Chip read as smaller + had a tiny hit-target). `tint`
// is the RESTING icon colour: Stop passes red so it reads as STOP at a glance,
// not only on hover.
component CompactIconBtn inherits Rectangle {
    in property <image> icon;
    in property <string> a11y;
    in property <color> tint: Theme.text-secondary;
    in property <color> accent: Theme.accent;
    callback clicked();

    accessible-role: button;
    accessible-label: a11y;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border-width: 1px;
    border-color: cta.has-hover ? root.accent.with-alpha(0.6) : Theme.border-strong;
    background: cta.pressed
        ? root.accent.with-alpha(0.34)
        : (cta.has-hover ? Theme.border-strong.with-alpha(0.22) : transparent);
    horizontal-stretch: 0;
    animate background { duration: 80ms; }

    Image {
        source: root.icon;
        // Hover brightens toward `accent`; otherwise the resting `tint` (red for
        // Stop) so the colour is meaningful without interaction.
        colorize: cta.has-hover ? root.accent : root.tint;
        width: 16px;
        height: 16px;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
    cta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Active-indicator chip: chip with a small pulsing dot prefix that
// represents an "active" / "live" capture state. Used for mic + sys.
component LiveChip inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <string> a11y;
    in property <bool> active: false;
    in property <color> accent: Theme.success;

    callback clicked();

    accessible-role: button;
    accessible-label: label != "" ? label : a11y;
    accessible-checkable: true;
    accessible-checked: active;

    background: active ? accent.with-alpha(0.18) : transparent;
    border-color: active ? accent : Theme.border-strong;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 8px;
        spacing: 4px;
        // Dot indicator
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: active ? accent : Theme.border-strong;
            y: (parent.height - self.height) / 2;
        }
        if root.has-icon : IconSlot {
            icon: root.icon;
            tint: active ? accent : Theme.text-secondary;
            glyph-size: 14px;
            slot-width: 14px;
            slot-height: 22px;
        }
        if root.label != "" : Text {
            text: label;
            font-size: 11px;
            color: active ? accent : Theme.text-secondary;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// Phase E6 v42 — push-to-record button. HOLD to record: pointer-down
// fires `pressed`, pointer-up fires `released` (Slint grabs the pointer
// on press, so `up` lands here even if the cursor drifts off). Rust
// records the chosen source while held, then transcribes + asks AI on
// release. Turns red with a filled dot while `recording` (set by Rust);
// no ⏺ glyph — a Rectangle dot dodges the missing-glyph font issue.
component RecordBtn inherits Rectangle {
    in property <string> label;
    // Source icon (mic / speaker), tinted like the label.
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <color> accent: Theme.success;
    in property <bool> recording: false;
    callback pressed();
    callback released();

    // V0.8.4 — Telegram-style swipe-up-to-lock. Default flow is unchanged:
    // hold to record (pressed), release to send (released). NEW: while holding,
    // drag up past `lock-dy` → hands-free "locked" recording — releasing the
    // button no longer stops it (the chip becomes a STOP button: the dot turns
    // into a square; a fresh click stops + sends, reusing `released()`). Recording
    // is "record-until-released" in Rust, so locking just defers the released()
    // call — no Rust change needed. `press-y` is the pointer y at press; the
    // TouchArea grabs the pointer on press so `moved` keeps firing past the bounds.
    in-out property <bool> locked: false;
    property <length> press-y;
    property <bool> swallow-up: false;
    // Threshold kept small: the bar is pinned at the TOP of the screen, so the
    // cursor clamps at the screen edge ~43px above the chip — a larger threshold
    // would be unreachable without first moving the bar down.
    property <length> lock-dy: 24px;

    accessible-role: button;
    accessible-label: label;

    background: recording ? Theme.danger.with-alpha(0.2) : transparent;
    border-color: recording ? Theme.danger : Theme.border-strong;
    border-width: 1px;
    border-radius: 10px;
    height: 22px;
    horizontal-stretch: 0;
    animate background, border-color { duration: 120ms; }

    // Reset the lock whenever recording ends from any cause (release, stop-click,
    // watchdog timeout) so the chip never gets stuck in the locked/stop look.
    changed recording => {
        if (!self.recording) {
            self.locked = false;
        }
    }

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 8px;
        spacing: 5px;
        // Record dot: filled red while recording; a SQUARE (border-radius 0)
        // once locked to read as a "stop" affordance; hollow accent ring idle.
        Rectangle {
            width: 8px;
            height: 8px;
            border-radius: root.locked ? 0px : 4px;
            y: (parent.height - self.height) / 2;
            background: root.recording ? Theme.danger : transparent;
            border-width: root.recording ? 0px : 1px;
            border-color: root.accent;
        }
        if root.has-icon : IconSlot {
            icon: root.icon;
            tint: root.recording ? Theme.danger : Theme.text-secondary;
            glyph-size: 14px;
            slot-width: 14px;
            slot-height: 22px;
        }
        Text {
            text: root.label;
            font-size: 11px;
            color: root.recording ? Theme.danger : Theme.text-secondary;
            vertical-alignment: center;
        }
        if root.recording : IconSlot {
            icon: root.locked
                ? @image-url("../assets/icons/stop.svg")
                : @image-url("../assets/icons/arrow-up.svg");
            tint: root.locked ? Theme.danger : Theme.warning;
            glyph-size: 12px;
            slot-width: 12px;
            slot-height: 22px;
        }
    }
    TouchArea {
        mouse-cursor: pointer;
        pointer-event(ev) => {
            if (ev.button == PointerEventButton.left) {
                if (ev.kind == PointerEventKind.down) {
                    if (root.locked) {
                        // Fresh click while locked = STOP (same as a release).
                        root.locked = false;
                        root.swallow-up = true;
                        root.released();
                    } else {
                        root.press-y = self.mouse-y;
                        root.swallow-up = false;
                        root.pressed();
                    }
                }
                if (ev.kind == PointerEventKind.up) {
                    if (root.swallow-up) {
                        root.swallow-up = false;
                    } else if (!root.locked) {
                        root.released();
                    }
                    // locked && !swallow-up = the release that follows a lock →
                    // keep recording hands-free (do nothing).
                }
            }
        }
        moved => {
            // Gate on `recording` so a chip whose recording never started (e.g.
            // the mic was busy → on_ptt_*_pressed bailed) can't show a locked /
            // stop look without actually recording.
            if (self.pressed && root.recording && !root.locked
                && root.press-y - self.mouse-y > root.lock-dy) {
                root.locked = true;
            }
        }
    }
}

// Phase E6 v44 — thin vertical separator between chip groups. Fixed
// height (Slint forbids `parent.*` inside a component body); the
// HorizontalLayout centres it on the cross axis.
component VDivider inherits Rectangle {
    width: 1px;
    height: 16px;
    background: Theme.border-strong;
}

// ===== Main overlay bar =====

export component OverlayBarWindow inherits Window {
    // Phase 4 — keep std-widgets (Button etc.) dark with the active scheme
    // instead of Slint's light fluent default. See settings_panel for detail.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    title: "overlay-mvp (Slint)";
    icon: @image-url("../assets/icon.svg");
    background: transparent;
    no-frame: true;
    always-on-top: true;
    // Phase E6 v10 — widened from 720 to 980 so new chip labels
    // (💡 tips, ⭐ bm, 🎯 stealth, 🔥 auto, ⚙ settings, X quit) all
    // fit without truncating the rightmost (X quit) chip.
    // Phase E6 v11 — height bumped 56 → 86 to fit live transcript row.
    // Phase E6 v38 — widened 980 → 1140: the Russian chip labels
    // (подсказки / закладка / скрытность / настройки / выход) are wider
    // than the English originals and were clipping the rightmost chip.
    // Phase E6 v44 — narrowed 1320 → 1000: the grouped layout makes the
    // capture toggles + quick actions icon-only, so the row is far more
    // compact (icons + 3 short labels instead of 15 text chips).
    // E10.2 — 1000 → 1080 after the "close all" chip landed, so the Settings
    // + quit chips never clip; the active-stack readout moved to the bottom
    // status row to keep the action row compact.
    // V0.8.3 — 1080 → 1120 to absorb the new ✏ "Написать" chip's width and keep
    // the un-armed RU worst case (wide "⚠ AI недоступен" status + close-all + 2
    // open tiles) comfortably inside the fixed-width bar (single-row layout, so
    // total content — not cluster placement — is what clips).
    // Phase 3a — 1120 → 1160 to absorb the new 🗄 archive chip with the SAME
    // worst-case slack as the verified 1120 baseline (icon-only chip ≈ 30 px).
    // v0.12.0 — 1160 → 1200 to absorb the new 📝 Summary chip (icon-only,
    // ≈ 30 px) with the same RU worst-case slack (review-agent finding).
    preferred-width: 1200px;
    preferred-height: 86px;
    // Relax the min-width in compact "reader" mode so the runtime set_size(340)
    // isn't clamped back up (Slint propagates min-width to the OS as a minimum
    // inner size). Full bar keeps 720 so its chip row never collapses.
    min-width: root.compact-bar ? 300px : 720px;

    // Status pill text (idle / recording / etc).
    in-out property <string> status-text: "idle";
    in-out property <color> status-color: Theme.text-muted;

    // Live capture flags.
    in-out property <bool> mic-active: false;
    // v0.13.1 — mic muted (drops mic transcript + mic recording). Drives the
    // mic chip's slashed-icon + dimmed look.
    in-out property <bool> mic-muted: false;
    in-out property <bool> sys-active: false;

    // Session timer label (formatted by Rust, e.g. "03:42").
    in-out property <string> timer-label: "00:00";
    in-out property <bool> timer-active: false;

    // Phase E10.2 — read-only "active stack" readout: which STT engine +
    // which AI model are actually live, with a 🟢 local / ☁ cloud / ◐ mixed
    // icon. So the user can tell at a glance what's transcribing + answering.
    in-out property <string> active-stack: "";

    // Cumulative session cost (formatted by Rust, e.g. "$0.024").
    in-out property <string> cost-label: "$0.000";

    // Tile counter for the "+ Tile" button.
    in-out property <int> tiles-spawned: 0;

    // #B1 — LIVE count of currently-open tiles (Rust keeps this in sync with
    // the TileWindows vec on every spawn/close). Drives the "+ tile (N)" label
    // and gates the "close all" chip, so closing tiles via their own X buttons
    // updates the bar (tiles-spawned is a CUMULATIVE counter and must NOT be
    // used for these — it never decrements except on close-all).
    in-out property <int> open-tiles: 0;

    // Phase E6 v10 — aggressive (every-line) auto-tile mode flag.
    // When true, the bar shows the "🔥 auto" chip lit; user can
    // toggle to spawn a tile on every transcript line (vs. only on
    // Question/Keyword triggers). Backend already supports it via
    // cfg.auto_tile_every_line; this just surfaces the switch.
    in-out property <bool> aggressive-active: false;
    // E10.2 — stealth on/off, so the 🎯 chip lights up + reflects restored state.
    in-out property <bool> stealth-active: false;

    // Phase E6 v11 — live status indicators. `last-transcript-line`
    // shows the most recent STT output (truncated by Rust to ~120
    // chars) below the chip row so user sees "транскрипция работает".
    // `ai-streaming` lights up the AI model chip background pulse so
    // user sees "AI работает" while a tile is mid-stream.
    in-out property <string> last-transcript-line: "";
    in-out property <bool> ai-streaming: false;
    // Source tag for the transcript line — "mic" / "sys" / "" to
    // colour-code which side of the conversation it came from.
    in-out property <string> last-transcript-source: "";

    // Phase E6 v42 — push-to-record (hold) state. Rust flips these true
    // while the corresponding source is recording so the button glows red.
    in-out property <bool> mic-recording: false;
    in-out property <bool> sys-recording: false;

    // Phase E6 v45 — ⚙ Settings chip lights up while the Settings window
    // is open (Rust flips this on open / close). User: "значок настроек
    // не загорается когда настройки открыты".
    in-out property <bool> settings-open: false;
    in-out property <bool> help-open: false;
    // Phase 3a — lights the 🗄 archive chip while the archive window is open
    // (same as settings-open / help-open).
    in-out property <bool> archive-open: false;
    // Phase E6 v45 — X quit is two-step: first press arms an inline
    // "Quit? Yes/No" confirm (Rust auto-disarms after a few seconds) so a
    // stray click can't kill the app. User: "крестик моментально всё
    // закрывает без предупреждения".
    in-out property <bool> quit-armed: false;
    // V0.8.0 (Поток B) — emergency-restart inline confirm, same two-step UX.
    in-out property <bool> restart-armed: false;
    // v0.8.2 (M1 fix) — true while EITHER inline confirm (quit / restart) is
    // showing. The confirm expands the action row inline, so we hide the
    // secondary right-cluster chips (close-all / + tile / 📷 / ⚙) while it's
    // up, keeping the row inside the fixed 1080px bar. Before this, RU
    // "Перезапустить? Да Нет" + the "close all" chip + the wide "⚠ AI
    // недоступен" status pushed "Нет" (cancel) off the right edge — exactly in
    // the restart-while-AI-down flow the feature exists for. The un-armed bar
    // is pixel-identical to before (chips only hide during the ≤4s confirm).
    property <bool> confirming: root.quit-armed || root.restart-armed;

    // v0.12.0 — true while a Summary request is in flight. Lights the 📝
    // chip AND doubles as the Rust-side re-click guard (a slow model must
    // not stack parallel summary calls).
    in-out property <bool> summary-busy: false;

    // ===== Compact "reader mode" =====
    // Collapse the wide bar to a small read-aloud pill (status + Stop + Expand)
    // for using the app purely as a text-to-speech reader. Persisted via
    // config.compact_bar; Rust resizes the bar window on toggle.
    in-out property <bool> compact-bar: false;
    // Label shown in the compact pill. Static "TTS" reader-mode marker for now;
    // live speaking/paused status (set from Rust) is a planned follow-up.
    in-out property <string> tts-status: "TTS";

    // ===== Callbacks =====
    callback mic-toggle-clicked();
    callback sys-toggle-clicked();
    // Phase E6 v42 — push-to-record hold callbacks (down = start, up = stop).
    callback ptt-mic-pressed();
    callback ptt-mic-released();
    callback ptt-sys-pressed();
    callback ptt-sys-released();
    callback timer-toggle-clicked();
    callback spawn-tile-clicked();
    // V0.8.3 — "Написать": open the typed-question input window.
    callback text-ask-clicked();
    callback close-all-tiles-clicked();
    callback capture-clicked(); // 📷 screenshot -> vision (same as F8)
    callback stealth-toggle-clicked();
    callback aggressive-toggle-clicked();
    callback open-settings-clicked();
    callback help-clicked();   // 🆘 chip / F1 → open the help window
    callback archive-clicked(); // 🗄 chip / F7 → open the session archive
    callback summary-clicked(); // v0.12.0 — 📝 chip → meeting-summary tile
    callback quit-clicked();   // X pressed → Rust arms the inline confirm
    // V0.8.0 (Поток B) — emergency restart (⟳). Two-step like Quit.
    callback restart-clicked();
    callback restart-confirm();
    callback restart-cancel();
    callback quit-confirm();   // "Yes" → really quit the app
    callback quit-cancel();    // "No" → disarm the confirm
    // Phase E6 v22 — manual cursor-delta drag (replaces modal
    // WM_NCLBUTTONDOWN which left TouchArea stuck pressed). down →
    // drag-start-requested (anchor), move-while-pressed → drag-moved.
    callback drag-start-requested();
    callback drag-moved();
    // Compact "reader mode": collapse/expand the bar; ⏹ stop read-aloud.
    callback compact-toggle-clicked();
    callback tts-stop-clicked();

    Rectangle {
        background: Theme.bg-surface.with-alpha(0.92);
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;

        // Phase E6 v21 — bar drag is now SCOPED to the status pill
        // only (see drag-handle TouchArea inside the pill below).
        // Cycle 20's full-background TouchArea stole every chip click
        // because Slint's pointer-event fires for ALL events in the
        // bbox even when children have their own TouchAreas (same
        // root cause as tile chrome cycle 10). User: "интерфейс
        // сразу стал не кликабельным". Now only the ~80px status
        // pill is the drag zone; every chip is freely clickable.

        if !root.compact-bar : VerticalLayout {
            padding: 6px;
            spacing: 4px;

        HorizontalLayout {
            padding: 2px;
            spacing: 6px;
            alignment: start;

            // Status pill (left edge) — DOUBLES AS DRAG HANDLE.
            // It has no click action of its own, so a pointer-event
            // TouchArea here is safe: its bbox is only the pill, so
            // it can't shadow the sibling chips' TouchAreas.
            Rectangle {
                background: root.status-color.with-alpha(0.18);
                border-color: root.status-color;
                border-width: 1px;
                border-radius: 10px;
                height: 22px;
                horizontal-stretch: 0;
                // Drag handle — press-and-drag to move the whole bar.
                TouchArea {
                    mouse-cursor: grab;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left
                            && ev.kind == PointerEventKind.down) {
                            root.drag-start-requested();
                        }
                    }
                    moved => {
                        if (self.pressed) { root.drag-moved(); }
                    }
                }
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 8px;
                    spacing: 4px;
                    BrandStateMark {
                        assistant-active: root.ai-streaming;
                        mark-size: 22px;
                    }
                    // Grip — drag affordance (accent). Design-system 6-dot
                    // grip icon (skia-safe) in place of the "::" text.
                    IconSlot {
                        icon: @image-url("../assets/icons/grip.svg");
                        tint: Theme.accent;
                        glyph-size: 12px;
                        slot-width: 12px;
                        slot-height: 22px;
                    }
                    Text {
                        text: root.status-text;
                        font-size: 11px;
                        font-weight: 600;
                        color: root.status-color;
                        vertical-alignment: center;
                    }
                }
            }

            // Phase E6 v44 — grouped, scannable layout (user: "слишком
            // много надписей в ряд"). Groups separated by VDividers:
            // [state] · [capture toggles] · [push-to-ask] · [session info]
            // · [quick actions] · →spring→ · [primary + system]. Toggles
            // and secondary actions are ICON-ONLY; the push-to-record
            // buttons keep words (the key feature) with a colour-coded
            // record dot (green=mic, cyan=sys).

            // ── Capture toggles (continuous mic / sys) — icon-only + dot ──
            LiveChip {
                // v0.13.1 — slashed mic when muted; lit green when live.
                icon: root.mic-muted
                    ? @image-url("../assets/icons/micslash.svg")
                    : @image-url("../assets/icons/mic.svg");
                has-icon: true;
                a11y: root.mic-muted ? "Mic muted (click to unmute)" : "Mic live (click to mute)";
                active: !root.mic-muted;
                accent: root.mic-muted ? Theme.text-muted : Theme.success;
                clicked => { root.mic-toggle-clicked(); }
            }
            LiveChip {
                icon: @image-url("../assets/icons/speaker.svg");
                has-icon: true;
                a11y: "System audio capture";
                active: root.sys-active;
                accent: Theme.accent;
                clicked => { root.sys-toggle-clicked(); }
            }

            VDivider { }

            // ── Push-to-record (hold to ask) — labelled; dot colour marks
            //    the source: green = mic (your voice), cyan = sys (them).
            RecordBtn {
                icon: @image-url("../assets/icons/mic.svg");
                has-icon: true;
                label: @tr("ask");
                accent: Theme.success;
                recording: root.mic-recording;
                pressed => { root.ptt-mic-pressed(); }
                released => { root.ptt-mic-released(); }
            }
            RecordBtn {
                icon: @image-url("../assets/icons/speaker.svg");
                has-icon: true;
                label: @tr("grab");
                accent: Theme.accent;
                recording: root.sys-recording;
                pressed => { root.ptt-sys-pressed(); }
                released => { root.ptt-sys-released(); }
            }

            VDivider { }

            // ── Session info (timer / model / cost) ──
            Chip {
                icon: root.timer-active
                    ? @image-url("../assets/icons/stop.svg")
                    : @image-url("../assets/icons/play.svg");
                has-icon: true;
                label: root.timer-active ? root.timer-label : @tr("start");
                active: root.timer-active;
                accent: #fbbf24;
                clicked => { root.timer-toggle-clicked(); }
            }
            Chip {
                label: root.cost-label;
                accent: #f59e0b;
                clicked => { /* no-op for now */ }
            }

            VDivider { }

            // ── Quick actions — icon-only (stealth / auto)
            Chip {
                icon: @image-url("../assets/icons/stealth.svg");
                has-icon: true;
                a11y: "Stealth (hide from capture)";
                active: root.stealth-active;
                accent: #ec4899;
                clicked => { root.stealth-toggle-clicked(); }
            }
            Chip {
                icon: @image-url("../assets/icons/flame.svg");
                has-icon: true;
                a11y: "Aggressive auto-tile";
                active: root.aggressive-active;
                accent: #fb923c;
                clicked => { root.aggressive-toggle-clicked(); }
            }
            // 🗄 Session archive (also F7) — browse + search past sessions.
            // Icon-only + left of the spring so it consumes slack, not the
            // width-sensitive right cluster. Lights while the archive is open.
            Chip {
                icon: @image-url("../assets/icons/archive.svg");
                has-icon: true;
                a11y: "Session archive";
                active: root.archive-open;
                accent: #a78bfa;
                clicked => { root.archive-clicked(); }
            }
            // v0.12.0 — Summary созвона: run the full-session transcript
            // through the AI → structured recap tile (participants / topics /
            // decisions / tasks / agreements). Works mid-session AND after
            // Стоп. Lights while the request is in flight.
            Chip {
                icon: @image-url("../assets/icons/summary.svg");
                has-icon: true;
                a11y: "Meeting summary";
                active: root.summary-busy;
                accent: #38bdf8;
                clicked => { root.summary-clicked(); }
            }

            // Spring spacer — pushes the primary + system cluster right.
            Rectangle { horizontal-stretch: 1; min-width: 12px; }

            // ── Primary + system ──
            // Close-all appears once tiles have been spawned so the user can
            // dismiss a screenful in one click (#110); resets the counter,
            // which also hides this chip again.
            if root.open-tiles > 0 && !root.confirming : Chip {
                label: @tr("close all");
                accent: #fb7185;
                clicked => { root.close-all-tiles-clicked(); }
            }
            // V0.8.3 — ✏ Написать: type a question when speaking aloud isn't an
            // option. Opens a small stealth-aware input window.
            if !root.confirming : Chip {
                icon: @image-url("../assets/icons/pencil.svg");
                has-icon: true;
                a11y: "Write a question";
                accent: #34d399;
                clicked => { root.text-ask-clicked(); }
            }
            if !root.confirming : Chip {
                label: @tr("+ tile ({})", root.open-tiles);
                accent: #f472b6;
                clicked => { root.spawn-tile-clicked(); }
            }
            if !root.confirming : Chip {
                icon: @image-url("../assets/icons/camera.svg");
                has-icon: true;
                a11y: "Screenshot to vision";
                accent: #22d3ee;
                clicked => { root.capture-clicked(); }
            }
            if !root.confirming : Chip {
                icon: @image-url("../assets/icons/gear.svg");
                has-icon: true;
                a11y: "Settings";
                active: root.settings-open;
                accent: Theme.text-muted;
                clicked => { root.open-settings-clicked(); }
            }
            // V0.8.4 — 🆘 help (icons + hotkeys + gestures); also F1. Lights up
            // while the help window is open (same as the ⚙ chip for Settings).
            if !root.confirming : Chip {
                icon: @image-url("../assets/icons/sos.svg");
                has-icon: true;
                a11y: "Help";
                active: root.help-open;
                accent: #60a5fa;
                clicked => { root.help-clicked(); }
            }
            // V0.8.0 (Поток B) — emergency restart, two-step like Quit. Use it
            // when the app/local AI gets stuck; settings (incl. stealth) survive.
            // Label is the recycle EMOJI 🔄 (color-emoji font), NOT the text
            // glyph ⟳ (U+27F3) — the latter renders as a missing-glyph box on
            // the Slint+skia text-font fallback (same class as ✕, why Quit uses
            // ASCII "X"). 🔄 renders fine (proven by tile.slint's regen button).
            if !root.restart-armed : Chip {
                icon: @image-url("../assets/icons/restart.svg");
                has-icon: true;
                a11y: "Emergency restart";
                accent: #38bdf8;
                clicked => { root.restart-clicked(); }
            }
            if root.restart-armed : HorizontalLayout {
                spacing: 4px;
                Text {
                    text: @tr("Restart?");
                    font-size: 11px;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                }
                Chip {
                    label: @tr("Yes");
                    active: true;
                    accent: #38bdf8;
                    clicked => { root.restart-confirm(); }
                }
                Chip {
                    label: @tr("No");
                    accent: Theme.accent;
                    clicked => { root.restart-cancel(); }
                }
            }
            // Compact "reader mode" — collapse the bar to a small read-aloud
            // pill. Lives with the window controls (left of Quit), where a
            // minimize/collapse affordance is expected. Hidden during a quit/
            // restart confirm so the inline buttons stay inside the bar.
            if !root.confirming : Chip {
                icon: @image-url("../assets/icons/minimize.svg");
                has-icon: true;
                a11y: "Compact reader mode";
                active: root.compact-bar;
                accent: #38bdf8;
                clicked => { root.compact-toggle-clicked(); }
            }
            // Quit — two-step. Idle: a single ASCII "X" (Unicode ✕ renders
            // as a missing-glyph box on the Slint+skia fallback). Armed:
            // inline "Quit? [Yes] [No]" so a stray click can't kill the app.
            if !root.quit-armed : Chip {
                icon: @image-url("../assets/icons/x.svg");
                has-icon: true;
                a11y: "Quit";
                accent: Theme.danger;
                clicked => { root.quit-clicked(); }
            }
            if root.quit-armed : HorizontalLayout {
                spacing: 4px;
                Text {
                    text: @tr("Quit?");
                    font-size: 11px;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                }
                Chip {
                    label: @tr("Yes");
                    active: true;
                    accent: Theme.danger;
                    clicked => { root.quit-confirm(); }
                }
                Chip {
                    label: @tr("No");
                    accent: Theme.accent;
                    clicked => { root.quit-cancel(); }
                }
            }
        }

        // ===== Live status row =====
        // Phase E6 v11 — bottom row shows last transcript line + AI
        // streaming indicator. Gives the user immediate visual proof
        // that STT and AI are working without opening a separate
        // window or watching a log file.
        HorizontalLayout {
            padding-left: 4px;
            padding-right: 4px;
            spacing: 6px;
            // Active-stack readout (read-only) — moved here from the top row
            // so Settings + quit fit. Shows local/cloud/mixed · STT · AI model.
            Text {
                text: root.active-stack;
                font-size: 10px;
                font-weight: 600;
                color: Theme.accent;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            // Source tag — "mic" green dot, "sys" cyan dot, "" gray.
            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: root.last-transcript-source == "mic"
                    ? Theme.success
                    : (root.last-transcript-source == "sys" ? Theme.accent : Theme.border-strong);
            }
            // The live transcript text — elide when too long.
            Text {
                text: root.last-transcript-line == ""
                    ? @tr("waiting for transcript... (mic/sys → STT)")
                    : root.last-transcript-line;
                font-size: 11px;
                color: root.last-transcript-line == "" ? Theme.text-muted : Theme.text-secondary;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // AI streaming pulse — visible when an ask is in flight.
            Rectangle {
                width: root.ai-streaming ? 80px : 0px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                background: root.ai-streaming ? #818cf8.with-alpha(0.22) : transparent;
                border-color: #818cf8;
                border-width: root.ai-streaming ? 1px : 0px;
                border-radius: 9px;
                horizontal-stretch: 0;
                if root.ai-streaming : HorizontalLayout {
                    alignment: center;
                    spacing: 4px;
                    padding-left: 6px;
                    padding-right: 6px;
                    Image {
                        source: @image-url("../assets/icons/brain.svg");
                        colorize: #818cf8;
                        width: 12px;
                        height: 12px;
                        image-fit: contain;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "AI streaming";
                        font-size: 10px;
                        color: #818cf8;
                        vertical-alignment: center;
                    }
                }
            }
        }
        }

        // ===== Compact "reader mode" pill =====
        // When collapsed, the whole bar is just: read-aloud status (also the
        // drag handle) + Stop + Expand. Rust resizes the window to ~340px on
        // toggle so it stops eating the screen. The global Shift+Alt+1/2/3
        // read-aloud hotkeys work regardless of this layout.
        if root.compact-bar : HorizontalLayout {
            padding: 6px;
            spacing: 6px;
            Rectangle {
                // Reader-mode plaque colour is FIXED accent — was tied to
                // status-color, which turns yellow while recording; confusing on
                // what is a TTS/read-aloud pill (design review #5).
                background: Theme.accent.with-alpha(0.16);
                border-color: Theme.accent.with-alpha(0.7);
                border-width: 1px;
                border-radius: 10px;
                height: 30px;
                horizontal-stretch: 1;
                TouchArea {
                    mouse-cursor: grab;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left
                            && ev.kind == PointerEventKind.down) {
                            root.drag-start-requested();
                        }
                    }
                    moved => {
                        if (self.pressed) { root.drag-moved(); }
                    }
                }
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    BrandStateMark {
                        assistant-active: root.ai-streaming;
                        mark-size: 20px;
                    }
                    // Drag affordance — same 6-dot grip as the full bar, so the
                    // user can see (and the help mentions) where to drag.
                    IconSlot {
                        icon: @image-url("../assets/icons/grip.svg");
                    }
                    Text {
                        text: root.tts-status;
                        font-size: 12px;
                        font-weight: 600;
                        color: Theme.accent;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
            }
            // 30×30 to match the plaque height + a real hit-target; Stop is
            // always red (resting tint) so it reads as STOP without hovering.
            CompactIconBtn {
                icon: @image-url("../assets/icons/stop.svg");
                a11y: "Stop reading aloud";
                tint: #ef4444;
                accent: #ef4444;
                clicked => { root.tts-stop-clicked(); }
            }
            CompactIconBtn {
                icon: @image-url("../assets/icons/maximize.svg");
                a11y: "Expand the bar";
                clicked => { root.compact-toggle-clicked(); }
            }
        }
    }
}
