// =====================================================================
// Design tokens for overlay-mvp (Slint).
//
// Single source of truth — mirrors slint/tokens.slint from the
// Settings work and the original src/styles.css. Used by overlay_bar
// and tile windows; settings panel has its own copy until we merge.
// =====================================================================

export global Theme {
    // --- Surface scale -------------------------------------------
    out property <color> bg-0: #0e0e11;
    out property <color> bg-1: #18181c;
    out property <color> bg-2: #1f1f25;
    out property <color> bg-3: #26262e;
    out property <color> bg-4: #2f2f38;

    // Glass surfaces use these alpha values over a Window with
    // background: transparent and `no-frame: true`.
    out property <color> glass:   #16161cdd;   // 0.87 alpha
    out property <color> glass-strong: #18181ce6; // 0.90 alpha

    // --- Text ----------------------------------------------------
    out property <color> text:      #e8e8ee;
    out property <color> text-mute: #9ca3af;
    out property <color> text-dim:  #6b6b76;

    // --- Borders -------------------------------------------------
    out property <color> border:        #2a2a32;
    out property <color> border-soft:   #22222a;
    out property <color> border-strong: #3a3a45;
    // glass border tint: white at 9% — matches color-mix in CSS
    out property <color> glass-border:  #ffffff17;

    // --- Semantic accents (KEEP meanings — match styles.css) -----
    out property <color> auto:   #6366f1;   // indigo — detector tile
    out property <color> system: #fb923c;   // orange — interviewer 🔊
    out property <color> mic:    #22c55e;   // green  — user 🎤
    out property <color> manual: #9ca3af;   // gray   — F6 manual
    out property <color> error:  #ef4444;   // red    — error / recording
    out property <color> warn:   #facc15;   // yellow — thinking / cost
    out property <color> ai:     #a855f7;   // purple — AI request
    out property <color> info:   #818cf8;   // light indigo — model chip

    // --- Radii ---------------------------------------------------
    out property <length> r-1: 4px;
    out property <length> r-2: 6px;
    out property <length> r-3: 8px;
    out property <length> r-4: 10px;
    out property <length> r-pill: 999px;

    // --- Type sizes ----------------------------------------------
    out property <length> fs-10: 10px;
    out property <length> fs-11: 11px;
    out property <length> fs-12: 12px;
    out property <length> fs-13: 13px;
    out property <length> fs-14: 14px;
    out property <length> fs-15: 15px;
    out property <length> fs-16: 16px;
    out property <length> fs-18: 18px;

    // --- Motion --------------------------------------------------
    out property <duration> dur-fast: 80ms;
    out property <duration> dur-base: 140ms;
}
