// V0.8.3 — "Написать": a small text-input window to type a question for the
// assistant when speaking aloud isn't possible (noise / public place / silence).
// Complements the voice flow, doesn't replace it.
//
// The Rust host (open_text_ask) creates it on demand, centres it on the primary
// monitor, applies WDA stealth (so it never shows on a screen-share — same as
// tiles/palette/Settings), and gives it keyboard focus. Enter or the "Send"
// button routes the typed text through the SAME ask pipeline as F9
// (fire_f9_ask with an explicit question) → a standard answer tile. Esc cancels.
//
// Solid background (Theme.bg-surface) — NOT a transparent/rounded card — to
// avoid the documented Windows DWM "created-but-invisible" pitfall for new
// frameless windows; present_window_stealth_aware doesn't wire DWM blur-behind.

import { LineEdit, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton } from "controls.slint";
import { Metrics } from "metrics.slint";

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.accent;
    in property <length> glyph-size: 15px;
    in property <length> slot-size: 18px;
    width: slot-size;
    height: slot-size;
    horizontal-stretch: 0;

    Image {
        source: root.icon;
        colorize: root.tint;
        width: root.glyph-size;
        height: root.glyph-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

export component TextAskWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    title: "suflyor text ask (Slint)";
    default-font-family: Theme.font-sans;
    background: Theme.bg-surface;
    preferred-width: 480px;
    preferred-height: 112px;

    in-out property <string> query;
    // v0.10.1 — the active profile/persona label (set live by the host on open),
    // so the user can see which profile will shape the typed answer.
    in-out property <string> active-profile;
    // Emitted with the typed text when the user presses Enter / clicks Send.
    callback submitted(string);
    // Emitted on Esc — the host hides + drops the window.
    callback cancelled();
    // ТЗ 2026-07-06 (C) — frameless drag (cursor-delta, same as help/wizard):
    // the header row is the handle; the host persists the position on close.
    callback drag-start-requested();
    callback drag-moved();

    forward-focus: input;

    function fire() {
        if (root.query != "") {
            root.submitted(root.query);
            root.query = "";
        }
    }

    FocusScope {
        // Esc cancels; everything else falls through to the focused LineEdit.
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.cancelled();
                return accept;
            }
            // Layout-independent editing shortcuts. Slint's built-in Ctrl+A/C/V/X
            // are keyed on the Latin chars a/c/v/x (i-slint-core `shortcut()`), so
            // under a Cyrillic layout the physical keys emit ф/с/м/ч and the
            // shortcuts silently die. Match those and call the LineEdit's own
            // functions (cursor/selection-aware). "ф/с/м/ч" are keycode matches,
            // not UI strings — deliberately not @tr.
            if (e.modifiers.control && !e.modifiers.shift) {
                if (e.text == "м" || e.text == "М") { input.paste(); return accept; }
                if (e.text == "с" || e.text == "С") { input.copy(); return accept; }
                if (e.text == "ч" || e.text == "Ч") { input.cut(); return accept; }
                if (e.text == "ф" || e.text == "Ф") { input.select-all(); return accept; }
            }
            return reject;
        }
        VerticalLayout {
            padding: 14px;
            spacing: 10px;
            HorizontalLayout {
                spacing: Metrics.space-sm;   // was 8px
                // ТЗ 2026-07-06 (C) — drag handle BEHIND the header content
                // (help.slint pattern): the TouchArea drags; the CloseButton
                // stays a sibling on top so its clicks are its own.
                Rectangle {
                    horizontal-stretch: 1;
                    height: 20px;
                    TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => {
                            if (self.pressed) { root.drag-moved(); }
                        }
                    }
                    HorizontalLayout {
                        spacing: Metrics.space-sm;
                        IconSlot {
                            icon: @image-url("../assets/icons/pencil.svg");
                            tint: Theme.accent;
                            glyph-size: 15px;
                            slot-size: 18px;
                        }
                        Text {
                            text: "Напишите вопрос ассистенту";
                            color: Theme.text-secondary;
                            font-size: Metrics.font-body;   // was 12px
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        // v0.10.1 — active profile/persona (applies to the typed
                        // answer too, identically to voice). Right-aligned, muted.
                        Text {
                            text: root.active-profile;
                            color: Theme.text-muted;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                }
                // V0.8.4 — explicit close (= Esc). Shared CloseButton.
                CloseButton {
                    clicked => { root.cancelled(); }
                }
            }
            HorizontalLayout {
                spacing: Metrics.space-sm;   // was 8px
                input := LineEdit {
                    placeholder-text: "Введите вопрос...";
                    text <=> root.query;
                    accepted => { root.fire(); }
                }
                Button {
                    text: "Отправить";
                    primary: true;
                    clicked => { root.fire(); }
                }
            }
        }
    }
}
