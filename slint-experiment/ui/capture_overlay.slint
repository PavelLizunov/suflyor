// V3 — Lightshot-style region-select overlay.
//
// Shown fullscreen over a FROZEN snapshot of the whole virtual desktop (the
// Rust host captures it, hands us the image, and positions this window to cover
// every monitor). The user drags a rectangle; on release we emit
// `region-selected` with the rect in LOGICAL px (the host multiplies by the
// window scale-factor to get image pixels and crops the frozen buffer). Esc or
// right-click or a too-small drag cancels.

export component CaptureOverlay inherits Window {
    title: "suflyor — capture";
    no-frame: true;
    always-on-top: true;
    forward-focus: fs;

    // Driven from Rust. Geometry (position + size) is owned by the Win32 host
    // (move_window over the virtual desktop); this component just fills 100% so
    // there's no Slint-vs-Win32 fight over the window rect.
    in property <image> frozen;

    // Rust-side flag: is the capture UI currently displayed? The overlay is
    // persistent + pre-stealthed (so it shows flash-free), so visibility is
    // tracked here rather than via an Option<window> in Rust.
    in-out property <bool> shown: false;

    // Selection state in logical px.
    property <length> sx;
    property <length> sy;
    property <length> ex;
    property <length> ey;
    in-out property <bool> dragging: false;

    // Feature #3 — capture intent: false = describe (default), true = translate
    // (output ONLY the translation, no screen description). Seeded by the host
    // (F8 = describe, Shift+F8 = translate); flippable via the on-overlay toggle.
    in-out property <bool> translate-mode: false;
    // v0.11.0 — Test Practice capture (seeded from the Settings toggle on plain
    // F8). Shown as a distinct hint; translate-mode takes precedence on read-back.
    in-out property <bool> practice-mode: false;

    // Normalised selection rect.
    property <length> rx: min(root.sx, root.ex);
    property <length> ry: min(root.sy, root.ey);
    property <length> rw: abs(root.ex - root.sx);
    property <length> rh: abs(root.ey - root.sy);

    // x1, y1, x2, y2 in LOGICAL px.
    callback region-selected(length, length, length, length);
    callback cancelled();

    background: #000000;

    // The frozen screenshot fills the window 1:1.
    Image {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        source: root.frozen;
        image-fit: fill;
    }

    // Dim everything; while dragging, leave the selection bright via 4 bands.
    if !root.dragging: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #00000055;
    }
    if root.dragging: Rectangle { // top
        x: 0;
        y: 0;
        width: root.width;
        height: root.ry;
        background: #00000088;
    }
    if root.dragging: Rectangle { // bottom
        x: 0;
        y: root.ry + root.rh;
        width: root.width;
        height: root.height - (root.ry + root.rh);
        background: #00000088;
    }
    if root.dragging: Rectangle { // left
        x: 0;
        y: root.ry;
        width: root.rx;
        height: root.rh;
        background: #00000088;
    }
    if root.dragging: Rectangle { // right
        x: root.rx + root.rw;
        y: root.ry;
        width: root.width - (root.rx + root.rw);
        height: root.rh;
        background: #00000088;
    }

    // Selection border + size readout.
    if root.dragging: Rectangle {
        x: root.rx;
        y: root.ry;
        width: root.rw;
        height: root.rh;
        border-color: #22d3ee;
        border-width: 2px;
        background: transparent;
    }
    if root.dragging && root.rw > 1px: Rectangle {
        x: root.rx;
        y: max(2px, root.ry - 22px);
        width: 110px;
        height: 20px;
        background: #111827dd;
        border-radius: 4px;
        Text {
            text: round(root.rw / 1px) + " × " + round(root.rh / 1px) + " px";
            color: #e8e8ec;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Hint pill (top-left).
    Rectangle {
        x: 12px;
        y: 12px;
        width: hint.preferred-width + 20px;
        height: 26px;
        background: #111827dd;
        border-radius: 6px;
        hint := Text {
            text: @tr("Drag to select a region · Esc / right-click to cancel");
            color: #e8e8ec;
            font-size: 12px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Drag tracking.
    TouchArea {
        width: 100%;
        height: 100%;
        pointer-event(ev) => {
            // OS-cancelled pointer grab (e.g. Alt-Tab mid-drag) — don't leave
            // the frozen overlay stuck on screen.
            if (ev.kind == PointerEventKind.cancel) {
                root.dragging = false;
                root.cancelled();
                return;
            }
            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.up) {
                root.dragging = false;
                root.cancelled();
                return;
            }
            if (ev.button == PointerEventButton.left) {
                if (ev.kind == PointerEventKind.down) {
                    root.sx = self.mouse-x;
                    root.sy = self.mouse-y;
                    root.ex = self.mouse-x;
                    root.ey = self.mouse-y;
                    root.dragging = true;
                } else if (ev.kind == PointerEventKind.up) {
                    // Emit ONLY for a real drag started in THIS session
                    // (root.dragging) that covers a deliberate area. A stray up, a
                    // plain click, or a tiny accidental drag cancels — never a
                    // spurious 1×1 capture. (4px was far too low: normal click
                    // jitter exceeded it and fired a vision request on noise.)
                    if (root.dragging && root.rw >= 16px && root.rh >= 16px) {
                        root.dragging = false;
                        root.region-selected(root.rx, root.ry, root.rx + root.rw, root.ry + root.rh);
                    } else {
                        root.dragging = false;
                        root.cancelled();
                    }
                }
            }
        }
        moved => {
            if (root.dragging) {
                root.ex = self.mouse-x;
                root.ey = self.mouse-y;
            }
        }
    }

    // Feature #3 — Describe/Translate mode toggle. Declared AFTER the drag
    // TouchArea so its own TouchArea sits on top and a click flips the mode
    // instead of starting a selection. Absolutely positioned under the hint pill.
    Rectangle {
        x: 12px;
        y: 46px;
        width: modehint.preferred-width + 24px;
        height: 26px;
        background: root.translate-mode ? #0e7490ee : (root.practice-mode ? #6d28d9ee : #111827dd);
        border-radius: 6px;
        border-width: 1px;
        border-color: #22d3ee;
        modehint := Text {
            text: root.translate-mode ? @tr("Translate — tap to Describe")
                : (root.practice-mode ? @tr("Test Practice (self-check)") : @tr("Describe — tap to Translate"));
            color: #e8e8ec;
            font-size: 12px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        TouchArea {
            clicked => {
                root.translate-mode = !root.translate-mode;
            }
        }
    }

    // Esc to cancel (best-effort — needs keyboard focus, which the host grabs
    // via SetForegroundWindow when it shows this overlay).
    fs := FocusScope {
        key-pressed(ev) => {
            if (ev.text == Key.Escape) {
                root.cancelled();
                return accept;
            }
            return reject;
        }
    }
}
