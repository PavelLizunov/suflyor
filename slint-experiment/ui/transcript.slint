// Session transcript viewer (ТЗ1) — a structured, READ-ONLY chronological list of
// a session's utterances (time · speaker · text), opened from the archive via the
// 📄 row button. Per-line checkboxes + "Copy all / Copy selected" (decision #7).
// Chrome (frameless / opaque / always-on-top, header drag, CloseButton, Esc)
// mirrors archive.slint verbatim — incl. the opaque-bg trap note there.
//
// i18n: chrome strings are @tr (English msgid; RU in slint-replay.po). The row
// DATA (time / speaker / text) is language-neutral, built in Rust.

import { ListView, Palette, LineEdit, TextEdit, Button, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton, SelectableText } from "controls.slint";
import { Metrics } from "metrics.slint";
import { DarkCheck } from "settings_panel.slint";

// One transcript row, built in Rust from a session's utterances.
export struct TranscriptLine {
    offset-label: string, // "02:15" session-relative, or "" if start unknown
    speaker: string,      // «Система» | «Микрофон» (role view) OR «Вы» / «Тимур» / «Говорящий 2» (voice view)
    speaker-color: color, // D3 — colour of the speaker label (accent in role view; per-speaker in «По голосам»)
    text: string,
    checked: bool,        // ТЗ1 — per-line selection for "Copy selected" (clipboard)
    marked: bool,         // G2b (2026-07-03) — per-line ⭐ multi-mark for «В память (N)»
    start-ms: int,        // ТЗ2b — session-relative ms, for click-to-seek + active line
    matched: bool,        // I (2026-07-05) — matches the current in-transcript search query
}

// D3 — one speaker in the «По голосам» rename list (display id · editable label · colour).
export struct SpeakerRow {
    id: int,
    label: string,
    color: color,
}

// A compact square checkbox (reused for per-line selection + "select all").
// DarkCheck is a big toggle SWITCH — too heavy per row — so this is a small tick.
component Tick inherits Rectangle {
    in property <bool> checked;
    callback clicked();
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border-width: 1px;
    border-color: root.checked ? Theme.accent : Theme.border;
    background: root.checked ? Theme.accent : transparent;
    animate background, border-color { duration: 100ms; }
    // F5 — SVG check (project standard) instead of a text "✓". Centered via the
    // same fill+center layout the archive RowIcon uses (a bare Image won't center).
    if root.checked : VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                source: @image-url("../assets/icons/check.svg");
                colorize: Theme.on-accent;
                width: 11px;
                height: 11px;
                image-fit: contain;
            }
        }
    }
    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component TranscriptWindow inherits Window {
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }

    title: "Transcript";
    icon: @image-url("../assets/icon.svg");
    // Opaque (NOT transparent) — a transparent + WS_EX_LAYERED frameless window
    // alpha-clamps text invisible (archive.slint learned this the hard way).
    background: Theme.bg-surface;
    no-frame: true;
    always-on-top: true;
    preferred-width: 720px;
    preferred-height: 560px;
    min-width: 480px;
    min-height: 320px;

    // Rust-built: session heading (title/time), the rows, and the empty flag.
    in-out property <string> heading: "";
    in-out property <[TranscriptLine]> lines: [];
    in-out property <bool> empty: false;
    // Баг5-class: how many utterances the display cap hid (0 = none). The footer
    // below the list discloses it so a long transcript isn't SILENTLY truncated
    // ("Copy all" still exports every line — it reads the full utterance set).
    in-out property <int> overflow-count: 0;
    // ТЗ1 copy (decision #7): "Copy all / selected" honour the "with timecodes"
    // toggle; `copied` flashes a 1.5s confirmation on the buttons (set from Rust).
    // `all-selected` mirrors the per-line checkboxes (kept in sync by Rust).
    in-out property <bool> with-timecodes: false;
    in-out property <bool> copied: false;
    in-out property <bool> all-selected: false;
    // ТЗ2b player: `has-audio` gates the mini-player; the rest are polled from
    // Rust — progress 0..1, "mm:ss / mm:ss" time, the active line index, play state.
    in-out property <bool> has-audio: false;
    in-out property <bool> playing: false;
    in-out property <float> progress: 0;
    in-out property <string> time-text: "";
    in-out property <int> active-line: -1;
    // Player speed + volume-boost (owner req 2026-07-05) — cycled by the mini-player
    // buttons, applied via set-speed / set-volume. Rust resets both to 1× per session.
    in-out property <float> speed: 1.0;
    in-out property <float> volume: 1.0;
    // G2b (2026-07-03) — «⭐ В память», mirrors the tiles: the per-line ⭐ toggles the
    // line's `marked`; one bottom «В память (N)» bar joins the marked lines into ONE
    // record. `capture-text` = the edit buffer (shown at N==1, or for a pending
    // selection); `capture-pending` = a right-click text-selection capture (independent
    // of the ⭐ marks, same split as the tiles).
    in-out property <int> marked-count: 0;
    // R1.2 (retest v0.28.0): last plain-clicked line — the anchor a SHIFT+click range-marks up to.
    // Reset by the Rust wiring on each fresh open (window is reused across sessions).
    in-out property <int> mark-anchor: -1;
    in-out property <string> capture-text: "";
    in-out property <bool> capture-pending: false;
    // Which single line seeded `capture-text` (-1 = none). Re-seed the edit buffer ONLY
    // when the SOLE-marked line changes, so an in-progress edit survives marking/unmarking
    // OTHER lines (mirrors the tile's review-I-1 guard).
    in-out property <int> capture-line-index: -1;

    // ── D3 — «По голосам» (speaker diarization) ──
    // false = «По ролям» (Микрофон/Система, default); true = «По голосам» (per-speaker).
    in-out property <bool> by-voice: false;
    // A diarization result exists for this session (enables the toggle).
    in-out property <bool> has-diarization: false;
    // The session can be diarized (finished + has system audio + aligned timecodes).
    in-out property <bool> can-diarize: false;
    // A diarization job is running (disabled button + status).
    in-out property <bool> diarizing: false;
    // V-1 (fable review): session IS diarizable but the models aren't installed → show
    // an install prompt (otherwise the whole toolbar is hidden and the feature is
    // undiscoverable + uninstallable).
    in-out property <bool> needs-diar-models: false;
    // The diarization models are downloading (progress in diar-status).
    in-out property <bool> installing-diar-models: false;
    // I-1 (fable review): this session's recording predates the wall-clock-padding fix
    // (D0.5), so audio_ms→sample drifts and speaker timings may be approximate → banner.
    in-out property <bool> timeline-unreliable: false;
    // F (fable) — re-detect guard: `has-speaker-names` (Rust-set) arms the guard; a re-run
    // wipes custom names, so `confirm-rediar` shows a confirm card first (clones archive resummary).
    in-out property <bool> has-speaker-names: false;
    in-out property <bool> confirm-rediar: false;
    // Progress / error line under the diarize controls.
    in-out property <string> diar-status: "";
    // «Сколько собеседников (без вас)» — the PRIMARY control (auto is unreliable on VoIP
    // audio). Default 2 (the common one-interviewer case).
    in-out property <int> speaker-count: 2;
    // The rename list, shown in «По голосам»: display id · label · colour.
    in-out property <[SpeakerRow]> speakers: [];
    // I (2026-07-05, owner top priority) — in-transcript search. `search-query` drives Rust
    // match-flagging (`matched` per line); `search-count`/`search-pos` show «pos / count».
    in-out property <string> search-query: "";
    in-out property <int> search-count: 0;
    in-out property <int> search-pos: 0; // 1-based; 0 = no current match

    callback toggle-play();
    callback play-line(int);
    callback seek-fraction(float);
    // Player speed + volume-boost (owner req 2026-07-05) — the button cycles the value,
    // sets the property (drives its own label), and hands the new value to Rust.
    callback set-speed(float);
    callback set-volume(float);
    callback copy-all-requested();
    callback copy-selected-requested();
    callback toggle-line(int);
    callback toggle-all(bool);
    callback close-requested();
    callback drag-start-requested();
    callback drag-moved();
    // G2b (2026-07-03) — ⭐ multi-mark → save, mirroring the tiles: toggle a line's mark;
    // «В память (N)» joins ALL marked lines into ONE note; clear-marks cancels. R1.2: the bool is
    // whether SHIFT was held (range-mark from the anchor to this line); Rust owns the range logic.
    callback toggle-line-marked(int, bool);
    callback save-marked();
    callback clear-marks();
    // Right-click text-selection capture → the same editor (save / cancel).
    callback save-capture();
    callback cancel-capture();
    // ТЗ 2026-07-03 — mouse-selection capture: (line-index, anchor-byte-offset,
    // cursor-byte-offset). Rust slices line.text by the selection and opens the same
    // editor (capture-text + capture-pending) that the ⭐-mark flow uses.
    callback capture-line-selection(int, int, int);

    // D3 — «По голосам»: flip the view; run diarization with `speaker-count`; rename a
    // speaker (display id, new name — blank clears). Rust rebuilds `lines` + `speakers`.
    callback toggle-by-voice(bool);
    callback run-diarization();
    // V-1 — download the diarization models (shown only when the session is
    // diarizable but the models are absent).
    callback install-diar-models();
    callback rename-speaker(int, string);
    // I — in-transcript search: `search-edited` re-flags matches on each keystroke; `search-jump(+1/-1)`
    // moves to the next/prev match (Rust jumps the player via play-line + calls scroll-to-line here).
    callback search-edited(string);
    callback search-jump(int);

    // I — scroll the virtualized ListView so line `idx` is roughly centered (same average-height
    // estimate std StandardListViewBase uses). Approximate with variable-height rows, but the audio
    // jump is exact + the 200ms poll then paints the landed row via active-line.
    public function scroll-to-line(idx: int) {
        if (root.lines.length == 0) {
            return;
        }
        lv.viewport-y = -clamp(
            idx * (lv.viewport-height / root.lines.length) - lv.height / 2,
            0px,
            max(0px, lv.viewport-height - lv.height));
    }

    forward-focus: fs;

    Rectangle {
        background: Theme.bg-surface.with-alpha(0.95);
        border-radius: Metrics.radius-panel;
        border-width: Metrics.border-thin;
        border-color: Theme.border;

        fs := FocusScope {
            width: 100%;
            height: 100%;
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    // F — Esc dismisses the re-detect confirm first, then closes the window.
                    if (root.confirm-rediar) {
                        root.confirm-rediar = false;
                    } else {
                        root.close-requested();
                    }
                    return accept;
                }
                return reject;
            }

            VerticalLayout {
                padding: Metrics.space-md;
                spacing: Metrics.space-sm;

                // ── Header: icon · title · session heading (DRAG) · close ──
                HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        horizontal-stretch: 1;
                        TouchArea {
                            pointer-event(ev) => {
                                if (ev.button == PointerEventButton.left
                                    && ev.kind == PointerEventKind.down) {
                                    root.drag-start-requested();
                                }
                            }
                            moved => { if (self.pressed) { root.drag-moved(); } }
                        }
                        HorizontalLayout {
                            spacing: Metrics.space-sm;
                            Image {
                                source: @image-url("../assets/icons/bubble.svg");
                                colorize: Theme.text-primary;
                                width: 18px;
                                height: 18px;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Transcript");
                                font-size: Metrics.font-heading;
                                font-weight: 700;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.heading;
                                font-size: Metrics.font-caption;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                    }
                    CloseButton {
                        clicked => { root.close-requested(); }
                    }
                }

                Rectangle {
                    background: Theme.border;
                    height: Metrics.border-thin;
                }

                // ── Toolbar: copy all / copy selected + timecode toggle (ТЗ1 #7) ──
                if !root.empty : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        width: 124px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        background: copy-ta.pressed
                            ? Theme.accent.with-alpha(0.7)
                            : copy-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                        animate background { duration: 120ms; }
                        copy-ta := TouchArea {
                            clicked => {
                                root.copy-all-requested();
                            }
                        }
                        Text {
                            // Per-scheme WCAG-AA text colour on the accent fill (white
                            // fails on the bright mint scheme); matches every other
                            // filled-accent control.
                            text: root.copied ? @tr("Copied ✓") : @tr("Copy all");
                            color: Theme.on-accent;
                            font-size: Metrics.font-label;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 150px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: sel-ta.pressed
                            ? Theme.accent.with-alpha(0.22)
                            : sel-ta.has-hover ? Theme.accent.with-alpha(0.14) : transparent;
                        animate background { duration: 120ms; }
                        sel-ta := TouchArea {
                            clicked => {
                                root.copy-selected-requested();
                            }
                        }
                        Text {
                            text: root.copied ? @tr("Copied ✓") : @tr("Copy selected");
                            color: Theme.accent;
                            font-size: Metrics.font-label;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    DarkCheck {
                        text: @tr("with timecodes [mm:ss]");
                        checked <=> root.with-timecodes;
                    }
                }

                // ── D3 — «По голосам» diarization toolbar (view toggle + detect controls) ──
                // V-1: also show when the session is diarizable but models are absent, so
                // the install prompt is reachable (else the whole feature is hidden).
                if !root.empty && (root.can-diarize || root.has-diarization || root.needs-diar-models) : VerticalLayout {
                    spacing: Metrics.space-sm;
                    // G (fable) — the view-toggle row shows ONLY once a result exists. It used
                    // to sit inside an always-present HorizontalLayout wrapper, but an EMPTY box
                    // layout in Slint 1.16 reports stretch=f32::MAX (ate all vertical space → the
                    // ListView collapsed to ~2 rows) AND max-width=0 (opened the window narrower).
                    // Hoisting the `if` so NOTHING renders pre-detect fixes both. (D3 8b4fa2c regression.)
                    if root.has-diarization : HorizontalLayout {
                        spacing: 4px;
                        Rectangle {
                            width: 92px;
                            height: 28px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.accent;
                            background: !root.by-voice ? Theme.accent : transparent;
                            role-ta := TouchArea { clicked => { root.toggle-by-voice(false); } }
                            Text {
                                text: @tr("By role");
                                color: !root.by-voice ? Theme.on-accent : Theme.accent;
                                font-size: Metrics.font-label;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 104px;
                            height: 28px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.accent;
                            background: root.by-voice ? Theme.accent : transparent;
                            voice-ta := TouchArea { clicked => { root.toggle-by-voice(true); } }
                            Text {
                                text: @tr("By voice");
                                color: root.by-voice ? Theme.on-accent : Theme.accent;
                                font-size: Metrics.font-label;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                    // I-1 (fable review) — system.wav is shorter than the SYSTEM-line span, so
                    // audio_ms→sample drifts and speaker labels may land off. E-fix: gate on
                    // has-diarization — the caveat is about label alignment, so it's meaningless
                    // (and was firing on every diarizable open) until a result actually exists.
                    if root.timeline-unreliable && root.has-diarization : Rectangle {
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.warning;
                        background: Theme.warning.with-alpha(0.10);
                        HorizontalLayout {
                            padding: 6px;
                            Text {
                                text: @tr("Speaker timings may be approximate for this recording.");
                                font-size: Metrics.font-caption;
                                color: Theme.text-primary;
                                wrap: word-wrap;
                            }
                        }
                    }
                    // V-1 (fable review) — models missing: offer the one-time download. The
                    // detect controls (below) stay hidden until can-diarize flips true.
                    if root.needs-diar-models && !root.can-diarize : VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: @tr("Speaker detection needs a one-time model download (~30 MB).");
                            font-size: Metrics.font-caption;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            Rectangle {
                                width: 232px;
                                height: 28px;
                                horizontal-stretch: 0;
                                border-radius: 6px;
                                background: root.installing-diar-models
                                    ? Theme.accent.with-alpha(0.5)
                                    : instd-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                                animate background { duration: 120ms; }
                                instd-ta := TouchArea {
                                    clicked => { if (!root.installing-diar-models) { root.install-diar-models(); } }
                                }
                                Text {
                                    text: root.installing-diar-models
                                        ? @tr("Downloading models…")
                                        : @tr("Install speaker models");
                                    color: Theme.on-accent;
                                    font-size: Metrics.font-label;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }
                    // ── Row 2 — detect controls (count stepper + run button; own row so
                    // the fixed-width controls never overflow the min-width window). Gated on
                    // can-diarize (V-1) — hidden until the models are installed. ──
                    if root.can-diarize : HorizontalLayout {
                        spacing: Metrics.space-sm;
                        // Speaker-count stepper — the PRIMARY control («сколько собеседников»).
                        // V-2: the count is OTHER voices (diarization runs on system.wav; your
                        // mic is a separate channel), so «besides you».
                        Text {
                            text: @tr("Speakers (besides you):");
                            font-size: Metrics.font-label;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 26px;
                            height: 28px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            TouchArea { clicked => { if (root.speaker-count > 1) { root.speaker-count -= 1; } } }
                            Text {
                                text: "−";
                                font-size: Metrics.font-body;
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "\{root.speaker-count}";
                            width: 22px;
                            font-size: Metrics.font-body;
                            font-weight: 700;
                            color: Theme.text-primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 26px;
                            height: 28px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            TouchArea { clicked => { if (root.speaker-count < 8) { root.speaker-count += 1; } } }
                            Text {
                                text: "+";
                                font-size: Metrics.font-body;
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 176px;
                            height: 28px;
                            border-radius: 6px;
                            background: root.diarizing
                                ? Theme.accent.with-alpha(0.5)
                                : dia-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                            animate background { duration: 120ms; }
                            dia-ta := TouchArea {
                                clicked => {
                                    if (!root.diarizing) {
                                        // F — confirm before a re-run that would wipe custom names.
                                        if (root.has-diarization && root.has-speaker-names) {
                                            root.confirm-rediar = true;
                                        } else {
                                            root.run-diarization();
                                        }
                                    }
                                }
                            }
                            Text {
                                text: root.has-diarization ? @tr("Re-detect speakers") : @tr("Detect speakers");
                                color: Theme.on-accent;
                                font-size: Metrics.font-label;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    // Progress / error line.
                    if root.diar-status != "" : Text {
                        text: root.diar-status;
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        wrap: word-wrap;
                    }
                    // Rename list (voice view): coloured dot + editable name per speaker.
                    // V-3 (fable review): a horizontal ScrollView bounds the row so 5+ speakers
                    // scroll instead of overflowing the window (the «Память >4» bug shape). For
                    // the common 2–3 speakers it fits and no scrollbar shows.
                    if root.by-voice && root.speakers.length > 0 : ScrollView {
                        height: 42px;
                        HorizontalLayout {
                            spacing: Metrics.space-md;
                            for sp[si] in root.speakers : HorizontalLayout {
                                spacing: 5px;
                                Rectangle {
                                    width: 11px;
                                    height: 11px;
                                    border-radius: 5px;
                                    background: sp.color;
                                    y: (parent.height - self.height) / 2;
                                }
                                LineEdit {
                                    text: sp.label;
                                    width: 108px;
                                    font-size: Metrics.font-label;
                                    // F-fix (fable, live-proven): commit AS-TYPED, not just on Enter.
                                    // The old Enter-only `accepted` let a typed-but-uncommitted name sit
                                    // VISIBLE while the store stayed empty → the re-detect guard saw no
                                    // names and silently re-ran («не спрашивает»). `edited` keeps the store
                                    // equal to the visible text; a blank value clears the rename.
                                    edited(t) => { root.rename-speaker(sp.id, t); }
                                }
                            }
                        }
                    }
                }

                // ── I (2026-07-05, owner top priority) — in-transcript search row: type → matching
                // lines tint; Enter / ‹ › jump the player to a match's moment + scroll the list to it. ──
                if !root.empty : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    padding-left: 4px;
                    LineEdit {
                        horizontal-stretch: 1;
                        text <=> root.search-query;
                        placeholder-text: @tr("Search in transcript");
                        font-size: Metrics.font-label;
                        edited(t) => { root.search-edited(t); }
                        accepted => { root.search-jump(1); }
                    }
                    if root.search-query != "" : Text {
                        text: "\{root.search-pos} / \{root.search-count}";
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                    // ‹ prev / › next match (ASCII, per the v0.25.1 lesson: skia draws exotic glyphs square).
                    Rectangle {
                        width: 26px;
                        height: 28px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.border;
                        TouchArea { clicked => { root.search-jump(-1); } }
                        Text {
                            text: "<";
                            font-size: Metrics.font-body;
                            color: Theme.text-primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 26px;
                        height: 28px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.border;
                        TouchArea { clicked => { root.search-jump(1); } }
                        Text {
                            text: ">";
                            font-size: Metrics.font-body;
                            color: Theme.text-primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── "Select all" header above the list ──
                if !root.empty : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    padding-left: 4px;
                    Tick {
                        checked: root.all-selected;
                        clicked => {
                            root.toggle-all(!root.all-selected);
                        }
                    }
                    Text {
                        text: @tr("select all");
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                // ── Empty: no saved transcript ──
                if root.empty : Text {
                    text: @tr("Transcript not saved");
                    font-size: Metrics.font-label;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                // ── Chronological transcript rows ──
                // I-fix — UNCONDITIONAL so the `lv` name is reachable from scroll-to-line (Slint
                // can't reference a conditional element from a function). Empty → stretch 0 so the
                // "Transcript not saved" placeholder (above) fills instead; 0 rows render anyway.
                lv := ListView {
                    // Virtualized (only VISIBLE rows are instantiated) → the list height is no
                    // longer bounded by the SW-renderer i16 (32767px) limit, so ALL utterances
                    // show — no display cap. Per-row `max-height:120px` + clip still bounds any
                    // single very long utterance.
                    vertical-stretch: root.empty ? 0 : 1;
                    for line[i] in root.lines : Rectangle {
                            // Баг5 — clamp + clip so ONE long utterance can't grow the
                            // row unbounded; with TRANSCRIPT_DISPLAY_CAP this keeps the
                            // un-virtualized list under the SW renderer's i16 (32767px)
                            // coordinate limit (see the guard in aux_windows.rs). The
                            // clipped tail is still in "Copy all".
                            max-height: 120px;
                            clip: true;
                            // Active-line highlight (ТЗ2b) — the row whose timecode
                            // contains the current playback position.
                            background: i == root.active-line
                                ? Theme.accent.with-alpha(0.14)
                                : line.matched ? Theme.warning.with-alpha(0.12)
                                : transparent;
                            border-radius: 4px;
                            // Clicking the row (anywhere but the checkbox) plays the
                            // mix from this line's moment (ТЗ2b). The Tick's own
                            // TouchArea below intercepts checkbox clicks first.
                            TouchArea {
                                clicked => {
                                    root.play-line(i);
                                }
                            }
                            HorizontalLayout {
                                spacing: Metrics.space-sm;
                                padding-left: 4px;
                                // P1/C2 — keep the ⭐ column left of the ListView scrollbar (reuse the
                                // tiles' right-inset), so stars stay clickable and aren't overdrawn.
                                padding-right: 18px;
                                padding-top: 1px;
                                padding-bottom: 1px;
                                Tick {
                                    checked: line.checked;
                                    clicked => {
                                        root.toggle-line(i);
                                    }
                                }
                                // Omit the time column entirely when the session
                                // start is unknown (matches the markdown view).
                                if line.offset-label != "" : Text {
                                    text: line.offset-label;
                                    font-size: Metrics.font-caption;
                                    color: Theme.text-muted;
                                    vertical-alignment: top;
                                    width: 52px;
                                }
                                Text {
                                    text: line.speaker;
                                    font-size: Metrics.font-caption;
                                    font-weight: 700;
                                    // Role view: the theme accent (scheme-aware). Voice view:
                                    // the per-speaker palette colour Rust set on the line.
                                    color: root.by-voice ? line.speaker-color : Theme.accent;
                                    vertical-alignment: top;
                                    width: 84px;
                                }
                                // ТЗ 2026-07-03 — selectable (read-only TextInput):
                                // drag-select → right-click Copy / ⭐-to-memory. Clicks
                                // on the text now go to selection, so the row's play-line
                                // seek stays on the timecode/speaker columns + padding
                                // (plain Texts, clicks fall through to the row TouchArea).
                                SelectableText {
                                    text: line.text;
                                    font-size: Metrics.font-body;
                                    text-color: Theme.text-secondary;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                    capture(a, c) => { root.capture-line-selection(i, a, c); }
                                }
                                // G2b — ⭐ MULTI-mark this line (toggle), like the tiles.
                                // Its own TouchArea intercepts the click so it doesn't also
                                // trigger the row's play-line (like the Tick above). Mark
                                // several → one «В память (N)» bar below.
                                Rectangle {
                                    width: 22px;
                                    height: 16px;
                                    border-radius: 4px;
                                    background: star-ta.has-hover ? Theme.border-strong : transparent;
                                    star-ta := TouchArea {
                                        // R1.2: latch SHIFT on pointer-down, fire on `clicked` (keeps
                                        // click-cancel-on-drag-off — same pattern as the tiles' StarMark).
                                        property <bool> shift-latched;
                                        pointer-event(e) => {
                                            if (e.kind == PointerEventKind.down) {
                                                self.shift-latched = e.modifiers.shift;
                                            }
                                        }
                                        clicked => {
                                            root.toggle-line-marked(i, self.shift-latched);
                                        }
                                    }
                                    // Muted outline star (SVG), same as the tiles' StarMark:
                                    // accent + full opacity when marked; muted + dim at rest.
                                    Image {
                                        source: @image-url("../assets/icons/star.svg");
                                        colorize: line.marked ? Theme.accent : (star-ta.has-hover ? Theme.accent : Theme.text-muted);
                                        opacity: line.marked ? 1.0 : (star-ta.has-hover ? 1.0 : 0.5);
                                        width: 13px;
                                        height: 13px;
                                        image-fit: contain;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                    }
                                }
                            }
                        }
                }

                // G2b — «В память» bar (mirrors the tiles): shows when ≥1 line is
                // ⭐-marked OR a text selection is pending. N==1 / a selection exposes the
                // edit buffer to trim before save; N>1 joins the marked lines into ONE
                // record. «В память (N)» = save-marked; a pending selection = save-capture.
                if root.marked-count >= 1 || root.capture-pending : VerticalLayout {
                    spacing: Metrics.space-sm;
                    // RS2: bounded, scrollable multi-line editor (was a LineEdit) so a big captured
                    // selection scrolls within 160px instead of pushing «В память»/«Отмена» off.
                    if root.marked-count == 1 || root.capture-pending : TextEdit {
                        text <=> root.capture-text;
                        wrap: word-wrap;
                        min-height: 44px;
                        max-height: 160px;
                    }
                    HorizontalLayout {
                        spacing: Metrics.space-sm;
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            text: root.capture-pending ? @tr("To memory") : @tr("To memory ({})", root.marked-count);
                            clicked => {
                                if (root.capture-pending) {
                                    root.save-capture();
                                } else {
                                    root.save-marked();
                                }
                            }
                        }
                        Button {
                            text: @tr("Cancel");
                            clicked => {
                                if (root.capture-pending) {
                                    root.cancel-capture();
                                } else {
                                    root.clear-marks();
                                }
                            }
                        }
                    }
                }

                // ── Overflow footer (Баг5): the list is capped under the SW-renderer
                // i16 limit; disclose the hidden tail so a long transcript isn't
                // silently cut. "Copy all" still exports every line (full utterances).
                if root.overflow-count > 0 : Text {
                    text: @tr("{} more lines not shown - use 'Copy all' for the full transcript", root.overflow-count);
                    font-size: Metrics.font-caption;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // ── Mini-player (ТЗ2b): play/pause · seek-bar · time ──
                if root.has-audio : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        width: 40px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        background: pp-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                        animate background { duration: 120ms; }
                        pp-ta := TouchArea {
                            clicked => {
                                root.toggle-play();
                            }
                        }
                        // F5 — SVG play/pause (the main bar's icons) instead of the
                        // ▶/⏸ emoji; centered via fill+center layout.
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                alignment: center;
                                Image {
                                    source: root.playing
                                        ? @image-url("../assets/icons/pause.svg")
                                        : @image-url("../assets/icons/play.svg");
                                    colorize: Theme.on-accent;
                                    width: 14px;
                                    height: 14px;
                                    image-fit: contain;
                                }
                            }
                        }
                    }
                    // Seek-bar: click anywhere to jump to that fraction.
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 28px;
                        seek-ta := TouchArea {
                            clicked => {
                                root.seek-fraction(self.mouse-x / self.width);
                            }
                        }
                        Rectangle {
                            y: (parent.height - self.height) / 2;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.border;
                            Rectangle {
                                x: 0;
                                width: parent.width * root.progress;
                                height: 100%;
                                border-radius: 3px;
                                background: Theme.accent;
                            }
                        }
                    }
                    Text {
                        text: root.time-text;
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                    // Speed cycle 1× → 1.5× → 2× (owner req 2026-07-05). rodio set_speed
                    // resamples, so pitch shifts slightly — fine for review; a pitch-
                    // preserving version would need a time-stretch dep.
                    Rectangle {
                        width: 46px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: spd-ta.pressed
                            ? Theme.accent.with-alpha(0.22)
                            : spd-ta.has-hover ? Theme.accent.with-alpha(0.14) : transparent;
                        animate background { duration: 120ms; }
                        spd-ta := TouchArea {
                            clicked => {
                                root.speed = root.speed >= 2.0 ? 1.0 : (root.speed >= 1.5 ? 2.0 : 1.5);
                                root.set-speed(root.speed);
                            }
                        }
                        Text {
                            text: root.speed == 1.0 ? "1×" : (root.speed == 1.5 ? "1.5×" : "2×");
                            color: Theme.accent;
                            font-size: Metrics.font-caption;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    // Volume boost cycle 1× → 2× → 3× (owner req «повышение звука») —
                    // amplify quiet recordings; may clip at extreme gain on loud sources.
                    Rectangle {
                        width: 54px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: vol-ta.pressed
                            ? Theme.accent.with-alpha(0.22)
                            : vol-ta.has-hover ? Theme.accent.with-alpha(0.14) : transparent;
                        animate background { duration: 120ms; }
                        vol-ta := TouchArea {
                            clicked => {
                                root.volume = root.volume >= 3.0 ? 1.0 : root.volume + 1.0;
                                root.set-volume(root.volume);
                            }
                        }
                        HorizontalLayout {
                            alignment: center;
                            spacing: 3px;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("../assets/icons/speaker.svg");
                                    colorize: Theme.accent;
                                    width: 13px;
                                    height: 13px;
                                    image-fit: contain;
                                }
                            }
                            Text {
                                text: root.volume == 1.0 ? "1×" : (root.volume == 2.0 ? "2×" : "3×");
                                color: Theme.accent;
                                font-size: Metrics.font-caption;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
                if root.empty == false && root.has-audio == false : Text {
                    text: @tr("Audio not saved");
                    font-size: Metrics.font-caption;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                }
            }
        }

        // F (fable) — «Re-detect speakers?» confirm, an overlay sibling of `fs` (clones the
        // archive resummary scrim). Shown only when a result with custom names exists — a re-run
        // wipes the names (cluster ids permute), so guard it. Scrim-click / Cancel / Esc dismiss.
        if root.confirm-rediar : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.scrim;
            TouchArea { clicked => { root.confirm-rediar = false; } }
            Rectangle {
                width: 380px;
                height: 172px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.bg-surface;
                border-radius: Metrics.radius-panel;
                border-width: Metrics.border-thin;
                border-color: Theme.border-strong;
                // Swallow clicks on the card so they don't reach the scrim (dismiss).
                TouchArea { }
                VerticalLayout {
                    padding: Metrics.space-md;
                    spacing: Metrics.space-sm;
                    Text {
                        text: @tr("Re-detect speakers?");
                        font-size: Metrics.font-heading;
                        font-weight: 700;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: @tr("Speaker names you set will be reset.");
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: Metrics.space-sm;
                        alignment: center;
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            background: rd-cancel-ta.has-hover ? Theme.bg-elevated : transparent;
                            rd-cancel-ta := TouchArea { clicked => { root.confirm-rediar = false; } }
                            Text {
                                text: @tr("Cancel");
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            background: rd-ok-ta.pressed
                                ? Theme.accent.with-alpha(0.7)
                                : rd-ok-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.88);
                            rd-ok-ta := TouchArea {
                                clicked => {
                                    root.confirm-rediar = false;
                                    root.run-diarization();
                                }
                            }
                            Text {
                                text: @tr("Re-detect");
                                color: Theme.on-accent;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
