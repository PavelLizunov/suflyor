// Session transcript viewer (ТЗ1) — a structured, READ-ONLY chronological list of
// a session's utterances (time · speaker · text), opened from the archive via the
// 📄 row button. Per-line checkboxes + "Copy all / Copy selected" (decision #7).
// Chrome (frameless / opaque / always-on-top, header drag, CloseButton, Esc)
// mirrors archive.slint verbatim — incl. the opaque-bg trap note there.
//
// i18n: chrome strings are @tr (English msgid; RU in slint-replay.po). The row
// DATA (time / speaker / text) is language-neutral, built in Rust.

import { ScrollView, Palette, LineEdit, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton } from "controls.slint";
import { Metrics } from "metrics.slint";
import { DarkCheck } from "settings_panel.slint";

// One transcript row, built in Rust from a session's utterances.
export struct TranscriptLine {
    offset-label: string, // "02:15" session-relative, or "" if start unknown
    speaker: string,      // "Система" | "Микрофон"
    text: string,
    checked: bool,        // ТЗ1 — per-line selection for "Copy selected"
    start-ms: int,        // ТЗ2b — session-relative ms, for click-to-seek + active line
}

// A compact square checkbox (reused for per-line selection + "select all").
// DarkCheck is a big toggle SWITCH — too heavy per row — so this is a small tick.
component Tick inherits Rectangle {
    in property <bool> checked;
    callback clicked();
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border-width: 1px;
    border-color: root.checked ? Theme.accent : Theme.border;
    background: root.checked ? Theme.accent : transparent;
    animate background, border-color { duration: 100ms; }
    // F5 — SVG check (project standard) instead of a text "✓". Centered via the
    // same fill+center layout the archive RowIcon uses (a bare Image won't center).
    if root.checked : VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                source: @image-url("../assets/icons/check.svg");
                colorize: Theme.on-accent;
                width: 11px;
                height: 11px;
                image-fit: contain;
            }
        }
    }
    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component TranscriptWindow inherits Window {
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }

    title: "Transcript";
    icon: @image-url("../assets/icon.svg");
    // Opaque (NOT transparent) — a transparent + WS_EX_LAYERED frameless window
    // alpha-clamps text invisible (archive.slint learned this the hard way).
    background: Theme.bg-surface;
    no-frame: true;
    always-on-top: true;
    preferred-width: 720px;
    preferred-height: 560px;
    min-width: 480px;
    min-height: 320px;

    // Rust-built: session heading (title/time), the rows, and the empty flag.
    in-out property <string> heading: "";
    in-out property <[TranscriptLine]> lines: [];
    in-out property <bool> empty: false;
    // ТЗ1 copy (decision #7): "Copy all / selected" honour the "with timecodes"
    // toggle; `copied` flashes a 1.5s confirmation on the buttons (set from Rust).
    // `all-selected` mirrors the per-line checkboxes (kept in sync by Rust).
    in-out property <bool> with-timecodes: false;
    in-out property <bool> copied: false;
    in-out property <bool> all-selected: false;
    // ТЗ2b player: `has-audio` gates the mini-player; the rest are polled from
    // Rust — progress 0..1, "mm:ss / mm:ss" time, the active line index, play state.
    in-out property <bool> has-audio: false;
    in-out property <bool> playing: false;
    in-out property <float> progress: 0;
    in-out property <string> time-text: "";
    in-out property <int> active-line: -1;
    // A2 (ТЗ 2026-07-02) — «⭐ В память»: the line index whose capture editor is
    // open (-1 = none) + the shared edit buffer. One line at a time.
    in-out property <int> capturing-line-index: -1;
    in-out property <string> capture-text: "";

    callback toggle-play();
    callback play-line(int);
    callback seek-fraction(float);
    callback copy-all-requested();
    callback copy-selected-requested();
    callback toggle-line(int);
    callback toggle-all(bool);
    callback close-requested();
    callback drag-start-requested();
    callback drag-moved();
    // A2 — save the (edited) captured line as an approved memory note.
    callback add-to-memory(string);

    forward-focus: fs;

    Rectangle {
        background: Theme.bg-surface.with-alpha(0.95);
        border-radius: Metrics.radius-panel;
        border-width: Metrics.border-thin;
        border-color: Theme.border;

        fs := FocusScope {
            width: 100%;
            height: 100%;
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.close-requested();
                    return accept;
                }
                return reject;
            }

            VerticalLayout {
                padding: Metrics.space-md;
                spacing: Metrics.space-sm;

                // ── Header: icon · title · session heading (DRAG) · close ──
                HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        horizontal-stretch: 1;
                        TouchArea {
                            pointer-event(ev) => {
                                if (ev.button == PointerEventButton.left
                                    && ev.kind == PointerEventKind.down) {
                                    root.drag-start-requested();
                                }
                            }
                            moved => { if (self.pressed) { root.drag-moved(); } }
                        }
                        HorizontalLayout {
                            spacing: Metrics.space-sm;
                            Image {
                                source: @image-url("../assets/icons/bubble.svg");
                                colorize: Theme.text-primary;
                                width: 18px;
                                height: 18px;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Transcript");
                                font-size: Metrics.font-heading;
                                font-weight: 700;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.heading;
                                font-size: Metrics.font-caption;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                    }
                    CloseButton {
                        clicked => { root.close-requested(); }
                    }
                }

                Rectangle {
                    background: Theme.border;
                    height: Metrics.border-thin;
                }

                // ── Toolbar: copy all / copy selected + timecode toggle (ТЗ1 #7) ──
                if !root.empty : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        width: 124px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        background: copy-ta.pressed
                            ? Theme.accent.with-alpha(0.7)
                            : copy-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                        animate background { duration: 120ms; }
                        copy-ta := TouchArea {
                            clicked => {
                                root.copy-all-requested();
                            }
                        }
                        Text {
                            // Per-scheme WCAG-AA text colour on the accent fill (white
                            // fails on the bright mint scheme); matches every other
                            // filled-accent control.
                            text: root.copied ? @tr("Copied ✓") : @tr("Copy all");
                            color: Theme.on-accent;
                            font-size: Metrics.font-label;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 150px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.accent;
                        background: sel-ta.pressed
                            ? Theme.accent.with-alpha(0.22)
                            : sel-ta.has-hover ? Theme.accent.with-alpha(0.14) : transparent;
                        animate background { duration: 120ms; }
                        sel-ta := TouchArea {
                            clicked => {
                                root.copy-selected-requested();
                            }
                        }
                        Text {
                            text: root.copied ? @tr("Copied ✓") : @tr("Copy selected");
                            color: Theme.accent;
                            font-size: Metrics.font-label;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    DarkCheck {
                        text: @tr("with timecodes [mm:ss]");
                        checked <=> root.with-timecodes;
                    }
                }

                // ── "Select all" header above the list ──
                if !root.empty : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    padding-left: 4px;
                    Tick {
                        checked: root.all-selected;
                        clicked => {
                            root.toggle-all(!root.all-selected);
                        }
                    }
                    Text {
                        text: @tr("select all");
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                // ── Empty: no saved transcript ──
                if root.empty : Text {
                    text: @tr("Transcript not saved");
                    font-size: Metrics.font-label;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                // ── Chronological transcript rows ──
                if !root.empty : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px;
                        for line[i] in root.lines : Rectangle {
                            // Active-line highlight (ТЗ2b) — the row whose timecode
                            // contains the current playback position.
                            background: i == root.active-line
                                ? Theme.accent.with-alpha(0.14)
                                : transparent;
                            border-radius: 4px;
                            // Clicking the row (anywhere but the checkbox) plays the
                            // mix from this line's moment (ТЗ2b). The Tick's own
                            // TouchArea below intercepts checkbox clicks first.
                            TouchArea {
                                clicked => {
                                    root.play-line(i);
                                }
                            }
                            HorizontalLayout {
                                spacing: Metrics.space-sm;
                                padding-left: 4px;
                                padding-right: 4px;
                                padding-top: 1px;
                                padding-bottom: 1px;
                                Tick {
                                    checked: line.checked;
                                    clicked => {
                                        root.toggle-line(i);
                                    }
                                }
                                // Omit the time column entirely when the session
                                // start is unknown (matches the markdown view).
                                if line.offset-label != "" : Text {
                                    text: line.offset-label;
                                    font-size: Metrics.font-caption;
                                    color: Theme.text-muted;
                                    vertical-alignment: top;
                                    width: 52px;
                                }
                                Text {
                                    text: line.speaker;
                                    font-size: Metrics.font-caption;
                                    font-weight: 700;
                                    color: Theme.accent;
                                    vertical-alignment: top;
                                    width: 84px;
                                }
                                Text {
                                    text: line.text;
                                    font-size: Metrics.font-body;
                                    color: Theme.text-secondary;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                                // A2 — ⭐ capture THIS line into memory. Its own
                                // TouchArea intercepts the click, so it doesn't also
                                // trigger the row's play-line (like the Tick above).
                                Rectangle {
                                    width: 22px;
                                    height: 16px;
                                    border-radius: 4px;
                                    background: star-ta.has-hover ? Theme.border-strong : transparent;
                                    star-ta := TouchArea {
                                        clicked => {
                                            root.capture-text = line.text;
                                            root.capturing-line-index = i;
                                        }
                                    }
                                    Text {
                                        text: "⭐";
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // A2 (ТЗ 2026-07-02) — «⭐ В память»: one editor for the window,
                // seeded by the ⭐ on each row. Edit/trim the captured line → Save
                // (approved memory note) / Cancel.
                if root.capturing-line-index != -1 : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Text {
                        text: @tr("Add to memory:");
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                    LineEdit {
                        text <=> root.capture-text;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: @tr("Save");
                        clicked => {
                            root.add-to-memory(root.capture-text);
                            root.capturing-line-index = -1;
                        }
                    }
                    Button {
                        text: @tr("Cancel");
                        clicked => { root.capturing-line-index = -1; }
                    }
                }

                // ── Mini-player (ТЗ2b): play/pause · seek-bar · time ──
                if root.has-audio : HorizontalLayout {
                    spacing: Metrics.space-sm;
                    Rectangle {
                        width: 40px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-radius: 6px;
                        background: pp-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.85);
                        animate background { duration: 120ms; }
                        pp-ta := TouchArea {
                            clicked => {
                                root.toggle-play();
                            }
                        }
                        // F5 — SVG play/pause (the main bar's icons) instead of the
                        // ▶/⏸ emoji; centered via fill+center layout.
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                alignment: center;
                                Image {
                                    source: root.playing
                                        ? @image-url("../assets/icons/pause.svg")
                                        : @image-url("../assets/icons/play.svg");
                                    colorize: Theme.on-accent;
                                    width: 14px;
                                    height: 14px;
                                    image-fit: contain;
                                }
                            }
                        }
                    }
                    // Seek-bar: click anywhere to jump to that fraction.
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 28px;
                        seek-ta := TouchArea {
                            clicked => {
                                root.seek-fraction(self.mouse-x / self.width);
                            }
                        }
                        Rectangle {
                            y: (parent.height - self.height) / 2;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.border;
                            Rectangle {
                                x: 0;
                                width: parent.width * root.progress;
                                height: 100%;
                                border-radius: 3px;
                                background: Theme.accent;
                            }
                        }
                    }
                    Text {
                        text: root.time-text;
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                }
                if root.empty == false && root.has-audio == false : Text {
                    text: @tr("Audio not saved");
                    font-size: Metrics.font-caption;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
