import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton } from "controls.slint";
import { Metrics } from "metrics.slint";

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.text-primary;
    in property <length> glyph-size: 15px;
    in property <length> slot-width: 26px;
    in property <length> slot-height: 26px;
    width: slot-width;
    height: slot-height;
    horizontal-stretch: 0;

    Image {
        source: root.icon;
        colorize: root.tint;
        width: root.glyph-size;
        height: root.glyph-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component BrandHeaderMark inherits Rectangle {
    in property <length> mark-size: 22px;
    width: mark-size;
    height: mark-size;
    horizontal-stretch: 0;

    Image {
        source: @image-url("../assets/brand-head.svg");
        colorize: Theme.is-light ? #111827 : #ffffff;
        width: root.mark-size;
        height: root.mark-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component TableHeader inherits Rectangle {
    in property <string> left;
    in property <string> right;
    height: 28px;
    background: Theme.bg-elevated;
    border-width: 1px;
    border-color: Theme.border;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 124px;
            height: parent.height;
            border-width: 0px;
            Text {
                text: root.left;
                font-family: Theme.font-mono;
                font-size: 10px;
                font-weight: 700;
                color: Theme.text-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: Theme.border;
            }
        }
        Text {
            text: root.right;
            font-family: Theme.font-mono;
            font-size: 10px;
            font-weight: 700;
            color: Theme.text-muted;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

component TableRow inherits Rectangle {
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <string> glyph: "";
    in property <string> desc;
    in property <bool> key-row: false;
    height: 42px;
    background: transparent;
    border-width: 1px;
    border-color: Theme.border;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 124px;
            height: parent.height;
            Rectangle {
                width: root.key-row ? 86px : (root.glyph != "" ? 104px : 28px);
                height: 26px;
                border-radius: 7px;
                border-width: 1px;
                border-color: Theme.border-strong;
                background: root.key-row ? Theme.accent.with-alpha(0.12) : Theme.bg-elevated;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                if root.has-icon && root.glyph == "" : IconSlot {
                    icon: root.icon;
                    tint: Theme.text-primary;
                    glyph-size: 15px;
                    slot-width: parent.width;
                    slot-height: parent.height;
                }
                if root.glyph != "" : Text {
                    text: root.glyph;
                    x: 0px;
                    width: parent.width;
                    height: parent.height;
                    font-family: Theme.font-mono;
                    font-size: root.key-row ? 11px : 10px;
                    font-weight: 700;
                    color: root.key-row ? Theme.accent : Theme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: Theme.border;
            }
        }
        Text {
            text: root.desc;
            font-size: 12px;
            color: Theme.text-secondary;
            wrap: word-wrap;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

export component HelpWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    title: @tr("Help");
    default-font-family: Theme.font-sans;
    background: Theme.bg-surface;
    preferred-width: 640px;
    preferred-height: 680px;

    callback cancelled();
    callback drag-start-requested();
    callback drag-moved();
    forward-focus: scope;

    scope := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.cancelled();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            padding: Metrics.space-lg;
            spacing: 10px;

            HorizontalLayout {
                spacing: Metrics.space-sm;
                Rectangle {
                    horizontal-stretch: 1;
                    height: Metrics.control-lg;
                    TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => {
                            if (self.pressed) { root.drag-moved(); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 7px;
                        alignment: start;
                        BrandHeaderMark { mark-size: 22px; }
                        Text {
                            text: "::";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            font-weight: 700;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: @tr("Help — icons, hotkeys & gestures");
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }
                CloseButton {
                    clicked => { root.cancelled(); }
                }
            }

            Rectangle { background: Theme.border; height: 1px; }

            ScrollView {
                VerticalLayout {
                    spacing: 0px;

                    Text {
                        text: @tr("Bar icons");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    TableHeader { left: @tr("Icon"); right: @tr("What it does"); }
                    for row in [
                        { ico: @image-url("../assets/icons/grip.svg"), hasicon: true, glyph: "", desc: @tr("Drag to move the bar; shows the live state") },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: "", desc: @tr("Toggle continuous mic capture (your voice)") },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: "", desc: @tr("Toggle continuous system-audio capture (the other side)") },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: @tr("ask"), desc: @tr("Hold to record your voice → AI answer (swipe up to lock)") },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: @tr("grab"), desc: @tr("Hold to capture system audio → AI answer (swipe up to lock)") },
                        { ico: @image-url("../assets/icons/play.svg"), hasicon: true, glyph: "", desc: @tr("Start / stop the live session (transcript + auto-tips)") },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: false, glyph: "$0.000", desc: @tr("Session cost (cloud only; local is free)") },
                        { ico: @image-url("../assets/icons/stealth.svg"), hasicon: true, glyph: "", desc: @tr("Stealth: hide the overlay from screen capture / share") },
                        { ico: @image-url("../assets/icons/flame.svg"), hasicon: true, glyph: "", desc: @tr("Aggressive auto-tiles (answer more often)") },
                        { ico: @image-url("../assets/icons/pencil.svg"), hasicon: true, glyph: "", desc: @tr("Write a question as text") },
                        { ico: @image-url("../assets/icons/plus.svg"), hasicon: true, glyph: "", desc: @tr("New tile from the last line / a manual question") },
                        { ico: @image-url("../assets/icons/camera.svg"), hasicon: true, glyph: "", desc: @tr("Screenshot a region → AI vision answer") },
                        { ico: @image-url("../assets/icons/archive.svg"), hasicon: true, glyph: "", desc: @tr("Session archive: browse and search past calls (also F7)") },
                        { ico: @image-url("../assets/icons/summary.svg"), hasicon: true, glyph: "", desc: @tr("Call summary: digest (participants, topics, decisions, tasks)") },
                        { ico: @image-url("../assets/icons/gear.svg"), hasicon: true, glyph: "", desc: @tr("Settings") },
                        { ico: @image-url("../assets/icons/sos.svg"), hasicon: true, glyph: "", desc: @tr("This help (also F1)") },
                        { ico: @image-url("../assets/icons/restart.svg"), hasicon: true, glyph: "", desc: @tr("Restart the overlay (two-step; settings survive)") },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: true, glyph: "", desc: @tr("Quit (two-step)") },
                    ] : TableRow {
                        icon: row.ico;
                        has-icon: row.hasicon;
                        glyph: row.glyph;
                        desc: row.desc;
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: @tr("Hotkeys");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    TableHeader { left: @tr("Key"); right: @tr("Action"); }
                    for row in [
                        ["F1", @tr("This help")],
                        ["F9", @tr("Ask AI now (streams the answer into a tile)")],
                        ["Shift+F9", @tr("Ask AI escalated to the smart cloud model (one-shot)")],
                        ["F8", @tr("Screenshot → AI vision (drag a region; Esc cancels)")],
                        ["F3", @tr("Re-ask the last question with fresh context")],
                        ["F4", @tr("Knowledge-base palette (open / close)")],
                        ["F6", @tr("Manual tile from the last transcript line")],
                        ["F7", @tr("Session archive (browse and search)")],
                        ["Shift+F8", @tr("Screenshot → translate text (AI vision)")],
                        ["Shift+Alt+1", @tr("Read the selected text aloud (TTS)")],
                        ["Shift+Alt+2", @tr("OCR a screen region and read it aloud")],
                        ["Shift+Alt+3", @tr("Pause / resume reading aloud")],
                    ] : TableRow {
                        key-row: true;
                        glyph: row[0];
                        desc: row[1];
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: @tr("Record gestures");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Text {
                        text: @tr("Hold a record button to record, release to send. While holding, swipe up to lock; releasing keeps recording. Click stop to send.");
                        font-size: Metrics.font-label;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: @tr("Local model and vision");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    Text {
                        text: @tr("Local AI model: Faster (4B) or Smarter (12B) — choose in Settings → AI. If the local AI drops, the overlay restarts the server itself. Recognition language (Auto/Russian/English) is in the same place, under Settings → Speech. Vision (F8) runs on the 4B model.");
                        font-size: Metrics.font-label;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: @tr("Read-aloud · recognition · compact mode");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    Text {
                        text: @tr("Shift+Alt+1 — read the selected text aloud; Shift+Alt+2 — OCR text from a screen region and read it; Shift+Alt+3 — pause/resume. Voices (TTS) and the recognition engine (OCR) install with a button in Settings → AI (TTS and Vision). Compact \"reader\" mode: the collapse chip on the bar turns it into a tiny read-aloud-only pill. \"Listening mode\" (Settings → Auto-tiles) mutes auto-tiles so you can just record and listen.");
                        font-size: Metrics.font-label;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;
            border-width: Metrics.border-thin;
            border-color: Theme.border;
        }
    }
}
