import { Button, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Metrics } from "metrics.slint";

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.text-primary;
    in property <length> glyph-size: 15px;
    in property <length> slot-width: 26px;
    in property <length> slot-height: 26px;
    width: slot-width;
    height: slot-height;
    horizontal-stretch: 0;

    Image {
        source: root.icon;
        colorize: root.tint;
        width: root.glyph-size;
        height: root.glyph-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component BrandHeaderMark inherits Rectangle {
    in property <length> mark-size: 22px;
    width: mark-size;
    height: mark-size;
    horizontal-stretch: 0;

    Image {
        source: @image-url("../assets/brand-head.svg");
        colorize: Theme.is-light ? #111827 : #ffffff;
        width: root.mark-size;
        height: root.mark-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component TableHeader inherits Rectangle {
    in property <string> left;
    in property <string> right;
    height: 28px;
    background: Theme.bg-elevated;
    border-width: 1px;
    border-color: Theme.border;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 124px;
            height: parent.height;
            border-width: 0px;
            Text {
                text: root.left;
                font-family: Theme.font-mono;
                font-size: 10px;
                font-weight: 700;
                color: Theme.text-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: Theme.border;
            }
        }
        Text {
            text: root.right;
            font-family: Theme.font-mono;
            font-size: 10px;
            font-weight: 700;
            color: Theme.text-muted;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

component TableRow inherits Rectangle {
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <string> glyph: "";
    in property <string> desc;
    in property <bool> key-row: false;
    height: 42px;
    background: transparent;
    border-width: 1px;
    border-color: Theme.border;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 124px;
            height: parent.height;
            Rectangle {
                width: root.key-row ? 86px : (root.glyph != "" ? 104px : 28px);
                height: 26px;
                border-radius: 7px;
                border-width: 1px;
                border-color: Theme.border-strong;
                background: root.key-row ? Theme.accent.with-alpha(0.12) : Theme.bg-elevated;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                if root.has-icon && root.glyph == "" : IconSlot {
                    icon: root.icon;
                    tint: Theme.text-primary;
                    glyph-size: 15px;
                    slot-width: parent.width;
                    slot-height: parent.height;
                }
                if root.glyph != "" : Text {
                    text: root.glyph;
                    x: 0px;
                    width: parent.width;
                    height: parent.height;
                    font-family: Theme.font-mono;
                    font-size: root.key-row ? 11px : 10px;
                    font-weight: 700;
                    color: root.key-row ? Theme.accent : Theme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: Theme.border;
            }
        }
        Text {
            text: root.desc;
            font-size: 12px;
            color: Theme.text-secondary;
            wrap: word-wrap;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

export component HelpWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    title: @tr("Help");
    default-font-family: Theme.font-sans;
    background: Theme.bg-surface;
    preferred-width: 640px;
    preferred-height: 680px;

    callback cancelled();
    callback drag-start-requested();
    callback drag-moved();
    forward-focus: scope;

    scope := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.cancelled();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            padding: Metrics.space-lg;
            spacing: 10px;

            HorizontalLayout {
                spacing: Metrics.space-sm;
                Rectangle {
                    horizontal-stretch: 1;
                    height: Metrics.control-lg;
                    TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => {
                            if (self.pressed) { root.drag-moved(); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 7px;
                        alignment: start;
                        BrandHeaderMark { mark-size: 22px; }
                        Text {
                            text: "::";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            font-weight: 700;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Справка - иконки, хоткеи и жесты";
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }
                Button {
                    text: "X";
                    clicked => { root.cancelled(); }
                }
            }

            Rectangle { background: Theme.border; height: 1px; }

            ScrollView {
                VerticalLayout {
                    spacing: 0px;

                    Text {
                        text: "Иконки бара";
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    TableHeader { left: "Иконка"; right: "Что делает"; }
                    for row in [
                        { ico: @image-url("../assets/icons/grip.svg"), hasicon: true, glyph: "", desc: "Перетащить = двигать бар; показывает состояние" },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: "", desc: "Постоянный захват микрофона (твой голос)" },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: "", desc: "Постоянный захват системного звука (собеседник)" },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: "спросить", desc: "Удержание = запись голоса -> ответ AI (свайп вверх = lock)" },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: "захватить", desc: "Удержание = запись системного звука -> ответ AI (свайп вверх = lock)" },
                        { ico: @image-url("../assets/icons/play.svg"), hasicon: true, glyph: "", desc: "Старт/стоп живой сессии (распознавание + авто-подсказки)" },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: false, glyph: "$0.000", desc: "Стоимость сессии (только cloud; локально бесплатно)" },
                        { ico: @image-url("../assets/icons/stealth.svg"), hasicon: true, glyph: "", desc: "Stealth: скрыть overlay от захвата/шеринга экрана" },
                        { ico: @image-url("../assets/icons/flame.svg"), hasicon: true, glyph: "", desc: "Агрессивные авто-тайлы (отвечать чаще)" },
                        { ico: @image-url("../assets/icons/pencil.svg"), hasicon: true, glyph: "", desc: "Написать вопрос текстом" },
                        { ico: @image-url("../assets/icons/plus.svg"), hasicon: true, glyph: "", desc: "Новый тайл из последней строки / ручной вопрос" },
                        { ico: @image-url("../assets/icons/camera.svg"), hasicon: true, glyph: "", desc: "Скриншот области -> ответ vision-AI" },
                        { ico: @image-url("../assets/icons/archive.svg"), hasicon: true, glyph: "", desc: "Архив сессий: просмотр и поиск прошлых созвонов (также F7)" },
                        { ico: @image-url("../assets/icons/summary.svg"), hasicon: true, glyph: "", desc: "Сводка созвона: конспект (участники, темы, решения, задачи)" },
                        { ico: @image-url("../assets/icons/gear.svg"), hasicon: true, glyph: "", desc: "Настройки" },
                        { ico: @image-url("../assets/icons/sos.svg"), hasicon: true, glyph: "", desc: "Эта справка (также F1)" },
                        { ico: @image-url("../assets/icons/restart.svg"), hasicon: true, glyph: "", desc: "Перезапуск overlay (в 2 шага; настройки сохраняются)" },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: true, glyph: "", desc: "Выход (в 2 шага)" },
                    ] : TableRow {
                        icon: row.ico;
                        has-icon: row.hasicon;
                        glyph: row.glyph;
                        desc: row.desc;
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: "Хоткеи";
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    TableHeader { left: "Клавиша"; right: "Действие"; }
                    for row in [
                        ["F1", "Эта справка"],
                        ["F9", "Спросить AI сейчас (ответ стримится в тайл)"],
                        ["Shift+F9", "Спросить AI с эскалацией к умной cloud-модели (разово)"],
                        ["F8", "Скриншот -> Vision-AI (выделите область; Esc - отмена)"],
                        ["F3", "Повторить последний вопрос со свежим контекстом"],
                        ["F4", "Палитра базы знаний (открыть / закрыть)"],
                        ["F6", "Ручной тайл из последней строки транскрипта"],
                        ["F7", "Архив сессий (просмотр и поиск)"],
                        ["Shift+F8", "Скриншот -> перевод текста (Vision-AI)"],
                    ] : TableRow {
                        key-row: true;
                        glyph: row[0];
                        desc: row[1];
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: @tr("Record gestures");
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Text {
                        text: @tr("Hold a record button to record, release to send. While holding, swipe up to lock; releasing keeps recording. Click stop to send.");
                        font-size: Metrics.font-label;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 18px; }
                    Text {
                        text: "Локальная модель и зрение";
                        font-weight: 700;
                        font-size: Metrics.font-body;
                        color: Theme.accent;
                    }
                    Rectangle { height: 8px; }
                    Text {
                        text: "Локальная AI-модель: Быстрее (4B) или Умнее (12B) — выбор в Настройки -> AI. Если локальный AI отвалится, overlay перезапустит сервер сам. Язык распознавания (Авто/Русский/English) — там же, в Настройки -> Речь. Зрение (F8) работает на модели 4B.";
                        font-size: Metrics.font-label;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;
            border-width: Metrics.border-thin;
            border-color: Theme.border;
        }
    }
}
