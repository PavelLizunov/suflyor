// V0.8.4 — 🆘 Help (F1): a read-only reference listing the bar icons, the global
// hotkeys, and the record gestures. Opened by F1 (toggle) or the bar's 🆘 chip
// via `open_help`; mirrors text_ask / wizard (frameless, SOLID Theme.bg-surface
// to dodge the documented Windows-DWM "created-but-invisible" pitfall for new
// frameless windows, stealth-aware, Esc / "X" to close). Strings are @tr; the
// hotkey rows REUSE the exact msgids already in the Settings ⌨ Hotkeys tab, so
// they need no new translations. ASCII "X" for close (✕ U+2715 renders as a
// missing-glyph box on the Slint+skia text fallback — same as the bar Quit).

import { Button, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Metrics } from "metrics.slint";

export component HelpWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    title: @tr("Help");
    default-font-family: Theme.font-sans;
    background: Theme.bg-surface;
    preferred-width: 580px;
    preferred-height: 660px;

    callback cancelled();
    // Frameless drag (cursor-delta, same as Settings) — the header is the handle.
    callback drag-start-requested();
    callback drag-moved();
    forward-focus: scope;

    scope := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.cancelled();
                return accept;
            }
            return reject;
        }
        // Brand watermark — faint vector logo behind the content (5% opacity),
        // centred, same as Settings. Everything above is transparent so it shows
        // through. colorize adapts it to dark + light schemes.
        Image {
            // Full brand scene watermark — theme-picked, NO colorize, 4–6%
            // opacity so it never competes with the help text (per design).
            source: Theme.is-light
                ? @image-url("../assets/brand-mark.png")
                : @image-url("../assets/brand-mark-light.png");
            opacity: 0.05;
            width: 280px;
            height: 280px;
            image-fit: contain;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
        VerticalLayout {
            padding: Metrics.space-lg;   // was 16px
            spacing: 10px;               // no exact token (between space-sm=8 and space-md=12)

            // ---- Header (doubles as the window drag handle, like Settings) ----
            HorizontalLayout {
                spacing: Metrics.space-sm;   // was 8px
                Rectangle {
                    horizontal-stretch: 1;
                    height: Metrics.control-lg;   // was 28px
                    // Drag handle fills the header; the icon + grip + title are
                    // drawn on top. Neither a Text nor a (non-Touch) layout
                    // captures pointer events, so the drag falls through here.
                    TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                root.drag-moved();
                            }
                        }
                    }
                    // App icon + ":: " accent grip + label — the same header
                    // chrome as Settings, so 🆘 reads as a real, draggable window.
                    HorizontalLayout {
                        spacing: 7px;
                        alignment: start;
                        Image {
                            // Head mark — theme-picked, NOT colorized (per design).
                            source: Theme.is-light
                                ? @image-url("../assets/brand-head.png")
                                : @image-url("../assets/brand-head-light.png");
                            width: 22px;
                            height: 22px;
                            image-fit: contain;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "::";
                            font-size: 14px;
                            font-weight: 700;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                        Text {
                            text: @tr("Help — icons, hotkeys & gestures");
                            font-size: 15px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }
                Button {
                    text: "X";
                    clicked => {
                        root.cancelled();
                    }
                }
            }

            // Under-header divider — same as Settings.
            Rectangle { background: Theme.border; height: 1px; }

            ScrollView {
                VerticalLayout {
                    spacing: 3px;

                    // ---- Bar icons ----
                    Text {
                        text: @tr("Bar icons");
                        font-weight: 700;
                        font-size: Metrics.font-body;   // was 12px
                        color: Theme.accent;
                    }
                    // Icon column uses the SAME design-system SVGs as the bar
                    // (skia-safe, colorized) so the help mirrors the live bar
                    // exactly. `hasicon` rows show the SVG (+ optional word for
                    // ask/grab); the cost row shows a "$0.000" text sample.
                    for row in [
                        { ico: @image-url("../assets/icons/grip.svg"), hasicon: true, glyph: "", desc: @tr("Drag to move the bar; shows the live state") },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: "", desc: @tr("Toggle continuous mic capture (your voice)") },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: "", desc: @tr("Toggle continuous system-audio capture (the other side)") },
                        { ico: @image-url("../assets/icons/mic.svg"), hasicon: true, glyph: @tr("ask"), desc: @tr("Hold to record your voice → AI answer (swipe up to lock)") },
                        { ico: @image-url("../assets/icons/speaker.svg"), hasicon: true, glyph: @tr("grab"), desc: @tr("Hold to capture system audio → AI answer (swipe up to lock)") },
                        { ico: @image-url("../assets/icons/play.svg"), hasicon: true, glyph: "", desc: @tr("Start / stop the live session (transcript + auto-tips)") },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: false, glyph: "$0.000", desc: @tr("Session cost (cloud only; local is free)") },
                        { ico: @image-url("../assets/icons/stealth.svg"), hasicon: true, glyph: "", desc: @tr("Stealth: hide the overlay from screen capture / share") },
                        { ico: @image-url("../assets/icons/flame.svg"), hasicon: true, glyph: "", desc: @tr("Aggressive auto-tiles (answer more often)") },
                        { ico: @image-url("../assets/icons/pencil.svg"), hasicon: true, glyph: "", desc: @tr("Write a question as text") },
                        { ico: @image-url("../assets/icons/plus.svg"), hasicon: true, glyph: "", desc: @tr("New tile from the last line / a manual question") },
                        { ico: @image-url("../assets/icons/camera.svg"), hasicon: true, glyph: "", desc: @tr("Screenshot a region → AI vision answer") },
                        { ico: @image-url("../assets/icons/gear.svg"), hasicon: true, glyph: "", desc: @tr("Settings") },
                        { ico: @image-url("../assets/icons/sos.svg"), hasicon: true, glyph: "", desc: @tr("This help (also F1)") },
                        { ico: @image-url("../assets/icons/restart.svg"), hasicon: true, glyph: "", desc: @tr("Restart the overlay (two-step; settings survive)") },
                        { ico: @image-url("../assets/icons/x.svg"), hasicon: true, glyph: "", desc: @tr("Quit (two-step)") },
                    ] : HorizontalLayout {
                        padding: 3px;                // small inset; no exact token (space-xs=4)
                        spacing: Metrics.space-md;   // was 12px
                        HorizontalLayout {
                            width: 86px;
                            spacing: 5px;
                            alignment: start;
                            if row.hasicon : Image {
                                source: row.ico;
                                colorize: Theme.text-primary;
                                width: 15px;
                                height: 15px;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                            if row.glyph != "" : Text {
                                text: row.glyph;
                                font-family: Theme.font-mono;
                                font-size: Metrics.font-body;   // was 12px
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: row.desc;
                            font-size: Metrics.font-body;   // was 12px
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle { height: Metrics.space-sm; }   // was 8px (section spacer)

                    // ---- Hotkeys (msgids reused from Settings → ⌨ Hotkeys) ----
                    Text {
                        text: @tr("Hotkeys");
                        font-weight: 700;
                        font-size: Metrics.font-body;   // was 12px
                        color: Theme.accent;
                    }
                    for row in [
                        ["F1", @tr("This help")],
                        ["F9", @tr("Ask AI now (streams the answer into a tile)")],
                        ["Shift+F9", @tr("Ask AI escalated to the smart cloud model (one-shot; tile shows a 🧠 badge)")],
                        ["F8", @tr("Screenshot → AI vision (drag a region; Esc cancels)")],
                        ["F3", @tr("Re-ask the last question with fresh context")],
                        ["F4", @tr("Knowledge-base palette (open / close)")],
                        ["F6", @tr("Manual tile from the last transcript line")],
                    ] : HorizontalLayout {
                        padding: 3px;                // small inset; no exact token (space-xs=4)
                        spacing: Metrics.space-md;   // was 12px
                        Text {
                            text: row[0];
                            font-family: Theme.font-mono;
                            font-size: Metrics.font-body;   // was 12px
                            font-weight: 700;
                            color: Theme.accent;
                            width: 86px;
                        }
                        Text {
                            text: row[1];
                            font-size: Metrics.font-body;   // was 12px
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle { height: Metrics.space-sm; }   // was 8px (section spacer)

                    // ---- Record gestures ----
                    Text {
                        text: @tr("Record gestures");
                        font-weight: 700;
                        font-size: Metrics.font-body;   // was 12px
                        color: Theme.accent;
                    }
                    Text {
                        text: @tr("Hold a record button to record, release to send. While holding, swipe up to LOCK (hands-free) — releasing keeps recording; click ⏹ to stop + send. Works on the bar (🎤/🔊) and on a tile's 🎤.");
                        font-size: Metrics.font-label;   // was 11px
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ---- Square 1px frame, matching Settings' bordered card (обводка) ----
        // A bare Rectangle captures no pointer events, so the X button, the
        // scrollbar and the drag handle all keep working underneath it.
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;
            border-width: Metrics.border-thin;   // was 1px
            border-color: Theme.border;
        }
    }
}
