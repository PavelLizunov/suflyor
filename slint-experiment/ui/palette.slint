// F4 knowledge-base palette.
//
// Frameless centered window: input field at top, RECENT chips below, a
// results list. The global F4 hotkey (and the overlay's 💡 chip) shows it;
// Esc / outside-click hides it. Up/Down navigate the results and Enter
// activates the selected one (#121). Results come from the real kb::search
// backend in overlay-backend; overlay_host.rs owns the wiring (global
// hotkey, outside-click dismissal, and the search call).

import { LineEdit, ScrollView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Metrics } from "metrics.slint";

export struct PaletteResult {
    key: string,
    title: string,
    preview: string,
    source: string,  // "snippet" | "kb"
}

export component PaletteWindow inherits Window {
    // Phase 4 — keep the std-widgets search LineEdit dark with the active
    // scheme instead of Slint's light fluent default.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    title: "F4 — KB palette";
    // Phase E6 fix: was `background: transparent` + frameless which
    // combined with WS_EX_LAYERED via make_transparent_overlay on the
    // HWND causes text to render invisible (alpha-clamped). Use solid
    // opaque background so the dark theme actually shows up. Frame
    // stays off for the floating-palette feel.
    icon: @image-url("../assets/icon.svg");
    background: Theme.bg-surface;
    no-frame: true;
    always-on-top: true;
    preferred-width: 520px;
    preferred-height: 420px;
    min-width: 420px;

    in-out property <string> query: "";
    // UI-audit 2026-06-13: was `["kubernetes","postgres","docker"]` — fake
    // "recent" data that ALWAYS showed (no Rust `set_recent_chips` ever
    // overwrote it), so every F4 open displayed three queries the user never
    // ran. Empty by default + the "recent:" label below hides when empty.
    // Wiring real recent queries is a separate backlog item.
    in-out property <[string]> recent-chips: [];
    in-out property <[PaletteResult]> results: [];
    in-out property <int> selected-index: 0;

    callback query-changed(string);
    callback chip-clicked(string);
    callback result-activated(int);
    callback close-requested();

    // Phase E6 v37 — direct initial keyboard focus to the search box so
    // the palette is ready to type the instant it opens AND so Escape
    // has a focused element to bubble up from to the FocusScope below.
    // (Bug A: "при вызове f4 я не могу сразу закрыть его" — Esc was
    // advertised but never wired, and nothing held focus.)
    forward-focus: search-input;

    Rectangle {
        background: Theme.bg-surface.with-alpha(0.93);
        border-radius: Metrics.radius-panel;   // was 12px
        border-width: Metrics.border-thin;   // was 1px
        border-color: Theme.border;

        FocusScope {
            width: 100%;
            height: 100%;
            // Escape closes the palette. The search LineEdit holds focus
            // (forward-focus above); it rejects Escape, which then
            // bubbles up to this ancestor FocusScope.
            // The std LineEdit (forward-focus target) consumes the arrow
            // keys internally, so Up/Down never bubble here — keyboard list
            // navigation can't be wired without replacing LineEdit with a
            // custom TextInput (which loses clipboard paste + cursor editing).
            // Enter (LineEdit.accepted) opens the top match; click any row to
            // open it directly. Escape bubbles up (LineEdit rejects it).
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.close-requested();
                    return accept;
                }
                // Layout-independent editing shortcuts (see text_ask.slint):
                // Slint keys Ctrl+A/C/V/X on the Latin a/c/v/x, so under a Cyrillic
                // layout the physical keys emit ф/с/м/ч and die. Call the LineEdit's
                // own functions; paste/cut fire `edited` above, so the search list
                // refreshes automatically. Keycode matches, not UI strings.
                if (event.modifiers.control && !event.modifiers.shift) {
                    if (event.text == "м" || event.text == "М") { search-input.paste(); return accept; }
                    if (event.text == "с" || event.text == "С") { search-input.copy(); return accept; }
                    if (event.text == "ч" || event.text == "Ч") { search-input.cut(); return accept; }
                    if (event.text == "ф" || event.text == "Ф") { search-input.select-all(); return accept; }
                }
                return reject;
            }

            VerticalLayout {
                padding: Metrics.space-md;   // was 12px
                spacing: Metrics.space-sm;   // was 8px

                // Input field
                search-input := LineEdit {
                    placeholder-text: @tr("type to search KB / snippets — /snip lists snippets, +key body adds one");
                    text <=> root.query;
                    // Reset the highlight to the top on every edit so the
                    // selection never points past a shorter result set.
                    edited(t) => { root.query-changed(t); root.selected-index = 0; }
                    // Enter spawns the highlighted result. Up/Down move the
                    // selection (handled by the ancestor FocusScope, since a
                    // single-line LineEdit lets those keys bubble).
                    accepted => {
                        if (root.results.length > 0) {
                            root.result-activated(root.selected-index);
                        }
                    }
                }

            // Recent chips row
            HorizontalLayout {
                spacing: Metrics.space-xs;   // was 4px
                if root.recent-chips.length > 0 : Text {
                    text: @tr("recent:");
                    font-size: Metrics.font-caption;   // was 10px
                    color: Theme.text-muted;
                    vertical-alignment: center;
                }
                for chip in root.recent-chips: Rectangle {
                    background: transparent;
                    border-color: Theme.border-strong;
                    border-width: Metrics.border-thin;   // was 1px
                    border-radius: Metrics.radius-control;   // was 10px
                    height: Metrics.control-sm;   // was 20px
                    horizontal-stretch: 0;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: chip;
                            font-size: Metrics.font-caption;   // was 10px
                            color: Theme.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea { clicked => { root.chip-clicked(chip); } }
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: @tr("Esc to close · Enter to spawn tile");
                    font-size: 9px;
                    color: Theme.text-muted;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                background: Theme.border;
                height: Metrics.border-thin;   // was 1px
            }

            // Results list
            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 2px;
                    if root.results.length == 0 : Text {
                        text: root.query == ""
                            ? @tr("Start typing to search the embedded knowledge base (1,696 entries)…")
                            : @tr("No results for \"{}\".", root.query);
                        font-size: Metrics.font-label;   // was 11px
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                    }
                    for result[i] in root.results: Rectangle {
                        background: i == root.selected-index ? Theme.bg-elevated : transparent;
                        border-radius: 4px;
                        border-color: i == root.selected-index ? Theme.accent : transparent;
                        border-width: Metrics.border-thin;   // was 1px
                        height: 44px;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: Metrics.space-md;   // was 12px

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 0px;
                                HorizontalLayout {
                                    spacing: Metrics.space-sm;   // was 8px
                                    Text {
                                        text: result.key;
                                        font-size: Metrics.font-body;   // was 12px
                                        font-weight: 700;
                                        color: i == root.selected-index ? Theme.accent : Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: result.source;
                                        font-size: 9px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: result.preview;
                                    font-size: Metrics.font-caption;   // was 10px
                                    color: Theme.text-muted;
                                    overflow: elide;
                                }
                            }
                        }
                        TouchArea {
                            clicked => { root.result-activated(i); }
                        }
                    }
                }
            }
            }
        }
    }
}
