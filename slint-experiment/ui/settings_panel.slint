// Settings window — custom dark tab bar + content area (the std TabWidget
// clashes with our theme, and we want per-tab control of content rendering).
// The sidebar groups tabs into SESSION / AI / APP; `active-tab` indexes the
// content pane. Indices have gaps (5 + 8) where the Stats + Snippets panes
// were removed:
//
//   0  Stealth          (APP)     capture-affinity toggle
//   1  Coaching         (SESSION) post-meeting debrief toggle
//   2  Hotkeys          (APP)     read-only global-hotkey table
//   3  Interface        (APP)     language switcher → gettext
//   4  Updates          (APP)     in-app updater
//   6  Audio            (APP)     device dropdowns + level meter + test
//   7  Auto-tiles       (AI)      detector toggle + trigger-keyword editor
//   9  Knowledge base   (AI)      search + entry preview
//  10  Profile+context  (SESSION) multi-profile picker + context editor
//  11  AI bridge        (AI)      cloud/local selector + probe + cost cap
//  12  STT              (AI)      provider selector + GigaAM GPU + Whisper

import { Button, LineEdit, ScrollView, SpinBox, ComboBox, Slider, TextEdit, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";

// Phase E6 v40 — toggle SWITCH (borrowed from the Claude Design bundle:
// "SwitchRow вместо чекбоксов"). Was a custom square checkbox (v24, to
// dodge the std CheckBox's near-invisible unchecked label on Theme.bg-surface).
// Now renders a pill track + sliding knob — bigger hit-target, clearer
// on/off read. NAME kept as `DarkCheck` so all call sites + the
// `checked`/`toggled` API stay untouched (pure visual swap). Green
// (Theme.accent) = ON, neutral grey = OFF; font-independent (no glyphs).
component DarkCheck inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked: false;
    callback toggled(bool);
    height: 24px;
    horizontal-stretch: 1;
    HorizontalLayout {
        spacing: 9px;
        alignment: start;
        // Track + knob. Knob slides right & turns green when ON.
        Rectangle {
            width: 34px;
            height: 18px;
            y: (parent.height - self.height) / 2;
            border-radius: 9px;
            border-width: 1px;
            border-color: root.checked ? Theme.accent : Theme.border;
            background: root.checked ? Theme.accent.with-alpha(0.2) : #ffffff0f;
            animate background, border-color { duration: 140ms; }
            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                y: (parent.height - self.height) / 2;
                x: root.checked ? parent.width - self.width - 3px : 3px;
                background: root.checked ? Theme.accent : Theme.text-muted;
                animate x, background { duration: 140ms; }
            }
        }
        Text {
            text: root.text;
            font-size: 12px;
            color: Theme.text-primary;
            vertical-alignment: center;
        }
    }
    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// Phase E6 v39 — grouped sidebar, cherry-picked from the Claude Design
// bundle (claude.ai/design handoff). Borrows the STRUCTURE — section
// headers + an active left-accent bar — while keeping the app's cyan
// accent (Theme.accent, same as the bar grip) for visual continuity. Each
// NavItem maps to its EXISTING pane index, so the content panes and the
// Rust `tab-selected` wiring stay untouched (low-risk increment).
component NavGroupHeader inherits Rectangle {
    in property <string> label;
    height: 22px;
    HorizontalLayout {
        padding-left: 9px;
        padding-top: 8px;
        Text {
            text: root.label;
            font-size: 10px;
            font-weight: 700;
            color: Theme.text-muted;
            vertical-alignment: bottom;
        }
    }
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <int> tab-index;
    in property <bool> active: false;
    callback chosen(int);
    height: 26px;
    border-radius: 4px;
    background: root.active
        ? Theme.accent.with-alpha(0.13)
        : (ta.has-hover ? Theme.bg-elevated : transparent);
    animate background { duration: 120ms; }
    // active left-accent bar
    if root.active: Rectangle {
        x: 0px;
        y: 6px;
        width: 3px;
        height: parent.height - 12px;
        border-radius: 2px;
        background: Theme.accent;
    }
    HorizontalLayout {
        padding-left: 11px;
        Text {
            text: root.label;
            font-size: 12px;
            color: root.active ? Theme.accent : Theme.text-secondary;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
    ta := TouchArea {
        clicked => { root.chosen(root.tab-index); }
    }
}

export component SettingsWindow inherits Window {
    // Phase 4 — drive the std-widgets Palette (ComboBox/LineEdit/TextEdit/
    // Button/Slider/SpinBox) off our active scheme so they render dark like
    // the rest of the UI instead of Slint's light fluent default. Light Frost
    // (scheme 3) is the only light scheme; `changed` keeps widgets in sync
    // when the user flips schemes live in Settings -> Interface.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    title: @tr("overlay-mvp settings (Slint)");
    // Phase E6 v25 — frameless. User: "хедер, он нам разве нужен?".
    // Native title bar removed; drag via the "Settings" sidebar header
    // (drag-start-requested + drag-moved → win32 cursor-delta drag,
    // same mechanism as the overlay bar). Close via the existing
    // "X Close" button.
    icon: @image-url("../assets/icon.png");
    no-frame: true;
    preferred-width: 720px;
    // Phase E6 v39 — taller (480→560) to fit the grouped sidebar
    // (3 section headers + 13 items) borrowed from the design bundle
    // without clipping the bottom-pinned Close button.
    preferred-height: 560px;
    min-width: 480px;
    min-height: 320px;
    // Phase E6 v26 — transparent window so the inner rounded Rectangle's
    // corners composite over the desktop (DWM per-pixel alpha applied
    // via make_transparent_tile on show). User: "закруглить рамки".
    background: transparent;

    in-out property <int> active-tab: 0;
    // Persisted cross-window toggles (driven by overlay-host).
    in-out property <bool> always-on-top-toggle: true;
    in-out property <bool> stealth-toggle: false;

    // Phase E6 — token status display + edit. Status strings are
    // populated by overlay-host on open from cfg.read().ai_bearer
    // and cfg.read().groq_api_key (masked: "✓ set (48 chars)" or
    // "❌ unset"). The LineEdit accepts a fresh value; Save fires
    // the corresponding callback which writes to config.json.
    in-out property <string> ai-bearer-status: "(loading...)";
    in-out property <string> ai-bearer-input: "";
    in-out property <string> groq-api-key-status: "(loading...)";
    in-out property <string> groq-api-key-input: "";
    in-out property <string> ai-base-url-input: "";
    // Phase E10.1 — cloud model dropdown from GET {ai_base_url}/models.
    in-out property <[string]> ai-models: [];
    in-out property <int> ai-model-index: 0;
    // E9 — experimental prompt-caching toggle (default off).
    in-out property <bool> ai-prompt-cache: false;
    // Local AI provider (Phase 1): 0 = cloud bridge, 1 = local (Ollama/llama.cpp).
    in-out property <int> ai-provider-index: 0;
    // V4 — vision (screenshot · F8) channel, resolved separately from the text model.
    in-out property <int> vision-provider-index: 2; // 0=off 1=same 2=cloud 3=local
    in-out property <string> vision-base-url-input;
    in-out property <string> vision-bearer-input;
    in-out property <string> vision-model-input;
    in-out property <string> vision-local-base-url-input;
    in-out property <string> vision-local-bearer-input;
    in-out property <string> vision-local-model-input;
    in-out property <string> vision-test-result;
    callback vision-provider-changed(int);
    callback vision-base-url-save(string);
    callback vision-bearer-save(string);
    callback vision-model-save(string);
    callback vision-local-base-url-save(string);
    callback vision-local-bearer-save(string);
    callback vision-local-model-save(string);
    callback vision-test-clicked();
    in-out property <string> ai-local-base-url-input: "";
    // Phase E10.1 — model dropdown populated from GET {base_url}/models so the
    // user picks a loaded model instead of typing its id.
    in-out property <[string]> ai-local-models: [];
    in-out property <int> ai-local-model-index: 0;
    in-out property <bool> ai-local-vision: false;
    // E10 — local-model "thinking"/reasoning toggle. Off (default) sends
    // enable_thinking=false for faster answers; on lets the model reason.
    in-out property <bool> ai-local-thinking: false;
    in-out property <string> ai-local-test-result: "";
    in-out property <string> ai-local-bearer-input: "";
    // E10.4 — in-app local-AI installer: downloads llama.cpp/whisper.cpp + models,
    // launches the servers, then auto-configures. Progress + GPU/CPU shown live.
    in-out property <bool> local-ai-installing: false;
    in-out property <string> local-ai-status: "";
    in-out property <float> local-ai-progress: 0.0; // 0.0..1.0
    in-out property <string> local-ai-gpu: "";
    in-out property <bool> local-ai-on-gpu: false;
    callback install-local-ai-clicked();
    callback cancel-local-ai-clicked();

    // Phase E6 v20 — tile body opacity (50..100%). Slider on Stealth
    // tab; Rust writes to cfg.tile_body_opacity + applies to spawning
    // tiles. Cherry-picked from design bundle 2 (only this prop).
    in-out property <float> tile-body-opacity: 1.0;
    callback tile-body-opacity-changed(float);

    // Phase E6 v23 — real audio device list (populated by Rust from
    // audio::list_devices().inputs on Settings open). mic-test-result
    // shows the dBFS probe outcome. Replaces the mock device list.
    in-out property <[string]> mic-devices: ["(loading devices…)"];
    in-out property <int> mic-device-index: 0;
    in-out property <string> mic-test-result: "";
    callback mic-device-selected(string);
    callback mic-test-clicked();

    callback always-on-top-changed(bool);
    callback stealth-changed(bool);
    callback open-wizard-clicked();
    callback close-clicked();
    callback tab-selected(int);
    // Phase E6 v25 — frameless window drag (cursor-delta, wired in Rust).
    callback drag-start-requested();
    callback drag-moved();
    callback ai-bearer-save(string);
    callback groq-api-key-save(string);
    callback ai-base-url-save(string);
    callback ai-model-selected(string);
    callback ai-models-refresh();
    callback ai-prompt-cache-changed(bool);
    callback ai-provider-changed(int);
    callback ai-local-base-url-save(string);
    callback ai-local-bearer-save(string);
    callback ai-local-model-selected(string);
    callback ai-local-models-refresh();
    callback ai-local-vision-changed(bool);
    callback ai-local-thinking-changed(bool);
    callback ai-local-test-clicked();
    // Phase E6 v27 — connection test buttons (AI bridge + STT).
    in-out property <string> ai-bridge-test-result: "";
    in-out property <string> stt-test-result: "";
    // STT provider (Phase E10): 0=cloud Groq, 1=local GigaAM, 2=local whisper-server.
    in-out property <int> stt-provider-index: 0;
    in-out property <string> stt-gigaam-dir-input: "";
    // GigaAM GPU acceleration via the ONNX Runtime DirectML EP (default on).
    in-out property <bool> stt-gigaam-gpu: true;
    in-out property <string> stt-whisper-url-input: "";
    in-out property <string> stt-whisper-bearer-input: "";
    in-out property <string> stt-whisper-model-input: "";
    callback ai-bridge-test-clicked();
    callback stt-test-clicked();
    callback stt-provider-changed(int);
    callback stt-gigaam-dir-save(string);
    callback stt-gigaam-gpu-changed(bool);
    callback stt-whisper-url-save(string);
    callback stt-whisper-bearer-save(string);
    callback stt-whisper-model-save(string);
    // Phase E6 v28 — full-profile import/export (incl. API keys).
    in-out property <string> profile-io-result: "";
    callback export-profile-clicked();
    callback import-profile-clicked();
    // #125 — server-ONLY import (AI/STT servers; keeps local prefs).
    callback import-server-settings-clicked();
    // #131 — diagnostics / readiness panel. Config-readiness levels are pushed
    // from Rust (Config::readiness); "Проверить всё" layers live AI/STT pings.
    // level: -1 checking · 0 ok · 2 not-configured · 3 info · 4 live-error.
    in-out property <string> diag-summary: "";
    in-out property <int> diag-ai-level: 0;
    in-out property <string> diag-ai-detail: "";
    in-out property <int> diag-stt-level: 0;
    in-out property <string> diag-stt-detail: "";
    in-out property <int> diag-mic-level: 3;
    in-out property <string> diag-mic-detail: "";
    in-out property <int> diag-sys-level: 3;
    in-out property <string> diag-sys-detail: "";
    in-out property <bool> diag-stealth-on: false;
    callback diagnostics-check-all-clicked();
    // Phase E6 v29 — meeting-context editor (Profile+context tab).
    in-out property <string> meeting-context-input: "";
    in-out property <string> meeting-context-result: "";
    callback meeting-context-save(string);
    // Phase F — multi-profile picker: named context presets. The active
    // profile's context mirrors meeting-context-input.
    in-out property <[string]> profile-names: [];
    in-out property <int> active-profile-index: -1;
    in-out property <string> profile-name-input: "";
    callback profile-selected(int);
    callback profile-add(string);
    callback profile-rename(string);
    callback profile-delete();
    // Phase F — Coaching + Auto-tiles controls (were dead/cosmetic: no binding).
    in-out property <bool> coaching-debrief: false;
    callback coaching-debrief-changed(bool);
    in-out property <bool> auto-tiles-enabled: true;
    callback auto-tiles-enabled-changed(bool);
    in-out property <string> trigger-keywords-input: "";
    callback trigger-keywords-save(string);
    // Phase E6 v43 — "Structure via AI" button: sends the current context
    // text to the AI with a profile-structuring prompt; Rust replaces the
    // field with the cleaned result. context-processing dims the button
    // while the AI call is in flight.
    in-out property <bool> context-processing: false;
    callback context-process-clicked();
    // Phase E6 v43 — voice dictation INTO the context field: click to
    // start recording the mic, click again to stop; Rust transcribes
    // (Groq) and appends the text to the editor. context-dictating drives
    // the red "stop" state.
    in-out property <bool> context-dictating: false;
    callback context-dictate-clicked();

    // Phase E6 v38 — interface-language selector. ui-language-index
    // reflects the saved config (0=Русский, 1=English); language-selected
    // fires when the ComboBox changes so Rust can switch the bundled
    // translation live AND persist it.
    in-out property <int> ui-language-index: 0;
    callback language-selected(int);

    // Colour-scheme selector (Interface tab). color-scheme-index reflects
    // the saved config (0=Glacier / 1=Graphite / 2=Obsidian / 3=Light Frost);
    // color-scheme-selected fires on change so Rust can switch Theme.scheme
    // live across every window AND persist it.
    in-out property <int> color-scheme-index: 0;
    callback color-scheme-selected(int);

    // Phase E8 — in-app auto-update (Updates tab). Rust sets app-version
    // from CARGO_PKG_VERSION on open; check-updates-clicked queries GitHub
    // and fills update-status / update-available; install-update-clicked
    // downloads + runs the installer (then the app quits).
    in-out property <string> app-version: "0.0.0";
    in-out property <string> update-status: "";
    in-out property <bool> update-available: false;
    in-out property <bool> update-checking: false;
    // Download URL of the found installer (set by Rust after a successful
    // check; read back by the install handler). Hidden plumbing.
    in-out property <string> update-download-url: "";
    callback check-updates-clicked();
    callback install-update-clicked();

    // Phase E6 v26 — rounded root. clip:true so the square-cornered
    // sidebar + content get masked to the 12px radius. Border + bg
    // moved here from the Window (which is now transparent).
    Rectangle {
        background: Theme.bg-surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;

        HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ----- Sidebar tab list -----
        Rectangle {
            width: 200px;
            background: Theme.bg-base;
            border-color: Theme.border;
            border-width: 0px;

            VerticalLayout {
                padding: 8px;
                spacing: 2px;

                // "Settings" header doubles as the window drag handle
                // (frameless — no native title bar). Phase E6 v25.
                Rectangle {
                    height: 26px;
                    horizontal-stretch: 1;
                    drag-handle := TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => { if (self.pressed) { root.drag-moved(); } }
                    }
                    // Phase E6 v26 — ":: " grip in accent Theme.accent (same as
                    // overlay bar) for visual continuity; label neutral.
                    // App icon sits first as branding (also in taskbar/Start).
                    HorizontalLayout {
                        spacing: 7px;
                        alignment: start;
                        Image {
                            source: @image-url("../assets/icon.svg");
                            colorize: Theme.accent;
                            width: 22px;
                            height: 22px;
                            image-fit: contain;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "::";
                            font-size: 14px;
                            font-weight: 700;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                        Text {
                            text: @tr("Settings");
                            font-size: 14px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { background: Theme.border; height: 1px; }

                // Phase E6 v39 — grouped nav (borrowed from design bundle).
                // Each item keeps its ORIGINAL pane index (0-12) so the
                // content panes + tab-selected wiring are untouched; only
                // the visual order + section grouping changes. Labels
                // reuse the existing emoji+text @tr msgids verbatim.
                NavGroupHeader { label: @tr("SESSION"); }
                NavItem {
                    label: @tr("👤 Profile + context"); tab-index: 10;
                    active: root.active-tab == 10;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🎯 Coaching"); tab-index: 1;
                    active: root.active-tab == 1;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: "AI"; }
                NavItem {
                    label: @tr("🧠 AI bridge"); tab-index: 11;
                    active: root.active-tab == 11;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🗣 STT"); tab-index: 12;
                    active: root.active-tab == 12;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🪟 Auto-tiles"); tab-index: 7;
                    active: root.active-tab == 7;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("📚 Knowledge base"); tab-index: 9;
                    active: root.active-tab == 9;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: @tr("APP"); }
                NavItem {
                    label: @tr("🎤 Audio"); tab-index: 6;
                    active: root.active-tab == 6;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🌐 Interface"); tab-index: 3;
                    active: root.active-tab == 3;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("⌨ Hotkeys"); tab-index: 2;
                    active: root.active-tab == 2;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🛡 Stealth"); tab-index: 0;
                    active: root.active-tab == 0;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("⬆ Updates"); tab-index: 4;
                    active: root.active-tab == 4;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🩺 Diagnostics"); tab-index: 13;
                    active: root.active-tab == 13;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                Rectangle { vertical-stretch: 1; }
                Button {
                    // ASCII X — Unicode ✕ U+2715 renders as missing-glyph
                    // box on Slint+skia font fallback (same fix as quit
                    // chip cycle 15, tile X cycle 11).
                    text: @tr("X  Close");
                    clicked => { root.close-clicked(); }
                }
            }
        }

        // ----- Content area -----
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-surface;
            clip: true;
            // Brand watermark — faint vector logo behind the content,
            // centred in the content pane (the pane bg is opaque, so the
            // mark must live INSIDE it, before the ScrollView). colorize
            // adapts it to dark *and* light schemes. User: бренд на
            // заднем плане меню.
            Image {
                source: @image-url("../assets/icon.svg");
                // Dark themes → tint the mark WHITE; light theme → keep it dark
                // (text-primary). Low opacity (5%) so it never muddies the text
                // contrast, esp. on screen-share. (User: тёмная тема — знак
                // светлый + прозрачность 4–6%; 12% было слишком много.)
                colorize: Theme.is-light ? Theme.text-primary : #ffffff;
                opacity: 0.05;
                width: 360px;
                height: 360px;
                image-fit: contain;
            }
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    // Header
                    Text {
                        text: tab-name-for(root.active-tab);
                        font-size: 18px;
                        font-weight: 700;
                        color: Theme.text-primary;
                    }
                    Rectangle { background: Theme.border; height: 1px; }

                    // Tab content
                    if root.active-tab == 0 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Stealth mode hides the overlay window from screen capture (Print Screen, Teams/Meet, OBS). Uses WDA_EXCLUDEFROMCAPTURE on Windows 10/11.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        DarkCheck {
                            text: @tr("Always on top (HWND_TOPMOST)");
                            checked <=> root.always-on-top-toggle;
                            toggled(v) => { root.always-on-top-changed(v); }
                        }
                        DarkCheck {
                            text: @tr("Stealth (hide from screen capture)");
                            checked <=> root.stealth-toggle;
                            toggled(v) => { root.stealth-changed(v); }
                        }
                        Rectangle { height: 12px; }
                        // Phase E6 v20 — tile opacity slider.
                        Text {
                            text: @tr("Tile opacity ({}%)", Math.round(root.tile-body-opacity * 100));
                            font-size: 11px;
                            color: Theme.text-secondary;
                        }
                        Text {
                            text: @tr("Lower values let you see the meeting through tiles. 100% = opaque, 50% = half-transparent.");
                            font-size: 10px;
                            // Phase E6 v23 — was Theme.text-muted (too dark, "чёрный на
                            // чёрном"); bumped to Theme.text-muted to match other
                            // description text in the panel.
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Slider {
                            minimum: 0.5;
                            maximum: 1.0;
                            value <=> root.tile-body-opacity;
                            changed(v) => { root.tile-body-opacity-changed(v); }
                        }
                    }
                    if root.active-tab == 1 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Post-meeting debrief: AI critique of pacing, filler density, key points. Opt-in.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        DarkCheck {
                            text: @tr("Enable post-meeting debrief");
                            checked <=> root.coaching-debrief;
                            toggled(v) => {
                                root.coaching-debrief-changed(v);
                            }
                        }
                    }
                    if root.active-tab == 2 : VerticalLayout {
                        spacing: 4px;
                        // Read-only list of the registered global hotkeys (see the
                        // GlobalHotKeyManager registrations in overlay_host.rs).
                        Text {
                            text: @tr("Global hotkeys (work anywhere, even when the app isn't focused):");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Rectangle { background: Theme.border; height: 1px; }
                        for entry in [
                            ["F9",  @tr("Ask AI now (streams the answer into a tile)")],
                            ["Shift+F9", @tr("Ask AI escalated to the smart cloud model (one-shot; tile shows a 🧠 badge)")],
                            ["F8",  @tr("Screenshot → AI vision (drag a region; Esc cancels)")],
                            ["F3",  @tr("Re-ask the last question with fresh context")],
                            ["F4",  @tr("Knowledge-base palette (open / close)")],
                            ["F6",  @tr("Manual tile from the last transcript line")],
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 12px;
                            Text {
                                text: entry[0];
                                font-size: 11px;
                                font-weight: 700;
                                color: Theme.accent;
                                width: 72px;
                            }
                            Text {
                                text: entry[1];
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                    }
                    if root.active-tab == 13 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Session readiness");
                            font-size: 13px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        Text {
                            text: root.diag-summary;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                        }
                        Rectangle { background: Theme.border; height: 1px; }
                        for row in [
                            { label: @tr("AI (answers)"), level: root.diag-ai-level, detail: root.diag-ai-detail },
                            { label: @tr("Speech recognition (STT)"), level: root.diag-stt-level, detail: root.diag-stt-detail },
                            { label: @tr("Microphone"), level: root.diag-mic-level, detail: root.diag-mic-detail == "" ? @tr("default") : root.diag-mic-detail },
                            { label: @tr("System audio"), level: root.diag-sys-level, detail: root.diag-sys-detail == "" ? @tr("default") : root.diag-sys-detail },
                            { label: @tr("Stealth"), level: 3, detail: root.diag-stealth-on ? @tr("on — verify with a screen-share preview") : @tr("off") },
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 10px;
                            Text {
                                text: row.label;
                                font-size: 11px;
                                font-weight: 600;
                                color: Theme.text-primary;
                                width: 150px;
                            }
                            Text {
                                text: row.level == 0 ? @tr("Ready")
                                    : row.level == -1 ? @tr("checking…")
                                    : row.level == 1 ? @tr("No signal")
                                    : row.level == 2 ? @tr("Not configured")
                                    : row.level == 4 ? @tr("Error")
                                    : "—";
                                font-size: 11px;
                                font-weight: 700;
                                width: 100px;
                                color: row.level == 0 ? Theme.success
                                    : row.level == 1 ? Theme.warning
                                    : (row.level == 2 || row.level == 4) ? Theme.danger
                                    : Theme.text-muted;
                            }
                            Text {
                                text: row.detail;
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                        }
                        Rectangle { height: 4px; }
                        HorizontalLayout {
                            alignment: start;
                            Button {
                                text: @tr("Check all");
                                clicked => { root.diagnostics-check-all-clicked(); }
                            }
                        }
                        Text {
                            text: @tr("“Check all” pings AI + STT, records the mic, and plays a test tone to verify system-audio capture. Speak during the check to see the mic level — you don't need to play anything yourself.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 3 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Interface language — switches all UI text on the fly.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Language:");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                // Language names are themselves untranslated identifiers
                                // (each appears in its own language as a self-label).
                                model: ["Русский", "English"];
                                // Phase E6 v38 — reflect the actual saved
                                // language (0=ru, 1=en) and fire a callback
                                // on change. Previously hardcoded index 0
                                // with no handler → the dropdown looked set
                                // to Russian but switching did nothing.
                                current-index: root.ui-language-index;
                                selected => {
                                    root.language-selected(self.current-index);
                                }
                            }
                        }
                        // Colour-scheme picker — switches the design tokens
                        // (theme.slint) live across every window. Fixes the
                        // recurring dark-on-dark complaints by letting the user
                        // pick the contrast they like.
                        Text {
                            text: @tr("Colour scheme — recolours the whole app instantly.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Scheme:");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                // Self-labelled scheme names (proper nouns —
                                // left untranslated so they read the same in
                                // both languages).
                                model: ["Glacier", "Graphite", "Obsidian", "Light Frost"];
                                current-index: root.color-scheme-index;
                                selected => {
                                    root.color-scheme-selected(self.current-index);
                                }
                            }
                        }
                        // First-run setup wizard — relaunchable any time.
                        Text {
                            text: @tr("Re-run the guided first-time setup.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            alignment: start;
                            Button {
                                text: @tr("🪄 Run setup wizard");
                                clicked => { root.open-wizard-clicked(); }
                            }
                        }
                    }
                    if root.active-tab == 4 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Check GitHub for a newer release. If one is found you can download + install it in one click (the app restarts).");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: root.update-checking
                                    ? @tr("Checking…")
                                    : @tr("Check for updates");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.check-updates-clicked();
                                }
                            }
                            // Shown only when a newer release was found.
                            if root.update-available : Button {
                                text: @tr("⬇ Update now");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.install-update-clicked();
                                }
                            }
                        }
                        // Result line: "up to date" / "vX available" / errors.
                        if root.update-status != "" : Text {
                            text: root.update-status;
                            font-size: 11px;
                            color: root.update-available ? Theme.success : Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Text {
                            text: @tr("Version: {} (suflyor / Slint)", root.app-version);
                            font-size: 10px;
                            color: Theme.text-muted;
                        }

                        Rectangle { background: Theme.border; height: 1px; }

                        // Phase E6 v28 — full-profile import/export.
                        Text {
                            text: @tr("Backup / transfer settings");
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        Text {
                            text: @tr("Exports the WHOLE config to a .json file you choose — INCLUDING the Claude bearer + Groq API key. Keep the file private. Import overwrites current settings (restart to apply).");
                            font-size: 10px;
                            color: Theme.warning;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Export settings (incl. keys)…");
                                clicked => { root.export-profile-clicked(); }
                            }
                            Button {
                                text: @tr("Import settings…");
                                clicked => { root.import-profile-clicked(); }
                            }
                        }
                        // #125 — server-only transfer: copies just AI/STT
                        // servers, keeps local profiles/devices/UI/snippets.
                        Text {
                            text: @tr("Server import copies ONLY AI/STT providers, URLs, models and keys — local UI, profiles, devices and snippets stay unchanged. Use it to carry your server setup to another PC.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            alignment: start;
                            Button {
                                text: @tr("Import server settings…");
                                clicked => { root.import-server-settings-clicked(); }
                            }
                        }
                        if root.profile-io-result != "" : Text {
                            text: root.profile-io-result;
                            font-size: 11px;
                            color: Theme.accent;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 6 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Microphone device selection. List is live from WASAPI capture endpoints.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Phase E6 v23 — real device list from
                        // audio::list_devices().inputs, wired by Rust.
                        ComboBox {
                            model: root.mic-devices;
                            current-index <=> root.mic-device-index;
                            selected(val) => { root.mic-device-selected(val); }
                        }
                        Button {
                            text: @tr("Test microphone (3s record)");
                            clicked => { root.mic-test-clicked(); }
                        }
                        if root.mic-test-result != "" : Text {
                            text: root.mic-test-result;
                            font-size: 11px;
                            color: Theme.accent;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 7 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Auto-tile triggers — when transcript contains these keywords, spawn an answer tile automatically.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        DarkCheck {
                            text: @tr("Enable auto-tile detector");
                            checked <=> root.auto-tiles-enabled;
                            toggled(v) => {
                                root.auto-tiles-enabled-changed(v);
                            }
                        }
                        Text {
                            text: @tr("Trigger keywords (space-separated). A sentence ending in '?' also triggers.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        TextEdit {
                            text <=> root.trigger-keywords-input;
                            wrap: word-wrap;
                            height: 150px;
                        }
                        Button {
                            text: @tr("Save keywords");
                            clicked => {
                                root.trigger-keywords-save(root.trigger-keywords-input);
                            }
                        }
                    }
                    if root.active-tab == 9 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Embedded knowledge base — 1,696 entries (glossary / commands / patterns), compiled into the binary.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Phase E6 v29 — the in-Settings search box was a
                        // dead stub. KB search lives in the F4 palette
                        // (fully wired). Point the user there instead of
                        // shipping a non-functional second search box.
                        Text {
                            text: @tr("Press F4 anywhere to search the knowledge base and spawn a tile from any entry.");
                            font-size: 11px;
                            color: Theme.accent;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 10 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Persistent context sent with every AI request — your role, focus areas, vocabulary. Saved to config; applied to new AI calls immediately.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Phase F — multi-profile picker. Row 1: select; row 2:
                        // add/rename/delete (split rows so the buttons never clip).
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Text {
                                text: @tr("Profile:");
                                font-size: 12px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            if root.profile-names.length > 0 : ComboBox {
                                model: root.profile-names;
                                current-index: root.active-profile-index;
                                min-width: 170px;
                                selected => {
                                    root.active-profile-index = self.current-index;
                                    root.profile-selected(self.current-index);
                                }
                            }
                            if root.profile-names.length == 0 : Text {
                                text: @tr("none yet — name one and Add");
                                font-size: 11px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                placeholder-text: @tr("profile name");
                                text <=> root.profile-name-input;
                                horizontal-stretch: 1;
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Button {
                                text: @tr("Add profile");
                                clicked => {
                                    root.profile-add(root.profile-name-input);
                                    root.profile-name-input = "";
                                }
                            }
                            Button {
                                text: @tr("Rename");
                                enabled: root.active-profile-index >= 0 && root.profile-name-input != "";
                                clicked => {
                                    root.profile-rename(root.profile-name-input);
                                    root.profile-name-input = "";
                                }
                            }
                            Button {
                                text: @tr("Delete");
                                enabled: root.active-profile-index >= 0;
                                clicked => {
                                    root.profile-delete();
                                }
                            }
                        }
                        // Phase E6 v29 — real multi-line editor wired to
                        // cfg.meeting_context (was a dead placeholder box).
                        TextEdit {
                            text <=> root.meeting-context-input;
                            wrap: word-wrap;
                            height: 220px;
                            placeholder-text: @tr("e.g. I'm a Senior SRE interviewing for a platform role. Answer concisely, prefer Kubernetes/AWS examples, Russian output.");
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            // Phase E6 v43 — voice dictation toggle.
                            Button {
                                text: root.context-dictating
                                    ? @tr("🔴 Stop recording")
                                    : @tr("🎤 Dictate");
                                clicked => { root.context-dictate-clicked(); }
                            }
                            Button {
                                text: @tr("Save context");
                                clicked => { root.meeting-context-save(root.meeting-context-input); }
                            }
                            // Phase E6 v43 — structure the context via AI.
                            Button {
                                text: root.context-processing
                                    ? @tr("Structuring…")
                                    : @tr("✨ Structure via AI");
                                enabled: !root.context-processing;
                                clicked => { root.context-process-clicked(); }
                            }
                            if root.meeting-context-result != "" : Text {
                                text: root.meeting-context-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if root.active-tab == 11 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Where do live answers come from? Pick a type, then configure it.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // ===== TYPE selector — gates everything below =====
                        ComboBox {
                            model: [@tr("Cloud (Claude bridge)"), @tr("Local (llama.cpp / Ollama)")];
                            current-index: root.ai-provider-index;
                            selected => {
                                root.ai-provider-index = self.current-index;
                                root.ai-provider-changed(self.current-index);
                            }
                        }
                        Rectangle { background: Theme.border; height: 1px; }

                        // ============================ CLOUD ============================
                        if root.ai-provider-index == 0 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Cloud bridge");
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.text-primary;
                            }
                            Text {
                                text: @tr("Bearer token:") + " " + root.ai-bearer-status;
                                font-size: 11px;
                                color: Theme.text-secondary;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("paste new bearer token then Save");
                                    text <=> root.ai-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-bearer-save(root.ai-bearer-input);
                                        root.ai-bearer-input = "";
                                    }
                                }
                            }
                            Text {
                                text: @tr("Base URL (Claude bridge endpoint):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("http://your.bridge.host:PORT/v1");
                                    text <=> root.ai-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-base-url-save(root.ai-base-url-input);
                                    }
                                }
                            }
                            Text {
                                text: @tr("AI model (Claude full ID):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ComboBox {
                                    model: root.ai-models;
                                    current-index: root.ai-model-index;
                                    horizontal-stretch: 1;
                                    selected => {
                                        root.ai-model-selected(self.current-value);
                                    }
                                }
                                Button {
                                    text: @tr("refresh");
                                    clicked => {
                                        root.ai-models-refresh();
                                    }
                                }
                            }
                            if root.ai-models.length == 0 : Text {
                                text: @tr("No models found — check the bridge URL/token, then press refresh.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: @tr("Test AI bridge connection");
                                    clicked => { root.ai-bridge-test-clicked(); }
                                }
                                if root.ai-bridge-test-result != "" : Text {
                                    text: root.ai-bridge-test-result;
                                    font-size: 11px;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }
                            }
                            DarkCheck {
                                text: @tr("Prompt-caching (experimental — needs bridge support)");
                                checked <=> root.ai-prompt-cache;
                                toggled(v) => { root.ai-prompt-cache-changed(v); }
                            }
                            Text {
                                text: @tr("Marks the system prompt as cacheable for faster repeat asks. If your bridge rejects it (AI stops answering), turn this back off.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                        }

                        // ============================ LOCAL ============================
                        if root.ai-provider-index == 1 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Local model");
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.text-primary;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("local URL — http://127.0.0.1:8080/v1 (llama.cpp) or :11434 (Ollama)");
                                    text <=> root.ai-local-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-local-base-url-save(root.ai-local-base-url-input);
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ComboBox {
                                    model: root.ai-local-models;
                                    current-index: root.ai-local-model-index;
                                    horizontal-stretch: 1;
                                    selected => {
                                        root.ai-local-model-selected(self.current-value);
                                    }
                                }
                                Button {
                                    text: @tr("refresh");
                                    clicked => {
                                        root.ai-local-models-refresh();
                                    }
                                }
                            }
                            if root.ai-local-models.length == 0 : Text {
                                text: @tr("No models found — start the local server, then press refresh.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("local server bearer token (optional)");
                                    text <=> root.ai-local-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-local-bearer-save(root.ai-local-bearer-input);
                                        root.ai-local-bearer-input = "";
                                    }
                                }
                            }
                            DarkCheck {
                                text: @tr("Local model supports images (vision)");
                                checked <=> root.ai-local-vision;
                                toggled(v) => {
                                    root.ai-local-vision-changed(v);
                                }
                            }
                            DarkCheck {
                                text: @tr("Local model reasoning/thinking (slower, off = faster)");
                                checked <=> root.ai-local-thinking;
                                toggled(v) => {
                                    root.ai-local-thinking-changed(v);
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: @tr("Test local connection");
                                    clicked => {
                                        root.ai-local-test-clicked();
                                    }
                                }
                                if root.ai-local-test-result != "" : Text {
                                    text: root.ai-local-test-result;
                                    font-size: 11px;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }
                            }
                            // ----- one-click in-app local-AI installer -----
                            Rectangle { background: Theme.border; height: 1px; }
                            Text {
                                text: @tr("Installs the local stack on this PC (~6 GB total): llama.cpp + Gemma-4-E4B (~5 GB; needs ~6 GB VRAM on GPU), whisper.cpp + Whisper-turbo (~0.9 GB), GigaAM-v3 (~0.2 GB). With NVIDIA it picks the CUDA build, otherwise CPU. Models you already have are reused, not re-downloaded.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: root.local-ai-installing ? @tr("Installing…") : @tr("Install local AI");
                                    enabled: !root.local-ai-installing;
                                    clicked => {
                                        root.install-local-ai-clicked();
                                    }
                                }
                                if root.local-ai-installing : Button {
                                    text: @tr("Cancel");
                                    clicked => {
                                        root.cancel-local-ai-clicked();
                                    }
                                }
                                if root.local-ai-gpu != "" : Text {
                                    text: root.local-ai-gpu;
                                    font-size: 11px;
                                    color: root.local-ai-on-gpu ? Theme.success : Theme.warning;
                                    vertical-alignment: center;
                                }
                            }
                            if root.local-ai-status != "" : Text {
                                text: root.local-ai-status;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                            if root.local-ai-installing : Rectangle {
                                height: 6px;
                                border-radius: 3px;
                                background: Theme.border;
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    height: parent.height;
                                    width: parent.width * root.local-ai-progress;
                                    border-radius: 3px;
                                    background: Theme.accent;
                                }
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }
                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\overlay-mvp\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }

                        // ===================== VISION (screenshots · F8) =====================
                        Rectangle { background: Theme.border; height: 2px; }
                        Text {
                            text: @tr("Vision (screenshots · F8)");
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        Text {
                            text: @tr("Where F8 screenshots are analysed. SEPARATE from the text model above — a local text model can keep answering while images go to a vision-capable model.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Off"), @tr("Same as text model above"), @tr("Cloud (Sonnet via bridge)"), @tr("Local (2nd vision server)")];
                            current-index: root.vision-provider-index;
                            selected => {
                                root.vision-provider-index = self.current-index;
                                root.vision-provider-changed(self.current-index);
                            }
                        }
                        if root.vision-provider-index == 2 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Screenshots are sent to the cloud. Leave a field blank to reuse the text bridge's value.");
                                font-size: 10px;
                                color: Theme.warning;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision base URL (blank = text bridge)");
                                    text <=> root.vision-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-base-url-save(root.vision-base-url-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision bearer (blank = text bridge)");
                                    text <=> root.vision-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-bearer-save(root.vision-bearer-input); root.vision-bearer-input = ""; } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision model (blank = claude-sonnet-4-6)");
                                    text <=> root.vision-model-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-model-save(root.vision-model-input); } }
                            }
                        }
                        if root.vision-provider-index == 3 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("A 2nd local OpenAI-compatible server running a vision model (e.g. Qwen2-VL). Blank = reuse the text-local server.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local URL — http://127.0.0.1:8082/v1");
                                    text <=> root.vision-local-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-base-url-save(root.vision-local-base-url-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local model id");
                                    text <=> root.vision-local-model-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-model-save(root.vision-local-model-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local bearer (optional)");
                                    text <=> root.vision-local-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-bearer-save(root.vision-local-bearer-input); root.vision-local-bearer-input = ""; } }
                            }
                        }
                        if root.vision-provider-index >= 2 : HorizontalLayout {
                            spacing: 6px;
                            Button { text: @tr("Test vision connection"); clicked => { root.vision-test-clicked(); } }
                            if root.vision-test-result != "" : Text {
                                text: root.vision-test-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if root.active-tab == 12 : VerticalLayout {
                        spacing: 8px;

                        // ===== STT engine (Phase E10) =====
                        Text {
                            text: @tr("Speech-to-text engine. Local options run on this PC (no cloud, no Groq key needed).");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Cloud (Groq Whisper)"), @tr("Local GigaAM-v3 (Russian)"), @tr("Local Whisper (whisper.cpp)")];
                            current-index: root.stt-provider-index;
                            selected => {
                                // Write the index back so the conditional engine
                                // fields (GigaAM dir / whisper-server URL) render
                                // immediately on selection instead of only after
                                // re-opening Settings.
                                root.stt-provider-index = self.current-index;
                                root.stt-provider-changed(self.current-index);
                            }
                        }
                        if root.stt-provider-index == 1 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("GigaAM model dir — folder with model.int8.onnx + vocab.txt");
                                text <=> root.stt-gigaam-dir-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-gigaam-dir-save(root.stt-gigaam-dir-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 1 : DarkCheck {
                            text: @tr("Use GPU (DirectML) — faster on long audio, ~1s warm-up on first use");
                            checked <=> root.stt-gigaam-gpu;
                            toggled(v) => {
                                root.stt-gigaam-gpu-changed(v);
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server URL — http://127.0.0.1:8081/v1");
                                text <=> root.stt-whisper-url-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-url-save(root.stt-whisper-url-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server bearer token (optional)");
                                input-type: password;
                                text <=> root.stt-whisper-bearer-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-bearer-save(root.stt-whisper-bearer-input);
                                    // Clear the secret from the field after Save
                                    // (matches ai-bearer / groq / local-bearer).
                                    root.stt-whisper-bearer-input = "";
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper model — e.g. whisper-large-v3-turbo");
                                text <=> root.stt-whisper-model-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-model-save(root.stt-whisper-model-input);
                                }
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }

                        Text {
                            text: @tr("Groq STT (Whisper) — API key + model. Used only when the engine above is Cloud.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }

                        // ----- groq_api_key -----
                        Text {
                            text: @tr("Groq API key:") + " " + root.groq-api-key-status;
                            font-size: 11px;
                            color: Theme.text-secondary;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("paste new Groq key then Save");
                                text <=> root.groq-api-key-input;
                                input-type: password;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.groq-api-key-save(root.groq-api-key-input);
                                    root.groq-api-key-input = "";
                                }
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }

                        // ----- Connection test (Phase E6 v27) -----
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Test STT connection");
                                clicked => { root.stt-test-clicked(); }
                            }
                            if root.stt-test-result != "" : Text {
                                text: root.stt-test-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\overlay-mvp\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                    }

                    // Phase E6 v18 — push tab content to TOP of viewport.
                    // Without this, ScrollView lets the VerticalLayout
                    // stretch to fill height, leaving small tabs (Stealth,
                    // Coaching) with their content visually centered/
                    // bottomed instead of starting at the header.
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }
        } // HorizontalLayout
    } // rounded root Rectangle

    pure function tab-name-for(idx: int) -> string {
        return idx == 0 ? @tr("Stealth") :
               idx == 1 ? @tr("Coaching") :
               idx == 2 ? @tr("Hotkeys") :
               idx == 3 ? @tr("Interface") :
               idx == 4 ? @tr("Updates") :
               idx == 6 ? @tr("Audio") :
               idx == 7 ? @tr("Auto-tiles") :
               idx == 9 ? @tr("Knowledge base") :
               idx == 10 ? @tr("Profile + context") :
               idx == 11 ? @tr("AI bridge") :
               idx == 12 ? @tr("STT") :
               idx == 13 ? @tr("Diagnostics") :
               "—";
    }
}
