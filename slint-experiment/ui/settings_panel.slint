// Phase 2 — Tabbed Settings window.
//
// Custom tab bar + content area: TabWidget std-widget exists but its
// styling clashes with our dark theme, and we want fine-grained
// control of per-tab content rendering for the migration. Tabs are
// indexed 0-12, each a stub for the corresponding React Settings
// panel from the migration plan order:
//
//   0  Stealth          (single toggle — sanity check)
//   1  Coaching         (toggle + numeric input)
//   2  Hotkeys          (table view, no edits)
//   3  Interface        (language switcher → wires gettext)
//   4  Updates          (external URL + diagnostic dump)
//   5  Stats            (read-only dashboard with bars)
//   6  Audio            (device dropdown + level meter + test)
//   7  Auto-tiles       (toggle + chip cloud editor)
//   8  Snippets         (CRUD modal)
//   9  Knowledge base   (search + entry preview)
//  10  Profile+context  (multi-text-field with import/export)
//  11  AI bridge        (probe button + cost cap input)
//  12  STT              (model dropdown + Whisper prompt editor)
//
// Phase 2.x ports each tab one at a time from the React Settings
// panels. Day 2 stub (the original two cross-window toggles) now
// lives inside tab 0 (Stealth).

import { Button, LineEdit, ScrollView, SpinBox, ComboBox, Slider, TextEdit } from "std-widgets.slint";

// Phase E6 v40 — toggle SWITCH (borrowed from the Claude Design bundle:
// "SwitchRow вместо чекбоксов"). Was a custom square checkbox (v24, to
// dodge the std CheckBox's near-invisible unchecked label on #14161e).
// Now renders a pill track + sliding knob — bigger hit-target, clearer
// on/off read. NAME kept as `DarkCheck` so all call sites + the
// `checked`/`toggled` API stay untouched (pure visual swap). Green
// (#2ac760) = ON, neutral grey = OFF; font-independent (no glyphs).
component DarkCheck inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked: false;
    callback toggled(bool);
    height: 24px;
    horizontal-stretch: 1;
    HorizontalLayout {
        spacing: 9px;
        alignment: start;
        // Track + knob. Knob slides right & turns green when ON.
        Rectangle {
            width: 34px;
            height: 18px;
            y: (parent.height - self.height) / 2;
            border-radius: 9px;
            border-width: 1px;
            border-color: root.checked ? #2ac760 : #4a4c54;
            background: root.checked ? #2ac76033 : #ffffff0f;
            animate background, border-color { duration: 140ms; }
            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                y: (parent.height - self.height) / 2;
                x: root.checked ? parent.width - self.width - 3px : 3px;
                background: root.checked ? #2ac760 : #9a9ca4;
                animate x, background { duration: 140ms; }
            }
        }
        Text {
            text: root.text;
            font-size: 12px;
            color: #e8e8ec;
            vertical-alignment: center;
        }
    }
    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// Phase E6 v39 — grouped sidebar, cherry-picked from the Claude Design
// bundle (claude.ai/design handoff). Borrows the STRUCTURE — section
// headers + an active left-accent bar — while keeping the app's cyan
// accent (#6cf, same as the bar grip) for visual continuity. Each
// NavItem maps to its EXISTING pane index, so the content panes and the
// Rust `tab-selected` wiring stay untouched (low-risk increment).
component NavGroupHeader inherits Rectangle {
    in property <string> label;
    height: 22px;
    HorizontalLayout {
        padding-left: 9px;
        padding-top: 8px;
        Text {
            text: root.label;
            font-size: 10px;
            font-weight: 700;
            color: #6b6b76;
            vertical-alignment: bottom;
        }
    }
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <int> tab-index;
    in property <bool> active: false;
    callback chosen(int);
    height: 26px;
    border-radius: 4px;
    background: root.active
        ? #6cf.with-alpha(0.13)
        : (ta.has-hover ? #1f2230 : transparent);
    animate background { duration: 120ms; }
    // active left-accent bar
    if root.active: Rectangle {
        x: 0px;
        y: 6px;
        width: 3px;
        height: parent.height - 12px;
        border-radius: 2px;
        background: #6cf;
    }
    HorizontalLayout {
        padding-left: 11px;
        Text {
            text: root.label;
            font-size: 12px;
            color: root.active ? #6cf : #c8c8cc;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
    ta := TouchArea {
        clicked => { root.chosen(root.tab-index); }
    }
}

export component SettingsWindow inherits Window {
    title: @tr("overlay-mvp settings (Slint)");
    // Phase E6 v25 — frameless. User: "хедер, он нам разве нужен?".
    // Native title bar removed; drag via the "Settings" sidebar header
    // (drag-start-requested + drag-moved → win32 cursor-delta drag,
    // same mechanism as the overlay bar). Close via the existing
    // "X Close" button.
    no-frame: true;
    preferred-width: 720px;
    // Phase E6 v39 — taller (480→560) to fit the grouped sidebar
    // (3 section headers + 13 items) borrowed from the design bundle
    // without clipping the bottom-pinned Close button.
    preferred-height: 560px;
    min-width: 480px;
    min-height: 320px;
    // Phase E6 v26 — transparent window so the inner rounded Rectangle's
    // corners composite over the desktop (DWM per-pixel alpha applied
    // via make_transparent_tile on show). User: "закруглить рамки".
    background: transparent;

    in-out property <int> active-tab: 0;
    // Persisted cross-window toggles (driven by overlay-host).
    in-out property <bool> always-on-top-toggle: true;
    in-out property <bool> stealth-toggle: false;

    // Phase E6 — token status display + edit. Status strings are
    // populated by overlay-host on open from cfg.read().ai_bearer
    // and cfg.read().groq_api_key (masked: "✓ set (48 chars)" or
    // "❌ unset"). The LineEdit accepts a fresh value; Save fires
    // the corresponding callback which writes to config.json.
    in-out property <string> ai-bearer-status: "(loading...)";
    in-out property <string> ai-bearer-input: "";
    in-out property <string> groq-api-key-status: "(loading...)";
    in-out property <string> groq-api-key-input: "";
    in-out property <string> ai-base-url-input: "";
    // Phase E10.1 — cloud model dropdown from GET {ai_base_url}/models.
    in-out property <[string]> ai-models: [];
    in-out property <int> ai-model-index: 0;
    // E9 — experimental prompt-caching toggle (default off).
    in-out property <bool> ai-prompt-cache: false;
    // Local AI provider (Phase 1): 0 = cloud bridge, 1 = local (Ollama/llama.cpp).
    in-out property <int> ai-provider-index: 0;
    in-out property <string> ai-local-base-url-input: "";
    // Phase E10.1 — model dropdown populated from GET {base_url}/models so the
    // user picks a loaded model instead of typing its id.
    in-out property <[string]> ai-local-models: [];
    in-out property <int> ai-local-model-index: 0;
    in-out property <bool> ai-local-vision: false;
    // E10 — local-model "thinking"/reasoning toggle. Off (default) sends
    // enable_thinking=false for faster answers; on lets the model reason.
    in-out property <bool> ai-local-thinking: false;
    in-out property <string> ai-local-test-result: "";

    // Phase E6 v20 — tile body opacity (50..100%). Slider on Stealth
    // tab; Rust writes to cfg.tile_body_opacity + applies to spawning
    // tiles. Cherry-picked from design bundle 2 (only this prop).
    in-out property <float> tile-body-opacity: 1.0;
    callback tile-body-opacity-changed(float);

    // Phase E6 v23 — real audio device list (populated by Rust from
    // audio::list_devices().inputs on Settings open). mic-test-result
    // shows the dBFS probe outcome. Replaces the mock device list.
    in-out property <[string]> mic-devices: ["(loading devices…)"];
    in-out property <int> mic-device-index: 0;
    in-out property <string> mic-test-result: "";
    callback mic-device-selected(string);
    callback mic-test-clicked();

    callback always-on-top-changed(bool);
    callback stealth-changed(bool);
    callback close-clicked();
    callback tab-selected(int);
    // Phase E6 v25 — frameless window drag (cursor-delta, wired in Rust).
    callback drag-start-requested();
    callback drag-moved();
    callback ai-bearer-save(string);
    callback groq-api-key-save(string);
    callback ai-base-url-save(string);
    callback ai-model-selected(string);
    callback ai-models-refresh();
    callback ai-prompt-cache-changed(bool);
    callback ai-provider-changed(int);
    callback ai-local-base-url-save(string);
    callback ai-local-model-selected(string);
    callback ai-local-models-refresh();
    callback ai-local-vision-changed(bool);
    callback ai-local-thinking-changed(bool);
    callback ai-local-test-clicked();
    // Phase E6 v27 — connection test buttons (AI bridge + STT).
    in-out property <string> ai-bridge-test-result: "";
    in-out property <string> stt-test-result: "";
    // STT provider (Phase E10): 0=cloud Groq, 1=local GigaAM, 2=local whisper-server.
    in-out property <int> stt-provider-index: 0;
    in-out property <string> stt-gigaam-dir-input: "";
    in-out property <string> stt-whisper-url-input: "";
    in-out property <string> stt-whisper-bearer-input: "";
    in-out property <string> stt-whisper-model-input: "";
    callback ai-bridge-test-clicked();
    callback stt-test-clicked();
    callback stt-provider-changed(int);
    callback stt-gigaam-dir-save(string);
    callback stt-whisper-url-save(string);
    callback stt-whisper-bearer-save(string);
    callback stt-whisper-model-save(string);
    // Phase E6 v28 — full-profile import/export (incl. API keys).
    in-out property <string> profile-io-result: "";
    callback export-profile-clicked();
    callback import-profile-clicked();
    // Phase E6 v29 — meeting-context editor (Profile+context tab).
    in-out property <string> meeting-context-input: "";
    in-out property <string> meeting-context-result: "";
    callback meeting-context-save(string);
    // Phase E6 v43 — "Structure via AI" button: sends the current context
    // text to the AI with a profile-structuring prompt; Rust replaces the
    // field with the cleaned result. context-processing dims the button
    // while the AI call is in flight.
    in-out property <bool> context-processing: false;
    callback context-process-clicked();
    // Phase E6 v43 — voice dictation INTO the context field: click to
    // start recording the mic, click again to stop; Rust transcribes
    // (Groq) and appends the text to the editor. context-dictating drives
    // the red "stop" state.
    in-out property <bool> context-dictating: false;
    callback context-dictate-clicked();

    // Phase E6 v38 — interface-language selector. ui-language-index
    // reflects the saved config (0=Русский, 1=English); language-selected
    // fires when the ComboBox changes so Rust can switch the bundled
    // translation live AND persist it.
    in-out property <int> ui-language-index: 0;
    callback language-selected(int);

    // Phase E8 — in-app auto-update (Updates tab). Rust sets app-version
    // from CARGO_PKG_VERSION on open; check-updates-clicked queries GitHub
    // and fills update-status / update-available; install-update-clicked
    // downloads + runs the installer (then the app quits).
    in-out property <string> app-version: "0.0.0";
    in-out property <string> update-status: "";
    in-out property <bool> update-available: false;
    in-out property <bool> update-checking: false;
    // Download URL of the found installer (set by Rust after a successful
    // check; read back by the install handler). Hidden plumbing.
    in-out property <string> update-download-url: "";
    callback check-updates-clicked();
    callback install-update-clicked();

    // Phase E6 v26 — rounded root. clip:true so the square-cornered
    // sidebar + content get masked to the 12px radius. Border + bg
    // moved here from the Window (which is now transparent).
    Rectangle {
        background: #14161e;
        border-radius: 12px;
        border-width: 1px;
        border-color: #2a2c3a;
        clip: true;

        HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ----- Sidebar tab list -----
        Rectangle {
            width: 200px;
            background: #0d0f15;
            border-color: #2a2c3a;
            border-width: 0px;

            VerticalLayout {
                padding: 8px;
                spacing: 2px;

                // "Settings" header doubles as the window drag handle
                // (frameless — no native title bar). Phase E6 v25.
                Rectangle {
                    height: 26px;
                    horizontal-stretch: 1;
                    drag-handle := TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => { if (self.pressed) { root.drag-moved(); } }
                    }
                    // Phase E6 v26 — ":: " grip in accent #6cf (same as
                    // overlay bar) for visual continuity; label neutral.
                    HorizontalLayout {
                        spacing: 0px;
                        alignment: start;
                        Text {
                            text: "::";
                            font-size: 14px;
                            font-weight: 700;
                            color: #6cf;
                            vertical-alignment: center;
                        }
                        Text {
                            text: " " + @tr("Settings");
                            font-size: 14px;
                            font-weight: 700;
                            color: #e8e8ec;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { background: #2a2c3a; height: 1px; }

                // Phase E6 v39 — grouped nav (borrowed from design bundle).
                // Each item keeps its ORIGINAL pane index (0-12) so the
                // content panes + tab-selected wiring are untouched; only
                // the visual order + section grouping changes. Labels
                // reuse the existing emoji+text @tr msgids verbatim.
                NavGroupHeader { label: @tr("SESSION"); }
                NavItem {
                    label: @tr("👤 Profile + context"); tab-index: 10;
                    active: root.active-tab == 10;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🎤 Audio"); tab-index: 6;
                    active: root.active-tab == 6;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🗣 STT"); tab-index: 12;
                    active: root.active-tab == 12;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: "AI"; }
                NavItem {
                    label: @tr("🧠 AI bridge"); tab-index: 11;
                    active: root.active-tab == 11;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🪟 Auto-tiles"); tab-index: 7;
                    active: root.active-tab == 7;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("✂ Snippets"); tab-index: 8;
                    active: root.active-tab == 8;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("📚 Knowledge base"); tab-index: 9;
                    active: root.active-tab == 9;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🎯 Coaching"); tab-index: 1;
                    active: root.active-tab == 1;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: @tr("APP"); }
                NavItem {
                    label: @tr("🌐 Interface"); tab-index: 3;
                    active: root.active-tab == 3;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("⌨ Hotkeys"); tab-index: 2;
                    active: root.active-tab == 2;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("🎯 Stealth"); tab-index: 0;
                    active: root.active-tab == 0;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("📊 Stats"); tab-index: 5;
                    active: root.active-tab == 5;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("⬆ Updates"); tab-index: 4;
                    active: root.active-tab == 4;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                Rectangle { vertical-stretch: 1; }
                Button {
                    // ASCII X — Unicode ✕ U+2715 renders as missing-glyph
                    // box on Slint+skia font fallback (same fix as quit
                    // chip cycle 15, tile X cycle 11).
                    text: @tr("X  Close");
                    clicked => { root.close-clicked(); }
                }
            }
        }

        // ----- Content area -----
        Rectangle {
            horizontal-stretch: 1;
            background: #14161e;
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    // Header
                    Text {
                        text: tab-name-for(root.active-tab);
                        font-size: 18px;
                        font-weight: 700;
                        color: #e8e8ec;
                    }
                    Rectangle { background: #2a2c3a; height: 1px; }

                    // Tab content
                    if root.active-tab == 0 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Stealth mode hides the overlay window from screen capture (Print Screen, Teams/Meet, OBS). Uses WDA_EXCLUDEFROMCAPTURE on Windows 10/11.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        DarkCheck {
                            text: @tr("Always on top (HWND_TOPMOST)");
                            checked <=> root.always-on-top-toggle;
                            toggled(v) => { root.always-on-top-changed(v); }
                        }
                        DarkCheck {
                            text: @tr("Stealth (hide from screen capture)");
                            checked <=> root.stealth-toggle;
                            toggled(v) => { root.stealth-changed(v); }
                        }
                        Rectangle { height: 12px; }
                        // Phase E6 v20 — tile opacity slider.
                        Text {
                            text: @tr("Tile opacity ({}%)", Math.round(root.tile-body-opacity * 100));
                            font-size: 11px;
                            color: #c8c8cc;
                        }
                        Text {
                            text: @tr("Lower values let you see the meeting through tiles. 100% = opaque, 50% = half-transparent.");
                            font-size: 10px;
                            // Phase E6 v23 — was #777 (too dark, "чёрный на
                            // чёрном"); bumped to #999 to match other
                            // description text in the panel.
                            color: #999;
                            wrap: word-wrap;
                        }
                        Slider {
                            minimum: 0.5;
                            maximum: 1.0;
                            value <=> root.tile-body-opacity;
                            changed(v) => { root.tile-body-opacity-changed(v); }
                        }
                    }
                    if root.active-tab == 1 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Post-meeting debrief: AI critique of pacing, filler density, key points. Opt-in.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        DarkCheck { text: @tr("Enable post-meeting debrief"); }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Min session seconds:");
                                font-size: 11px;
                                color: #c8c8cc;
                                vertical-alignment: center;
                            }
                            SpinBox { minimum: 30; maximum: 3600; value: 60; }
                        }
                    }
                    if root.active-tab == 2 : VerticalLayout {
                        spacing: 4px;
                        // SCAFFOLDING: "wire to RegisterHotKey in Phase 2.3" — internal
                        // marker that Phase 2.3 will replace this stub with real config.
                        // Description still user-facing → wrap.
                        Text {
                            text: @tr("Global hotkeys (read-only — wire to RegisterHotKey in Phase 2.3):");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        Rectangle { background: #2a2c3a; height: 1px; }
                        for entry in [
                            ["F1",  @tr("Toggle hotkey-hint popover")],
                            ["F2",  @tr("Cycle context profile")],
                            ["F3",  @tr("Ask the AI now")],
                            ["F4",  @tr("Open KB palette")],
                            ["F7",  @tr("Bulk collapse/expand all tiles")],
                            ["F8",  @tr("Push-to-talk (hold)")],
                            ["F9",  @tr("Reload last tile")],
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 12px;
                            Text {
                                text: entry[0];
                                font-size: 11px;
                                font-weight: 700;
                                color: #6cf;
                                width: 40px;
                            }
                            Text {
                                text: entry[1];
                                font-size: 11px;
                                color: #c8c8cc;
                            }
                        }
                    }
                    if root.active-tab == 3 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Interface language. Wires gettext for all UI strings (Phase 6).");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Language:");
                                font-size: 11px;
                                color: #c8c8cc;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                // Language names are themselves untranslated identifiers
                                // (each appears in its own language as a self-label).
                                model: ["Русский", "English"];
                                // Phase E6 v38 — reflect the actual saved
                                // language (0=ru, 1=en) and fire a callback
                                // on change. Previously hardcoded index 0
                                // with no handler → the dropdown looked set
                                // to Russian but switching did nothing.
                                current-index: root.ui-language-index;
                                selected => {
                                    root.language-selected(self.current-index);
                                }
                            }
                        }
                    }
                    if root.active-tab == 4 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Check GitHub for a newer release. If one is found you can download + install it in one click (the app restarts).");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: root.update-checking
                                    ? @tr("Checking…")
                                    : @tr("Check for updates");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.check-updates-clicked();
                                }
                            }
                            // Shown only when a newer release was found.
                            if root.update-available : Button {
                                text: @tr("⬇ Update now");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.install-update-clicked();
                                }
                            }
                        }
                        // Result line: "up to date" / "vX available" / errors.
                        if root.update-status != "" : Text {
                            text: root.update-status;
                            font-size: 11px;
                            color: root.update-available ? #34d399 : #999;
                            wrap: word-wrap;
                        }
                        Text {
                            text: @tr("Version: {} (suflyor / Slint)", root.app-version);
                            font-size: 10px;
                            color: #666;
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // Phase E6 v28 — full-profile import/export.
                        Text {
                            text: @tr("Backup / transfer settings");
                            font-size: 12px;
                            font-weight: 700;
                            color: #e8e8ec;
                        }
                        Text {
                            text: @tr("Exports the WHOLE config to a .json file you choose — INCLUDING the Claude bearer + Groq API key. Keep the file private. Import overwrites current settings (restart to apply).");
                            font-size: 10px;
                            color: #e5b44b;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Export settings (incl. keys)…");
                                clicked => { root.export-profile-clicked(); }
                            }
                            Button {
                                text: @tr("Import settings…");
                                clicked => { root.import-profile-clicked(); }
                            }
                        }
                        if root.profile-io-result != "" : Text {
                            text: root.profile-io-result;
                            font-size: 11px;
                            color: #6cf;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 5 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Session stats aggregated across all journals.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        // SCAFFOLDING: mock stats data — Phase 2.6 will wire to real
                        // journal aggregation (replaces literal numbers).
                        for line in [
                            "Sessions logged:        112",
                            "Total session time:     14h 22m",
                            "AI requests:            1,847",
                            "AI errors:              23 (1.2%)",
                            "Tiles spawned:          612",
                            "Total cost:             $1.84",
                        ] : Text {
                            text: line;
                            font-size: 11px;
                            color: #c8c8cc;
                            font-family: "Consolas";
                        }
                    }
                    if root.active-tab == 6 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Microphone device selection. List is live from WASAPI capture endpoints.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        // Phase E6 v23 — real device list from
                        // audio::list_devices().inputs, wired by Rust.
                        ComboBox {
                            model: root.mic-devices;
                            current-index <=> root.mic-device-index;
                            selected(val) => { root.mic-device-selected(val); }
                        }
                        Button {
                            text: @tr("Test microphone (3s record)");
                            clicked => { root.mic-test-clicked(); }
                        }
                        if root.mic-test-result != "" : Text {
                            text: root.mic-test-result;
                            font-size: 11px;
                            color: #6cf;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 7 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Auto-tile triggers — when transcript contains these keywords, spawn an answer tile automatically.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        DarkCheck { text: @tr("Enable auto-tile detector"); checked: true; }
                        LineEdit { placeholder-text: @tr("Add keyword..."); }
                    }
                    if root.active-tab == 8 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Custom snippets — invoke via /key in F4 palette to spawn a tile with the snippet body.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        // SCAFFOLDING: mock snippet rows — Phase 2.9 wires to
                        // config.json snippets array.
                        for snip in [
                            ["k8s",       "Kubernetes orchestrator notes"],
                            ["postgres",  "PG cheatsheet"],
                            ["docker",    "Docker reference"],
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 8px;
                            Text {
                                text: "/" + snip[0];
                                font-size: 11px;
                                font-weight: 700;
                                color: #6cf;
                                width: 80px;
                            }
                            Text {
                                text: snip[1];
                                font-size: 11px;
                                color: #c8c8cc;
                            }
                        }
                        Button { text: @tr("+ Add snippet"); }
                    }
                    if root.active-tab == 9 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Embedded knowledge base — 1,696 entries (glossary / commands / patterns), compiled into the binary.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        // Phase E6 v29 — the in-Settings search box was a
                        // dead stub. KB search lives in the F4 palette
                        // (fully wired). Point the user there instead of
                        // shipping a non-functional second search box.
                        Text {
                            text: @tr("Press F4 anywhere to search the knowledge base and spawn a tile from any entry.");
                            font-size: 11px;
                            color: #6cf;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 10 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Persistent context sent with every AI request — your role, focus areas, vocabulary. Saved to config; applied to new AI calls immediately.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        // Phase E6 v29 — real multi-line editor wired to
                        // cfg.meeting_context (was a dead placeholder box).
                        TextEdit {
                            text <=> root.meeting-context-input;
                            wrap: word-wrap;
                            height: 220px;
                            placeholder-text: @tr("e.g. I'm a Senior SRE interviewing for a platform role. Answer concisely, prefer Kubernetes/AWS examples, Russian output.");
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            // Phase E6 v43 — voice dictation toggle.
                            Button {
                                text: root.context-dictating
                                    ? @tr("🔴 Stop recording")
                                    : @tr("🎤 Dictate");
                                clicked => { root.context-dictate-clicked(); }
                            }
                            Button {
                                text: @tr("Save context");
                                clicked => { root.meeting-context-save(root.meeting-context-input); }
                            }
                            // Phase E6 v43 — structure the context via AI.
                            Button {
                                text: root.context-processing
                                    ? @tr("Structuring…")
                                    : @tr("✨ Structure via AI");
                                enabled: !root.context-processing;
                                clicked => { root.context-process-clicked(); }
                            }
                            if root.meeting-context-result != "" : Text {
                                text: root.meeting-context-result;
                                font-size: 11px;
                                color: #6cf;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if root.active-tab == 11 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: @tr("Claude AI bridge — bearer token + base URL + model.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }

                        // ----- ai_bearer (Claude token) -----
                        Text {
                            text: @tr("Bearer token:") + " " + root.ai-bearer-status;
                            font-size: 11px;
                            color: #c8c8cc;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("paste new bearer token then Save");
                                text <=> root.ai-bearer-input;
                                input-type: password;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.ai-bearer-save(root.ai-bearer-input);
                                    root.ai-bearer-input = "";
                                }
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // ----- ai_base_url -----
                        Text {
                            text: @tr("Base URL (Claude bridge endpoint):");
                            font-size: 11px;
                            color: #c8c8cc;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("http://your.bridge.host:PORT/v1");
                                text <=> root.ai-base-url-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.ai-base-url-save(root.ai-base-url-input);
                                }
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // ----- ai_model -----
                        Text {
                            text: @tr("AI model (Claude full ID):");
                            font-size: 11px;
                            color: #c8c8cc;
                        }
                        // Model picker — populated from GET {base_url}/models
                        // (Anthropic bridge / OpenAI-compatible endpoint).
                        // "refresh" re-queries; saving the URL or bearer also
                        // re-fetches. No hand-typing the model id.
                        HorizontalLayout {
                            spacing: 6px;
                            ComboBox {
                                model: root.ai-models;
                                current-index: root.ai-model-index;
                                horizontal-stretch: 1;
                                selected => {
                                    root.ai-model-selected(self.current-value);
                                }
                            }
                            Button {
                                text: @tr("refresh");
                                clicked => {
                                    root.ai-models-refresh();
                                }
                            }
                        }
                        if root.ai-models.length == 0 : Text {
                            text: @tr("No models found — check the bridge URL/token, then press refresh.");
                            font-size: 10px;
                            color: #999;
                            wrap: word-wrap;
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // ===== Local model provider (Ollama / llama.cpp) =====
                        Text {
                            text: @tr("Provider — run a LOCAL model instead of the cloud bridge (fallback if Claude is down, or full replacement).");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Cloud (bridge)"), @tr("Local (Ollama / llama.cpp)")];
                            current-index: root.ai-provider-index;
                            selected => {
                                root.ai-provider-changed(self.current-index);
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("local URL — http://127.0.0.1:11434/v1");
                                text <=> root.ai-local-base-url-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.ai-local-base-url-save(root.ai-local-base-url-input);
                                }
                            }
                        }
                        // Model picker — populated from GET {URL}/models
                        // (llama.cpp serves the loaded model; Ollama the full
                        // list). "refresh" re-queries; switching to Local or
                        // saving the URL also auto-fetches. No hand-typing.
                        HorizontalLayout {
                            spacing: 6px;
                            ComboBox {
                                model: root.ai-local-models;
                                current-index: root.ai-local-model-index;
                                horizontal-stretch: 1;
                                selected => {
                                    root.ai-local-model-selected(self.current-value);
                                }
                            }
                            Button {
                                text: @tr("refresh");
                                clicked => {
                                    root.ai-local-models-refresh();
                                }
                            }
                        }
                        if root.ai-local-models.length == 0 : Text {
                            text: @tr("No models found — start the local server, then press refresh.");
                            font-size: 10px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        DarkCheck {
                            text: @tr("Local model supports images (vision)");
                            checked <=> root.ai-local-vision;
                            toggled(v) => {
                                root.ai-local-vision-changed(v);
                            }
                        }
                        DarkCheck {
                            text: @tr("Local model reasoning/thinking (slower, off = faster)");
                            checked <=> root.ai-local-thinking;
                            toggled(v) => {
                                root.ai-local-thinking-changed(v);
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Test local connection");
                                clicked => {
                                    root.ai-local-test-clicked();
                                }
                            }
                            if root.ai-local-test-result != "" : Text {
                                text: root.ai-local-test-result;
                                font-size: 11px;
                                color: #6cf;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // ----- Connection test (Phase E6 v27) -----
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Test AI bridge connection");
                                clicked => { root.ai-bridge-test-clicked(); }
                            }
                            if root.ai-bridge-test-result != "" : Text {
                                text: root.ai-bridge-test-result;
                                font-size: 11px;
                                color: #6cf;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // E9 — experimental prompt-caching toggle.
                        DarkCheck {
                            text: @tr("Prompt-caching (experimental — needs bridge support)");
                            checked <=> root.ai-prompt-cache;
                            toggled(v) => { root.ai-prompt-cache-changed(v); }
                        }
                        Text {
                            text: @tr("Marks the system prompt as cacheable for faster repeat asks. If your bridge rejects it (AI stops answering), turn this back off.");
                            font-size: 10px;
                            color: #666;
                            wrap: word-wrap;
                        }

                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\overlay-mvp\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: #666;
                            wrap: word-wrap;
                        }
                    }
                    if root.active-tab == 12 : VerticalLayout {
                        spacing: 8px;

                        // ===== STT engine (Phase E10) =====
                        Text {
                            text: @tr("Speech-to-text engine. Local options run on this PC (no cloud, no Groq key needed).");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Cloud (Groq Whisper)"), @tr("Local GigaAM-v3 (Russian)"), @tr("Local Whisper (whisper.cpp)")];
                            current-index: root.stt-provider-index;
                            selected => {
                                root.stt-provider-changed(self.current-index);
                            }
                        }
                        if root.stt-provider-index == 1 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("GigaAM model dir — folder with model.int8.onnx + vocab.txt");
                                text <=> root.stt-gigaam-dir-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-gigaam-dir-save(root.stt-gigaam-dir-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server URL — http://127.0.0.1:8081/v1");
                                text <=> root.stt-whisper-url-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-url-save(root.stt-whisper-url-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server bearer token (optional)");
                                input-type: password;
                                text <=> root.stt-whisper-bearer-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-bearer-save(root.stt-whisper-bearer-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper model — e.g. whisper-large-v3-turbo");
                                text <=> root.stt-whisper-model-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-model-save(root.stt-whisper-model-input);
                                }
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        Text {
                            text: @tr("Groq STT (Whisper) — API key + model. Used only when the engine above is Cloud.");
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }

                        // ----- groq_api_key -----
                        Text {
                            text: @tr("Groq API key:") + " " + root.groq-api-key-status;
                            font-size: 11px;
                            color: #c8c8cc;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("paste new Groq key then Save");
                                text <=> root.groq-api-key-input;
                                input-type: password;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.groq-api-key-save(root.groq-api-key-input);
                                    root.groq-api-key-input = "";
                                }
                            }
                        }

                        Rectangle { background: #2a2c3a; height: 1px; }

                        // ----- Connection test (Phase E6 v27) -----
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Test STT connection");
                                clicked => { root.stt-test-clicked(); }
                            }
                            if root.stt-test-result != "" : Text {
                                text: root.stt-test-result;
                                font-size: 11px;
                                color: #6cf;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\overlay-mvp\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: #666;
                            wrap: word-wrap;
                        }
                    }

                    // Phase E6 v18 — push tab content to TOP of viewport.
                    // Without this, ScrollView lets the VerticalLayout
                    // stretch to fill height, leaving small tabs (Stealth,
                    // Coaching) with their content visually centered/
                    // bottomed instead of starting at the header.
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }
        } // HorizontalLayout
    } // rounded root Rectangle

    pure function tab-name-for(idx: int) -> string {
        return idx == 0 ? @tr("Stealth") :
               idx == 1 ? @tr("Coaching") :
               idx == 2 ? @tr("Hotkeys") :
               idx == 3 ? @tr("Interface") :
               idx == 4 ? @tr("Updates") :
               idx == 5 ? @tr("Stats") :
               idx == 6 ? @tr("Audio") :
               idx == 7 ? @tr("Auto-tiles") :
               idx == 8 ? @tr("Snippets") :
               idx == 9 ? @tr("Knowledge base") :
               idx == 10 ? @tr("Profile + context") :
               idx == 11 ? @tr("AI bridge") :
               idx == 12 ? @tr("STT") :
               "—";
    }
}
