// Settings window — custom dark tab bar + content area (the std TabWidget
// clashes with our theme, and we want per-tab control of content rendering).
// The sidebar groups tabs into SESSION / AI / APP; `active-tab` indexes the
// content pane. Indices have gaps (5 + 8) where the Stats + Snippets panes
// were removed:
//
//   0  Stealth          (APP)     capture-affinity toggle
//   1  Coaching         (SESSION) post-meeting debrief toggle
//   2  Hotkeys          (APP)     read-only global-hotkey table
//   3  Interface        (APP)     language switcher → gettext
//   4  Updates          (APP)     in-app updater
//   6  Audio            (APP)     device dropdowns + level meter + test
//   7  Auto-tiles       (AI)      detector toggle + trigger-keyword editor
//   9  Knowledge base   (AI)      search + entry preview
//  10  Profile+context  (SESSION) multi-profile picker + context editor
//  11  AI bridge        (AI)      cloud/local selector + probe + cost cap
//  12  STT              (AI)      provider selector + GigaAM GPU + Whisper

import { Button, LineEdit, ScrollView, SpinBox, ComboBox, Slider, TextEdit, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton } from "controls.slint";

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.text-secondary;
    in property <length> glyph-size: 15px;
    in property <length> slot-width: 16px;
    in property <length> slot-height: 26px;
    width: slot-width;
    height: slot-height;
    horizontal-stretch: 0;

    Image {
        source: root.icon;
        colorize: root.tint;
        width: root.glyph-size;
        height: root.glyph-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component BrandHeaderMark inherits Rectangle {
    in property <length> mark-size: 22px;
    width: mark-size;
    height: mark-size;
    horizontal-stretch: 0;

    Image {
        source: @image-url("../assets/brand-head.svg");
        colorize: Theme.is-light ? #111827 : #ffffff;
        width: root.mark-size;
        height: root.mark-size;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

// Curated-memory row (Phase 3b.3) — a candidate OR an approved item rendered in
// the 💭 Memory tab. `id` is the DB row id (passed back on approve/reject/
// delete); `kind` is a glyph; `reason` is the heuristic hint (candidates) or
// empty (items). Built in Rust by settings_memory.rs.
export struct MemoryRow {
    id: int,
    kind: string,
    text: string,
    reason: string,
}

// Onboarding «Компоненты» hub — one row per on-demand component (engine /
// local model / STT / voices / OCR). Built in Rust from
// `overlay_backend::components::status`.
export struct ComponentRow {
    name: string,
    detail: string,
    installed: bool,
    hint: string,
    // True for the light, single-call installers wired INLINE in the hub
    // (voices / OCR). The heavy ones (engine / model / STT) keep their dedicated
    // panels with progress + cancel, so this is false for them.
    installable: bool,
    // Settings tab-index this card jumps to via «Открыть ›» (engine/model → AI
    // мост 11, STT → STT 12). -1 = no jump (voices/OCR install inline instead).
    jump-tab: int,
}

// Phase E6 v40 — toggle SWITCH (borrowed from the Claude Design bundle:
// "SwitchRow вместо чекбоксов"). Was a custom square checkbox (v24, to
// dodge the std CheckBox's near-invisible unchecked label on Theme.bg-surface).
// Now renders a pill track + sliding knob — bigger hit-target, clearer
// on/off read. NAME kept as `DarkCheck` so all call sites + the
// `checked`/`toggled` API stay untouched (pure visual swap). Green
// (Theme.accent) = ON, neutral grey = OFF; font-independent (no glyphs).
export component DarkCheck inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked: false;
    callback toggled(bool);
    // min-height (not a fixed height) so the row can GROW when a long label wraps
    // to a 2nd line instead of being clipped vertically. horizontal-stretch:1 fills
    // the card width.
    min-height: 24px;
    horizontal-stretch: 1;
    HorizontalLayout {
        spacing: 9px;
        // No alignment:start — the label Text must receive the REMAINING width so
        // word-wrap engages (alignment:start froze it at one-line width and ran
        // long labels off the card edge — the GPU DirectML / Test-Practice toggles).
        // Track + knob. Knob slides right & turns green when ON.
        Rectangle {
            width: 38px;
            horizontal-stretch: 0;
            height: 22px;
            y: (parent.height - self.height) / 2;
            border-radius: 11px;
            border-width: 1px;
            border-color: root.checked ? Theme.accent : Theme.border;
            background: root.checked ? Theme.accent.with-alpha(0.2) : #ffffff0f;
            animate background, border-color { duration: 140ms; }
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                y: (parent.height - self.height) / 2;
                x: root.checked ? parent.width - self.width - 3px : 3px;
                background: root.checked ? Theme.accent : Theme.text-muted;
                animate x, background { duration: 140ms; }
            }
        }
        Text {
            text: root.text;
            font-size: 12px;
            color: Theme.text-primary;
            vertical-alignment: center;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
    }
    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// Glacier scard — a titled card that groups related settings on a tab. Pass
// `title` for a section header (omit for a plain padded card); children lay out
// vertically inside via @children. Subtly elevated (bg-elevated) + 1px border so
// dense tabs read as grouped panels instead of a flat stack of controls.
component SettingsCard inherits Rectangle {
    in property <string> title;
    // FILL the content-pane width instead of growing to the content's preferred
    // width — without this a card whose only content is a long wrapping Text (no
    // stretch:1 control like a DarkCheck/Slider to anchor the width) pushed the
    // tab's VerticalLayout — and the ScrollView — into a HORIZONTAL scroll, so
    // the card border ran off-screen and text spilled past the (off-screen)
    // border. `clip` is a belt-and-braces guard so nothing can render outside the
    // rounded border even if a child reports an over-wide min-width.
    horizontal-stretch: 1;
    background: Theme.bg-elevated;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.border;
    clip: true;
    VerticalLayout {
        padding: 12px;
        spacing: 8px;
        if root.title != "" : Text {
            text: root.title;
            font-size: 12px;
            font-weight: 700;
            color: Theme.text-secondary;
        }
        @children
    }
}

// Phase E6 v39 — grouped sidebar, cherry-picked from the Claude Design
// bundle (claude.ai/design handoff). Borrows the STRUCTURE — section
// headers + an active left-accent bar — while keeping the app's cyan
// accent (Theme.accent, same as the bar grip) for visual continuity. Each
// NavItem maps to its EXISTING pane index, so the content panes and the
// Rust `tab-selected` wiring stay untouched (low-risk increment).
component NavGroupHeader inherits Rectangle {
    in property <string> label;
    height: 22px;
    HorizontalLayout {
        padding-left: 9px;
        padding-top: 8px;
        Text {
            text: root.label;
            font-size: 10px;
            font-weight: 700;
            color: Theme.text-muted;
            vertical-alignment: bottom;
        }
    }
}

component NavItem inherits Rectangle {
    in property <string> label;
    // Design-system nav icon (skia-safe line SVG), tinted with the row colour.
    in property <image> icon;
    in property <int> tab-index;
    in property <bool> active: false;
    callback chosen(int);
    height: 26px;
    border-radius: 4px;
    background: root.active
        ? Theme.accent-subtle
        : (ta.has-hover ? Theme.bg-elevated : transparent);
    animate background { duration: 120ms; }
    // active left-accent bar
    if root.active: Rectangle {
        x: 0px;
        y: 6px;
        width: 3px;
        height: parent.height - 12px;
        border-radius: 2px;
        background: Theme.accent;
    }
    HorizontalLayout {
        padding-left: 10px;
        spacing: 8px;
        IconSlot {
            icon: root.icon;
            tint: root.active ? Theme.accent : Theme.text-secondary;
            glyph-size: 15px;
            slot-width: 16px;
            slot-height: 26px;
        }
        Text {
            text: root.label;
            font-size: 12px;
            color: root.active ? Theme.accent : Theme.text-secondary;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
    ta := TouchArea {
        clicked => { root.chosen(root.tab-index); }
    }
}

export component SettingsWindow inherits Window {
    // Phase 4 — drive the std-widgets Palette (ComboBox/LineEdit/TextEdit/
    // Button/Slider/SpinBox) off our active scheme so they render dark like
    // the rest of the UI instead of Slint's light fluent default. Light Frost
    // (scheme 3) is the only light scheme; `changed` keeps widgets in sync
    // when the user flips schemes live in Settings -> Interface.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    title: @tr("suflyor settings (Slint)");
    // Phase E6 v25 — frameless. User: "хедер, он нам разве нужен?".
    // Native title bar removed; drag via the "Settings" sidebar header
    // (drag-start-requested + drag-moved → win32 cursor-delta drag,
    // same mechanism as the overlay bar). Close via the existing
    // "X Close" button.
    icon: @image-url("../assets/icon.svg");
    no-frame: true;
    preferred-width: 720px;
    // Phase E6 v39 — taller (480→560) to fit the grouped sidebar; v0.22 → 600
    // for the extra «Компоненты» nav item. The sidebar nav is now ALSO inside a
    // ScrollView, so Close stays pinned even below this height.
    preferred-height: 600px;
    min-width: 480px;
    min-height: 320px;
    // Phase E6 v26 — transparent window so the inner rounded Rectangle's
    // corners composite over the desktop (DWM per-pixel alpha applied
    // via make_transparent_tile on show). User: "закруглить рамки".
    background: transparent;

    in-out property <int> active-tab: 0;
    // Tile-placement monitor picker (tab 0). Items + selected index are filled by
    // the Rust controller from enum_monitors() on open; the card hides when there
    // is only one display.
    in-out property <[string]> tile-monitors: [];
    in-out property <int> tile-monitor-index: 0;
    // Phase 3b.3 — 💭 Memory tab data (built in Rust by settings_memory.rs over
    // the SQLite memory tables). Candidates = pending suggestions; items =
    // approved memory. `id` flows back through the callbacks.
    in-out property <[MemoryRow]> memory-candidates: [];
    in-out property <[MemoryRow]> memory-items: [];
    // Onboarding «Компоненты» readiness rows (set by the controller on open).
    in-out property <[ComponentRow]> component-rows: [];
    // Index of the row whose inline install is running (-1 = none) + its status
    // line. The controller sets these while a hub install worker runs.
    in-out property <int> component-busy-index: -1;
    in-out property <string> component-busy-status;
    // Fired when the user clicks a card's inline «Установить» (passes the row index).
    callback component-install(int);
    in-out property <string> memory-status: "";
    callback memory-approve(int);
    callback memory-reject(int);
    callback memory-delete-item(int);
    callback memory-extract();
    // v0.16.0 — manual "add your own fact" input (personal knowledge base):
    // the text goes straight into the APPROVED memory_items (typing it IS the
    // consent the approve step otherwise provides).
    in-out property <string> memory-add-text: "";
    callback memory-add-fact(string);
    // Persisted cross-window toggles (driven by overlay-host).
    in-out property <bool> always-on-top-toggle: true;
    in-out property <bool> stealth-toggle: false;

    // Phase E6 — token status display + edit. Status strings are
    // populated by overlay-host on open from cfg.read().ai_bearer
    // and cfg.read().groq_api_key (masked: "✓ set (48 chars)" or
    // "❌ unset"). The LineEdit accepts a fresh value; Save fires
    // the corresponding callback which writes to config.json.
    in-out property <string> ai-bearer-status: "(loading...)";
    in-out property <string> ai-bearer-input: "";
    in-out property <string> groq-api-key-status: "(loading...)";
    in-out property <string> groq-api-key-input: "";
    in-out property <string> ai-base-url-input: "";
    // Phase E10.1 — cloud model dropdown from GET {ai_base_url}/models.
    in-out property <[string]> ai-models: [];
    in-out property <int> ai-model-index: 0;
    // E9 — experimental prompt-caching toggle (default off).
    in-out property <bool> ai-prompt-cache: false;
    // Local AI provider (Phase 1): 0 = cloud bridge, 1 = local (Ollama/llama.cpp).
    in-out property <int> ai-provider-index: 0;
    // V4 — vision (screenshot · F8) channel, resolved separately from the text model.
    in-out property <int> vision-provider-index: 2; // 0=off 1=same 2=cloud 3=local
    // Feature #4 — IPA phonetics in F8 translate-mode output (OFF by default).
    in-out property <bool> vision-phonetics: false;
    // v0.11.0 — Test Practice mode for plain F8 (study / self-check). OFF default.
    in-out property <bool> vision-test-practice: false;
    in-out property <string> vision-base-url-input;
    in-out property <string> vision-bearer-input;
    in-out property <string> vision-model-input;
    in-out property <string> vision-local-base-url-input;
    in-out property <string> vision-local-bearer-input;
    in-out property <string> vision-local-model-input;
    in-out property <string> vision-test-result;
    callback vision-provider-changed(int);
    callback vision-phonetics-changed(bool);
    callback vision-test-practice-changed(bool);
    callback vision-base-url-save(string);
    callback vision-bearer-save(string);
    callback vision-model-save(string);
    callback vision-local-base-url-save(string);
    callback vision-local-bearer-save(string);
    callback vision-local-model-save(string);
    callback vision-test-clicked();

    // Read-aloud (Озвучка) — voice chooser + speed preset + a test button.
    in-out property <[string]> tts-voice-names;
    in-out property <int> tts-voice-index: 0;
    in-out property <int> tts-rate-index: 1; // 0..4 preset, default «1.0×»
    in-out property <bool> tts-available: false;
    in-out property <bool> tts-installing: false;
    in-out property <string> tts-install-status;
    callback tts-voice-changed(int);
    callback tts-rate-changed(int);
    callback tts-test-clicked();
    callback tts-install-clicked();

    // Text recognition (OCR) engine — local Tesseract for Shift+Alt+2 / Ctrl+F8,
    // installed on demand (not bundled).
    in-out property <bool> ocr-installed: false;
    in-out property <bool> ocr-installing: false;
    in-out property <string> ocr-install-status;
    callback ocr-install-clicked();
    in-out property <string> ai-local-base-url-input: "";
    // Phase E10.1 — model dropdown populated from GET {base_url}/models so the
    // user picks a loaded model instead of typing its id.
    in-out property <[string]> ai-local-models: [];
    in-out property <int> ai-local-model-index: 0;
    in-out property <bool> ai-local-vision: false;
    // E10 — local-model "thinking"/reasoning toggle. Off (default) sends
    // enable_thinking=false for faster answers; on lets the model reason.
    in-out property <bool> ai-local-thinking: false;
    // v0.18.0 — local LLM size choice: false = fast 4B (default), true = smart
    // but ~2× slower 12B. The 12B is downloaded on demand (not bundled); these
    // mirror config + the download worker state.
    in-out property <bool> ai-local-quality: false;
    in-out property <bool> quality-model-present: false;
    in-out property <bool> quality-downloading: false;
    in-out property <bool> model-switching: false; // server relaunch in flight
    in-out property <float> quality-progress: 0.0; // 0.0..1.0
    in-out property <string> quality-status: "";
    // v0.18.2 — 12B vision: its own projector (gemma4uv, ~175 MB) downloaded on
    // demand, attachable ONLY on a new-enough engine (>= b9626). present = file
    // on disk; supported = engine can load it; downloading = pull in flight.
    in-out property <bool> quality-vision-present: false;
    in-out property <bool> quality-vision-supported: false;
    in-out property <bool> vision12b-downloading: false;
    in-out property <string> vision12b-status: "";
    // v0.18.2 — llama.cpp engine auto-update. build = installed bNNNN (display);
    // updating = a check/swap in flight; status = live English/RU line.
    in-out property <string> engine-build: "";
    in-out property <bool> engine-updating: false;
    in-out property <string> engine-update-status: "";
    in-out property <string> ai-local-test-result: "";
    in-out property <string> ai-local-bearer-input: "";
    // E10.4 — in-app local-AI installer: downloads llama.cpp/whisper.cpp + models,
    // launches the servers, then auto-configures. Progress + GPU/CPU shown live.
    in-out property <bool> local-ai-installing: false;
    in-out property <string> local-ai-status: "";
    in-out property <float> local-ai-progress: 0.0; // 0.0..1.0
    in-out property <string> local-ai-gpu: "";
    in-out property <bool> local-ai-on-gpu: false;
    callback install-local-ai-clicked();
    callback cancel-local-ai-clicked();

    // Phase E6 v20 — tile body opacity (50..100%). Slider on Stealth
    // tab; Rust writes to cfg.tile_body_opacity + applies to spawning
    // tiles. Cherry-picked from design bundle 2 (only this prop).
    in-out property <float> tile-body-opacity: 1.0;
    callback tile-body-opacity-changed(float);

    // Phase E6 v23 — real audio device list (populated by Rust from
    // audio::list_devices().inputs on Settings open). mic-test-result
    // shows the dBFS probe outcome. Replaces the mock device list.
    in-out property <[string]> mic-devices: ["(loading devices…)"];
    in-out property <int> mic-device-index: 0;
    in-out property <string> mic-test-result: "";
    callback mic-device-selected(string);
    callback mic-test-clicked();

    callback always-on-top-changed(bool);
    callback stealth-changed(bool);
    callback tile-monitor-changed(int);
    callback open-wizard-clicked();
    callback close-clicked();
    callback tab-selected(int);
    // Phase E6 v25 — frameless window drag (cursor-delta, wired in Rust).
    callback drag-start-requested();
    callback drag-moved();
    callback ai-bearer-save(string);
    callback groq-api-key-save(string);
    callback ai-base-url-save(string);
    callback ai-model-selected(string);
    callback ai-models-refresh();
    callback ai-prompt-cache-changed(bool);
    callback ai-provider-changed(int);
    callback ai-local-base-url-save(string);
    callback ai-local-bearer-save(string);
    callback ai-local-model-selected(string);
    callback ai-local-models-refresh();
    callback ai-local-vision-changed(bool);
    callback ai-local-thinking-changed(bool);
    // v0.18.0 — local model size: faster 4B vs smarter 12B. `model-quality-changed`
    // writes config + restarts the local server with the other GGUF;
    // `download-quality-clicked` pulls the 12B on demand (it isn't bundled).
    callback model-quality-changed(bool);
    callback download-quality-clicked();
    // v0.18.2 — pull the 12B vision projector; update the llama.cpp engine.
    callback download-vision12b-clicked();
    callback update-engine-clicked();
    callback ai-local-test-clicked();
    // Phase E6 v27 — connection test buttons (AI bridge + STT).
    in-out property <string> ai-bridge-test-result: "";
    in-out property <string> stt-test-result: "";
    // STT provider (Phase E10): 0=cloud Groq, 1=local GigaAM, 2=local whisper-server.
    in-out property <int> stt-provider-index: 0;
    // Recognition language (stt_language): 0=auto-detect, 1=Russian, 2=English.
    in-out property <int> stt-language-index: 0;
    in-out property <string> stt-gigaam-dir-input: "";
    // GigaAM GPU acceleration via the ONNX Runtime DirectML EP (default on).
    in-out property <bool> stt-gigaam-gpu: true;
    in-out property <string> stt-whisper-url-input: "";
    in-out property <string> stt-whisper-bearer-input: "";
    in-out property <string> stt-whisper-model-input: "";
    callback ai-bridge-test-clicked();
    callback stt-test-clicked();
    callback stt-provider-changed(int);
    callback stt-language-changed(int);
    callback stt-gigaam-dir-save(string);
    callback stt-gigaam-gpu-changed(bool);
    callback stt-whisper-url-save(string);
    callback stt-whisper-bearer-save(string);
    callback stt-whisper-model-save(string);
    // Phase E6 v28 — full-profile import/export (incl. API keys).
    in-out property <string> profile-io-result: "";
    callback export-profile-clicked();
    callback import-profile-clicked();
    // #125 — server-ONLY import (AI/STT servers; keeps local prefs).
    callback import-server-settings-clicked();
    // P1.7 — server-ONLY export (server fields only, incl. creds — for PC->PC
    // transfer); and a REDACTED import PREVIEW gated behind an explicit Apply.
    callback export-server-settings-clicked();
    callback apply-server-settings-clicked();
    callback cancel-server-settings-clicked();
    // True once a picked file has been parsed into a preview: reveals the
    // redacted diff + Apply/Cancel below the import button.
    in-out property <bool> server-preview-ready: false;
    // Redacted, data-only preview lines (provider/url/model old->new + key
    // PRESENCE as "set"/"—"); composed in Rust like the diagnostics detail
    // strings. NEVER carries a secret value (see preview_server_settings).
    in-out property <string> server-preview-cloud: "";
    in-out property <string> server-preview-local: "";
    in-out property <string> server-preview-vision: "";
    in-out property <string> server-preview-stt: "";
    // Machine-local GigaAM model path note (old/incoming); kept from THIS PC.
    in-out property <string> server-preview-gigaam: "";
    // #131 — diagnostics / readiness panel. Config-readiness levels are pushed
    // from Rust (Config::readiness); "Проверить всё" layers live AI/STT pings.
    // level: -1 checking · 0 ok · 2 not-configured · 3 info · 4 live-error.
    in-out property <string> diag-summary: "";
    in-out property <int> diag-ai-level: 0;
    in-out property <string> diag-ai-detail: "";
    in-out property <int> diag-stt-level: 0;
    in-out property <string> diag-stt-detail: "";
    in-out property <int> diag-mic-level: 3;
    in-out property <string> diag-mic-detail: "";
    in-out property <int> diag-sys-level: 3;
    in-out property <string> diag-sys-detail: "";
    in-out property <bool> diag-stealth-on: false;
    // P1.1 — Vision (F8) channel readiness. level 0=ready, 3=off/neutral.
    in-out property <int> diag-vision-level: 3;
    in-out property <string> diag-vision-detail: "";
    // P1.2 — global-hotkey registration. level 0=all registered, 4=a key failed
    // (conflict); detail names the failed key(s), never a blanket "disabled".
    in-out property <int> diag-hotkeys-level: 3;
    in-out property <string> diag-hotkeys-detail: "";
    // Failed hotkey names (data only; the "conflict:" wording is composed +
    // translated in the row so no English leaks from Rust).
    in-out property <string> diag-hotkeys-failed: "";
    // Transient confirmation flag for the redacted diagnostic-report copy
    // (bool so the "copied" word is translated in-UI, no Rust-built string).
    in-out property <bool> diag-copied: false;
    // Transient confirmation for the "Collect logs" action (redacted log saved).
    in-out property <bool> diag-logs-collected: false;
    callback diagnostics-check-all-clicked();
    callback diagnostics-copy-report-clicked();
    callback diagnostics-collect-logs-clicked();
    // Phase E6 v29 — meeting-context editor (Profile+context tab).
    in-out property <string> meeting-context-input: "";
    in-out property <string> meeting-context-result: "";
    callback meeting-context-save(string);
    // Phase F — multi-profile picker: named context presets. The active
    // profile's context mirrors meeting-context-input.
    in-out property <[string]> profile-names: [];
    in-out property <int> active-profile-index: -1;
    in-out property <string> profile-name-input: "";
    callback profile-selected(int);
    callback profile-add(string);
    callback profile-rename(string);
    callback profile-delete();
    // Phase F — Coaching + Auto-tiles controls (were dead/cosmetic: no binding).
    in-out property <bool> coaching-debrief: false;
    callback coaching-debrief-changed(bool);
    // v0.13.0 — raw-audio recording (Audio tab).
    in-out property <bool> record-audio: true;
    callback record-audio-changed(bool);
    // v0.15.0 — storage/retention controls (Audio tab). Mode: 0 = keep all,
    // 1 = keep last N sessions, 2 = keep last N days; the value LineEdit holds
    // N as text (parsed + persisted by Rust; invalid input is ignored).
    in-out property <int> retention-mode: 1;
    in-out property <string> retention-value: "10";
    callback retention-changed(int, string);
    // Journal (archive transcripts) retention: count + disk cap, 0 = unlimited.
    in-out property <string> journal-keep-value: "100";
    in-out property <string> journal-mb-value: "500";
    callback journal-retention-changed(string, string);
    callback open-recordings-clicked();
    callback open-data-folder-clicked();
    in-out property <bool> auto-tiles-enabled: true;
    callback auto-tiles-enabled-changed(bool);
    // "Listening mode" — mute auto-detected AI tiles (TileKind::Ai) so the user
    // can record + just listen without tiles popping up.
    in-out property <bool> suppress-tiles: false;
    callback suppress-tiles-changed(bool);
    in-out property <string> trigger-keywords-input: "";
    callback trigger-keywords-save(string);
    // Phase E6 v43 — "Structure via AI" button: sends the current context
    // text to the AI with a profile-structuring prompt; Rust replaces the
    // field with the cleaned result. context-processing dims the button
    // while the AI call is in flight.
    in-out property <bool> context-processing: false;
    callback context-process-clicked();
    // Phase E6 v43 — voice dictation INTO the context field: click to
    // start recording the mic, click again to stop; Rust transcribes
    // (Groq) and appends the text to the editor. context-dictating drives
    // the red "stop" state.
    in-out property <bool> context-dictating: false;
    callback context-dictate-clicked();

    // Phase E6 v38 — interface-language selector. ui-language-index
    // reflects the saved config (0=Русский, 1=English); language-selected
    // fires when the ComboBox changes so Rust can switch the bundled
    // translation live AND persist it.
    in-out property <int> ui-language-index: 0;
    callback language-selected(int);

    // Colour-scheme selector (Interface tab). color-scheme-index reflects
    // the saved config (0=Glacier / 1=Graphite / 2=Obsidian / 3=Light Frost);
    // color-scheme-selected fires on change so Rust can switch Theme.scheme
    // live across every window AND persist it.
    in-out property <int> color-scheme-index: 0;
    callback color-scheme-selected(int);

    // Phase E8 — in-app auto-update (Updates tab). Rust sets app-version
    // from CARGO_PKG_VERSION on open; check-updates-clicked queries GitHub
    // and fills update-status / update-available; install-update-clicked
    // downloads + runs the installer (then the app quits).
    in-out property <string> app-version: "0.0.0";
    in-out property <string> update-status: "";
    in-out property <bool> update-available: false;
    in-out property <bool> update-checking: false;
    // Download URL of the found installer (set by Rust after a successful
    // check; read back by the install handler). Hidden plumbing.
    in-out property <string> update-download-url: "";
    callback check-updates-clicked();
    callback install-update-clicked();

    // Phase E6 v26 — rounded root. clip:true so the square-cornered
    // sidebar + content get masked to the 12px radius. Border + bg
    // moved here from the Window (which is now transparent).
    Rectangle {
        background: Theme.bg-surface;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;

        HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ----- Sidebar tab list -----
        Rectangle {
            width: 200px;
            background: Theme.bg-base;
            border-color: Theme.border;
            border-width: 0px;

            VerticalLayout {
                padding: 8px;
                spacing: 2px;

                // "Settings" header doubles as the window drag handle
                // (frameless — no native title bar). Phase E6 v25.
                Rectangle {
                    height: 26px;
                    horizontal-stretch: 1;
                    drag-handle := TouchArea {
                        mouse-cursor: grab;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => { if (self.pressed) { root.drag-moved(); } }
                    }
                    // Drag grip + title.
                    HorizontalLayout {
                        spacing: 7px;
                        alignment: start;
                        BrandHeaderMark {
                            mark-size: 22px;
                        }
                        IconSlot {
                            icon: @image-url("../assets/icons/grip.svg");
                            tint: Theme.accent;
                            glyph-size: 13px;
                            slot-width: 13px;
                            slot-height: 26px;
                        }
                        Text {
                            text: @tr("Settings");
                            font-size: 14px;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { background: Theme.border; height: 1px; }

                // Phase E6 v39 — grouped nav (borrowed from design bundle).
                // Each item keeps its ORIGINAL pane index (0-12) so the
                // content panes + tab-selected wiring are untouched; only
                // the visual order + section grouping changes. Labels
                // reuse the existing emoji+text @tr msgids verbatim.
                // Scrollable nav so the «X Close» button below ALWAYS stays
                // visible no matter how many items the sidebar holds. The new
                // «Компоненты» item tipped the fixed list past the window height,
                // pushing Close off the bottom (design review #2).
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px;
                NavGroupHeader { label: @tr("SESSION"); }
                NavItem {
                    label: @tr("Profile + context"); icon: @image-url("../assets/icons/user.svg"); tab-index: 10;
                    active: root.active-tab == 10;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Coaching"); icon: @image-url("../assets/icons/coach.svg"); tab-index: 1;
                    active: root.active-tab == 1;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: "AI"; }
                NavItem {
                    label: @tr("Components"); icon: @image-url("../assets/icons/update.svg"); tab-index: 15;
                    active: root.active-tab == 15;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("AI bridge"); icon: @image-url("../assets/icons/ai.svg"); tab-index: 11;
                    active: root.active-tab == 11;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("STT"); icon: @image-url("../assets/icons/stt.svg"); tab-index: 12;
                    active: root.active-tab == 12;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("TTS"); icon: @image-url("../assets/icons/speaker.svg"); tab-index: 5;
                    active: root.active-tab == 5;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Auto-tiles"); icon: @image-url("../assets/icons/tiles.svg"); tab-index: 7;
                    active: root.active-tab == 7;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Knowledge base"); icon: @image-url("../assets/icons/knowledge.svg"); tab-index: 9;
                    active: root.active-tab == 9;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }

                NavGroupHeader { label: @tr("APP"); }
                NavItem {
                    label: @tr("Audio"); icon: @image-url("../assets/icons/audio.svg"); tab-index: 6;
                    active: root.active-tab == 6;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Interface"); icon: @image-url("../assets/icons/monitor.svg"); tab-index: 3;
                    active: root.active-tab == 3;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Hotkeys"); icon: @image-url("../assets/icons/kb.svg"); tab-index: 2;
                    active: root.active-tab == 2;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Stealth"); icon: @image-url("../assets/icons/stealth.svg"); tab-index: 0;
                    active: root.active-tab == 0;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Updates"); icon: @image-url("../assets/icons/update.svg"); tab-index: 4;
                    active: root.active-tab == 4;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Diagnostics"); icon: @image-url("../assets/icons/diag.svg"); tab-index: 13;
                    active: root.active-tab == 13;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                NavItem {
                    label: @tr("Memory"); icon: @image-url("../assets/icons/bubble.svg"); tab-index: 14;
                    active: root.active-tab == 14;
                    chosen(i) => { root.active-tab = i; root.tab-selected(i); }
                }
                    }
                }
                Rectangle {
                    // Unified close — x.svg icon (matches the bar Quit, tile X,
                    // archive X, "Написать" X) + a "Close" label, since this one
                    // sits at the bottom of the nav rather than in a corner.
                    // Danger tint on hover.
                    height: 32px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: closeta.has-hover ? Theme.danger.with-alpha(0.55) : Theme.border-strong;
                    background: closeta.has-hover ? Theme.danger.with-alpha(0.13) : transparent;
                    animate background, border-color { duration: 120ms; }
                    HorizontalLayout {
                        alignment: center;
                        spacing: 7px;
                        VerticalLayout {
                            alignment: center;
                            Image {
                                source: @image-url("../assets/icons/x.svg");
                                colorize: Theme.text-secondary;
                                width: 12px;
                                height: 12px;
                                image-fit: contain;
                            }
                        }
                        Text {
                            text: @tr("Close");
                            font-size: 12px;
                            color: Theme.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    closeta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.close-clicked(); }
                    }
                }
            }
        }

        // ----- Content area -----
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-surface;
            clip: true;
            // Watermark only on the AIRY tabs — hidden on the dense ones (AI
            // bridge 11 / Auto-tiles 7 / Hotkeys 2 / Memory 14) where it bled
            // through behind fields, cards and lists (design review #3). Gated
            // with an `if`-element (not `visible:`, which rendered nothing at
            // all here) — the same reliable per-tab pattern used below.
            if root.active-tab != 11 && root.active-tab != 7
                && root.active-tab != 2 && root.active-tab != 14 : Image {
                source: Theme.is-light
                    ? @image-url("../assets/brand-mark.png")
                    : @image-url("../assets/brand-mark-light.png");
                opacity: Theme.is-light ? 0.055 : 0.085;
                width: 300px;
                height: 300px;
                image-fit: contain;
                x: parent.width - self.width - 18px;
                y: parent.height - self.height - 22px;
            }
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    // Header
                    Text {
                        text: tab-name-for(root.active-tab);
                        font-size: 18px;
                        font-weight: 700;
                        color: Theme.text-primary;
                    }
                    Rectangle { background: Theme.border; height: 1px; }

                    // Tab content
                    if root.active-tab == 0 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Window behaviour");
                            Text {
                                text: @tr("Stealth mode hides the overlay window from screen capture (Print Screen, Teams/Meet, OBS). Uses WDA_EXCLUDEFROMCAPTURE on Windows 10/11.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            DarkCheck {
                                text: @tr("Always on top (HWND_TOPMOST)");
                                checked <=> root.always-on-top-toggle;
                                toggled(v) => { root.always-on-top-changed(v); }
                            }
                            DarkCheck {
                                text: @tr("Stealth (hide from screen capture)");
                                checked <=> root.stealth-toggle;
                                toggled(v) => { root.stealth-changed(v); }
                            }
                        }
                        SettingsCard {
                            title: @tr("Tile opacity");
                            // Phase E6 v20 — tile opacity slider.
                            Text {
                                text: @tr("Tile opacity ({}%)", Math.round(root.tile-body-opacity * 100));
                                font-size: 11px;
                                color: Theme.text-secondary;
                            }
                            Text {
                                text: @tr("Lower values let you see the meeting through tiles. 100% = opaque, 50% = half-transparent.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            Slider {
                                minimum: 0.5;
                                maximum: 1.0;
                                value <=> root.tile-body-opacity;
                                changed(v) => { root.tile-body-opacity-changed(v); }
                            }
                        }
                    }
                    if root.active-tab == 1 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Coaching");
                            Text {
                                text: @tr("Post-meeting debrief: AI critique of pacing, filler density, key points. Opt-in.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            DarkCheck {
                                text: @tr("Enable post-meeting debrief");
                                checked <=> root.coaching-debrief;
                                toggled(v) => {
                                    root.coaching-debrief-changed(v);
                                }
                            }
                        }
                    }
                    if root.active-tab == 2 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Hotkeys");
                            // Read-only list of the registered global hotkeys (see the
                            // GlobalHotKeyManager registrations in overlay_host.rs).
                            Text {
                                text: @tr("Global hotkeys (work anywhere, even when the app isn't focused):");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            Rectangle { background: Theme.border; height: 1px; }
                            for entry in [
                                ["F9",  @tr("Ask AI now (streams the answer into a tile)")],
                                ["Shift+F9", @tr("Ask AI escalated to the smart cloud model (one-shot; tile shows a cloud badge)")],
                                ["F3",  @tr("Re-ask the last question with fresh context")],
                                ["F6",  @tr("Manual tile from the last transcript line")],
                                ["F8",  @tr("Screenshot → AI vision (drag a region; Esc cancels)")],
                                ["Shift+F8", @tr("Screenshot → translate only (no screen description)")],
                                ["Ctrl+F8", @tr("Screenshot → OCR the text, then read it aloud")],
                                ["Shift+Alt+1", @tr("Read the selected text aloud")],
                                ["Shift+Alt+2", @tr("OCR a screen region and read it aloud")],
                                ["Shift+Alt+3", @tr("Pause / stop reading aloud")],
                                ["F4",  @tr("Knowledge-base palette (open / close)")],
                                ["F1",  @tr("Help (open / close)")],
                                ["F7",  @tr("Session archive (open / close)")],
                            ] : HorizontalLayout {
                                padding: 4px;
                                spacing: 12px;
                                Text {
                                    text: entry[0];
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Theme.accent;
                                    width: 92px;
                                }
                                Text {
                                    text: entry[1];
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                    if root.active-tab == 13 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Diagnostics");
                        Text {
                            text: @tr("Session readiness");
                            font-size: 13px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        Text {
                            text: root.diag-summary;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                        }
                        Rectangle { background: Theme.border; height: 1px; }
                        for row in [
                            { label: @tr("AI (answers)"), level: root.diag-ai-level, detail: root.diag-ai-detail },
                            { label: @tr("Speech recognition (STT)"), level: root.diag-stt-level, detail: root.diag-stt-detail },
                            { label: @tr("Vision (F8)"), level: root.diag-vision-level, detail: root.diag-vision-detail == "" ? @tr("off") : root.diag-vision-detail },
                            { label: @tr("Microphone"), level: root.diag-mic-level, detail: root.diag-mic-detail == "" ? @tr("default") : root.diag-mic-detail },
                            { label: @tr("System audio"), level: root.diag-sys-level, detail: root.diag-sys-detail == "" ? @tr("default") : root.diag-sys-detail },
                            // Detail precedence is load-bearing: registering (level 3) → conflict (failed non-empty) → ok list → unavailable. Keep `failed` checked BEFORE `detail` so a conflict is never hidden behind the registered list.
                            { label: @tr("Global hotkeys"), level: root.diag-hotkeys-level, detail: root.diag-hotkeys-level == 3 ? @tr("registering…") : (root.diag-hotkeys-failed != "" ? @tr("conflict: {}", root.diag-hotkeys-failed) : (root.diag-hotkeys-detail != "" ? root.diag-hotkeys-detail : @tr("hotkey system unavailable"))) },
                            { label: @tr("Stealth"), level: 3, detail: root.diag-stealth-on ? @tr("on — verify with a screen-share preview") : @tr("off") },
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 10px;
                            Text {
                                text: row.label;
                                font-size: 11px;
                                font-weight: 600;
                                color: Theme.text-primary;
                                width: 150px;
                            }
                            Text {
                                text: row.level == 0 ? @tr("Ready")
                                    : row.level == -1 ? @tr("checking…")
                                    : row.level == 1 ? @tr("No signal")
                                    : row.level == 2 ? @tr("Not configured")
                                    : row.level == 4 ? @tr("Error")
                                    : "—";
                                font-size: 11px;
                                font-weight: 700;
                                width: 100px;
                                color: row.level == 0 ? Theme.success
                                    : row.level == 1 ? Theme.warning
                                    : (row.level == 2 || row.level == 4) ? Theme.danger
                                    : Theme.text-muted;
                            }
                            Text {
                                text: row.detail;
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                        }
                        Rectangle { height: 4px; }
                        HorizontalLayout {
                            alignment: start;
                            spacing: 8px;
                            Button {
                                text: @tr("Check all");
                                clicked => { root.diagnostics-check-all-clicked(); }
                            }
                            Button {
                                text: @tr("Copy report");
                                clicked => { root.diagnostics-copy-report-clicked(); }
                            }
                            Button {
                                text: @tr("Collect logs");
                                clicked => { root.diagnostics-collect-logs-clicked(); }
                            }
                            Text {
                                text: root.diag-copied ? @tr("copied") : (root.diag-logs-collected ? @tr("log saved") : "");
                                font-size: 11px;
                                font-weight: 700;
                                color: Theme.success;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: @tr("“Check all” pings AI + STT, records the mic, and plays a test tone to verify system-audio capture. Speak during the check to see the mic level — you don't need to play anything yourself.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        }
                    }
                    if root.active-tab == 3 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Language");
                            Text {
                                text: @tr("Interface language — switches all UI text on the fly.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: @tr("Language:");
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    vertical-alignment: center;
                                }
                                ComboBox {
                                    // Language names are themselves untranslated identifiers
                                    // (each appears in its own language as a self-label).
                                    model: ["Русский", "English"];
                                    // Phase E6 v38 — reflect the actual saved
                                    // language (0=ru, 1=en) and fire a callback
                                    // on change. Previously hardcoded index 0
                                    // with no handler → the dropdown looked set
                                    // to Russian but switching did nothing.
                                    current-index: root.ui-language-index;
                                    selected => {
                                        root.language-selected(self.current-index);
                                    }
                                }
                            }
                        }
                        // Tile-placement monitor picker — only meaningful with 2+
                        // displays, so the whole card hides on a single monitor.
                        // Lives in Interface (next to display/language) as the
                        // natural home for "which screen do tiles appear on".
                        if root.tile-monitors.length > 1 : SettingsCard {
                            title: @tr("Tile placement");
                            Text {
                                text: @tr("Which monitor new answer tiles appear on.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            ComboBox {
                                model: root.tile-monitors;
                                current-index <=> root.tile-monitor-index;
                                selected(v) => { root.tile-monitor-changed(self.current-index); }
                            }
                        }
                        SettingsCard {
                            title: @tr("Colour scheme");
                            // Colour-scheme picker — switches the design tokens
                            // (theme.slint) live across every window. Fixes the
                            // recurring dark-on-dark complaints by letting the user
                            // pick the contrast they like.
                            Text {
                                text: @tr("Colour scheme — recolours the whole app instantly.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: @tr("Scheme:");
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    vertical-alignment: center;
                                }
                                ComboBox {
                                    // Self-labelled scheme names (proper nouns —
                                    // left untranslated so they read the same in
                                    // both languages).
                                    model: ["Glacier", "Graphite", "Obsidian", "Light Frost"];
                                    current-index: root.color-scheme-index;
                                    selected => {
                                        root.color-scheme-selected(self.current-index);
                                    }
                                }
                            }
                        }
                        SettingsCard {
                            title: @tr("Setup");
                            // First-run setup wizard — relaunchable any time.
                            Text {
                                text: @tr("Re-run the guided first-time setup.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                alignment: start;
                                Button {
                                    text: @tr("Run setup wizard");
                                    clicked => { root.open-wizard-clicked(); }
                                }
                            }
                        }
                    }
                    if root.active-tab == 5 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Read aloud");
                        Text {
                            text: @tr("Read selected text (Shift+Alt+1) or a screen region (Shift+Alt+2) aloud. Pause or resume with Shift+Alt+3.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Voice chooser — only when at least one voice is installed.
                        if root.tts-available : HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Voice:");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                model: root.tts-voice-names;
                                current-index: root.tts-voice-index;
                                selected => { root.tts-voice-changed(self.current-index); }
                            }
                        }
                        // No voices yet → offer the download (like the local-AI
                        // model installer — heavy data installs via a button, not
                        // bundled in the app installer).
                        if !root.tts-available : VerticalLayout {
                            spacing: 6px;
                            Text {
                                text: @tr("Neural voices aren't installed yet — download them (Irina + Ruslan, ~130 MB).");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                alignment: start;
                                Button {
                                    text: root.tts-installing ? @tr("Installing…") : @tr("Install voices");
                                    enabled: !root.tts-installing;
                                    clicked => { root.tts-install-clicked(); }
                                }
                            }
                        }
                        if root.tts-install-status != "" : Text {
                            text: root.tts-install-status;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                        }
                        // Speed preset (multipliers are language-neutral, untranslated).
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Speed:");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                model: ["0.75×", "1.0×", "1.3×", "1.5×", "2.0×"];
                                current-index: root.tts-rate-index;
                                selected => { root.tts-rate-changed(self.current-index); }
                            }
                        }
                        // Quick test of the current voice + speed.
                        HorizontalLayout {
                            alignment: start;
                            Button {
                                text: @tr("Test voice");
                                enabled: root.tts-available;
                                clicked => { root.tts-test-clicked(); }
                            }
                        }
                        }
                    }
                    if root.active-tab == 4 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Updates");
                        Text {
                            text: @tr("Check GitHub for a newer release. If one is found you can download + install it in one click (the app restarts).");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: root.update-checking
                                    ? @tr("Checking…")
                                    : @tr("Check for updates");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.check-updates-clicked();
                                }
                            }
                            // Shown only when a newer release was found.
                            if root.update-available : Button {
                                text: @tr("Update now");
                                enabled: !root.update-checking;
                                clicked => {
                                    root.install-update-clicked();
                                }
                            }
                        }
                        // Result line: "up to date" / "vX available" / errors.
                        if root.update-status != "" : Text {
                            text: root.update-status;
                            font-size: 11px;
                            color: root.update-available ? Theme.success : Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Text {
                            text: @tr("Version: {} (suflyor / Slint)", root.app-version);
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        }

                        SettingsCard {
                            title: @tr("Backup / transfer settings");
                        // Phase E6 v28 — full-profile import/export.
                        // (duplicate heading removed — the SettingsCard title already shows it)
                        Text {
                            text: @tr("Exports the WHOLE config to a .json file you choose — INCLUDING the Claude bearer + Groq API key. Keep the file private. Import overwrites current settings (restart to apply).");
                            font-size: 10px;
                            color: Theme.warning;
                            wrap: word-wrap;
                        }
                        // Stacked (not a row): the two RU labels side by side ran
                        // past the ~480px card edge. One button per row never clips.
                        VerticalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Export settings (incl. keys)…");
                                clicked => { root.export-profile-clicked(); }
                            }
                            Button {
                                text: @tr("Import settings…");
                                clicked => { root.import-profile-clicked(); }
                            }
                        }
                        // #125 / P1.7 — server-only transfer: copies just AI/STT
                        // servers, keeps local profiles/devices/UI/snippets.
                        // Import shows a redacted preview before applying.
                        Text {
                            text: @tr("Server transfer copies ONLY AI/STT providers, URLs, models and keys — local UI, profiles, devices and snippets stay unchanged. Use it to carry your server setup to another PC. Export writes those server fields (INCLUDING keys) to a .json; import shows a preview and asks you to confirm before applying.");
                            font-size: 10px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Stacked (not a row): the two long RU server labels side by
                        // side overflowed the card. One button per row never clips.
                        VerticalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Export server settings…");
                                clicked => { root.export-server-settings-clicked(); }
                            }
                            Button {
                                text: @tr("Import server settings…");
                                clicked => { root.import-server-settings-clicked(); }
                            }
                        }
                        // P1.7 — redacted import preview + explicit Apply gate.
                        if root.server-preview-ready : Rectangle {
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: #ffffff08;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                Text {
                                    text: @tr("Review changes before applying (keys shown as set/— only, never the value):");
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Theme.text-primary;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.server-preview-cloud;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.server-preview-local;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.server-preview-vision;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.server-preview-stt;
                                    font-size: 11px;
                                    color: Theme.text-primary;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: root.server-preview-gigaam;
                                    font-size: 10px;
                                    color: Theme.warning;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: start;
                                    Button {
                                        text: @tr("Apply server settings");
                                        primary: true;
                                        clicked => { root.apply-server-settings-clicked(); }
                                    }
                                    Button {
                                        text: @tr("Cancel");
                                        clicked => { root.cancel-server-settings-clicked(); }
                                    }
                                }
                            }
                        }
                        if root.profile-io-result != "" : Text {
                            text: root.profile-io-result;
                            font-size: 11px;
                            color: Theme.accent;
                            wrap: word-wrap;
                        }
                        }
                    }
                    if root.active-tab == 6 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Microphone");
                        Text {
                            text: @tr("Microphone device selection. List is live from WASAPI capture endpoints.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Phase E6 v23 — real device list from
                        // audio::list_devices().inputs, wired by Rust.
                        ComboBox {
                            model: root.mic-devices;
                            current-index <=> root.mic-device-index;
                            selected(val) => { root.mic-device-selected(val); }
                        }
                        Button {
                            text: @tr("Test microphone (3s record)");
                            clicked => { root.mic-test-clicked(); }
                        }
                        if root.mic-test-result != "" : Text {
                            text: root.mic-test-result;
                            font-size: 11px;
                            color: Theme.accent;
                            wrap: word-wrap;
                        }
                        }
                        SettingsCard {
                            title: @tr("Recording");
                        // v0.13.0 — raw session-audio recording.
                        DarkCheck {
                            text: @tr("Record session audio (mic + system)");
                            checked <=> root.record-audio;
                            toggled(v) => {
                                root.record-audio-changed(v);
                            }
                        }
                        Text {
                            text: @tr("Saved locally as separate mic + system WAVs per session — nothing is uploaded. ~230 MB/hour. Used by the archive's re-Summary.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // v0.15.0 — recordings retention policy (was a fixed
                        // "last 10 sessions"). Applied at the next session start.
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Keep recordings:");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                model: [@tr("all (no limit)"), @tr("last N sessions"), @tr("last N days")];
                                current-index <=> root.retention-mode;
                                selected(v) => {
                                    root.retention-changed(root.retention-mode, root.retention-value);
                                }
                            }
                            if root.retention-mode != 0 : LineEdit {
                                width: 64px;
                                text <=> root.retention-value;
                                edited(t) => { root.retention-changed(root.retention-mode, t); }
                                accepted(t) => { root.retention-changed(root.retention-mode, t); }
                            }
                        }
                        if root.retention-mode == 0 : Text {
                            text: @tr("Unlimited recordings can take tens of GB per month with daily calls.");
                            font-size: 11px;
                            color: Theme.warning;
                            wrap: word-wrap;
                        }
                        Button {
                            text: @tr("Open recordings folder");
                            clicked => { root.open-recordings-clicked(); }
                        }
                        }
                        SettingsCard {
                            title: @tr("Storage");
                        // v0.15.0 — journal (archive) retention: the JSONL
                        // transcripts behind the archive window. Was a hidden
                        // hard-coded 100-sessions / 500 MB bound — a 10-calls-a-day
                        // user lost archive history after ~2 weeks.
                        Text {
                            text: @tr("Session journals — the transcripts + AI answers behind the archive (F7). When the disk cap is exceeded, the oldest journals are deleted even if the count limit is not reached:");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Journals to keep (0 = unlimited):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                width: 64px;
                                text <=> root.journal-keep-value;
                                edited(t) => { root.journal-retention-changed(t, root.journal-mb-value); }
                                accepted(t) => { root.journal-retention-changed(t, root.journal-mb-value); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Journal disk cap, MB (0 = unlimited):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                width: 64px;
                                text <=> root.journal-mb-value;
                                edited(t) => { root.journal-retention-changed(root.journal-keep-value, t); }
                                accepted(t) => { root.journal-retention-changed(root.journal-keep-value, t); }
                            }
                        }
                        Text {
                            text: @tr("Retention changes apply at the next session start.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        }
                    }
                    // ===== Components (onboarding readiness hub, tab 15) =====
                    if root.active-tab == 15 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Components");
                        Text {
                            text: @tr("What's installed for offline AI — one place to see what's ready. Each piece is downloaded on demand from its own tab (shown below each item).");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        for row[idx] in root.component-rows : Rectangle {
                            background: Theme.bg-surface;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border;
                            // min-height (not fixed) so a long where-to-install
                            // hint that wraps to 2 lines grows the card instead of
                            // clipping (design review #8). Vertical padding keeps
                            // wrapped text off the borders.
                            min-height: 50px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 10px;
                                Rectangle {
                                    width: 10px;
                                    height: 10px;
                                    border-radius: 5px;
                                    y: (parent.height - self.height) / 2;
                                    background: row.installed ? Theme.success : Theme.border-strong;
                                }
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: row.name;
                                        font-size: 12px;
                                        font-weight: 600;
                                        color: Theme.text-primary;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: row.installed
                                            ? (row.detail != "" ? row.detail : @tr("installed"))
                                            : row.hint;
                                        font-size: 10px;
                                        color: Theme.text-muted;
                                        wrap: word-wrap;
                                    }
                                }
                                // Action / status (right). Install in progress for
                                // THIS row → live status; light installer not yet
                                // installed → inline «Установить»; otherwise the
                                // installed / not-installed label.
                                if idx == root.component-busy-index : Text {
                                    text: root.component-busy-status;
                                    font-size: 11px;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                }
                                if idx != root.component-busy-index && row.installable && !row.installed : VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 0;
                                    Button {
                                        text: @tr("Install");
                                        clicked => {
                                            root.component-install(idx);
                                        }
                                    }
                                }
                                // Heavy components (engine / model / STT) NOT yet
                                // installed → «Открыть» jumps to their dedicated
                                // panel where the full installer (progress + cancel)
                                // lives. Once installed they show «установлено» below.
                                if idx != root.component-busy-index
                                    && !row.installed
                                    && row.jump-tab >= 0 : VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 0;
                                    Button {
                                        text: @tr("Open");
                                        clicked => {
                                            root.active-tab = row.jump-tab;
                                            root.tab-selected(row.jump-tab);
                                        }
                                    }
                                }
                                // Anything with no pending action → status label
                                // (installed = green «установлено»; otherwise grey).
                                if idx != root.component-busy-index
                                    && !(row.installable && !row.installed)
                                    && !(row.jump-tab >= 0 && !row.installed) : Text {
                                    text: row.installed ? @tr("installed") : @tr("not installed");
                                    font-size: 11px;
                                    font-weight: 600;
                                    color: row.installed ? Theme.success : Theme.text-muted;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                }
                            }
                        }
                        }
                    }
                    if root.active-tab == 7 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Auto-tiles");
                            Text {
                                text: @tr("Auto-tile triggers — when transcript contains these keywords, spawn an answer tile automatically.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            DarkCheck {
                                text: @tr("Enable auto-tile detector");
                                checked <=> root.auto-tiles-enabled;
                                toggled(v) => {
                                    root.auto-tiles-enabled-changed(v);
                                }
                            }
                            DarkCheck {
                                text: @tr("Listening mode — don't show tiles");
                                checked <=> root.suppress-tiles;
                                toggled(v) => {
                                    root.suppress-tiles-changed(v);
                                }
                            }
                            Text {
                                text: @tr("Mutes auto-detected AI tiles so you can record and just listen. Manual asks (F6/F9), the knowledge base, and summaries still appear.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            Text {
                                text: @tr("Trigger keywords (space-separated). A sentence ending in '?' also triggers.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            TextEdit {
                                text <=> root.trigger-keywords-input;
                                wrap: word-wrap;
                                height: 150px;
                            }
                            Button {
                                text: @tr("Save keywords");
                                clicked => {
                                    root.trigger-keywords-save(root.trigger-keywords-input);
                                }
                            }
                        }
                    }
                    if root.active-tab == 9 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Knowledge base");
                            Text {
                                text: @tr("Embedded knowledge base — 1,696 entries (glossary / commands / patterns), compiled into the binary.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            // Phase E6 v29 — the in-Settings search box was a
                            // dead stub. KB search lives in the F4 palette
                            // (fully wired). Point the user there instead of
                            // shipping a non-functional second search box.
                            Text {
                                text: @tr("Press F4 anywhere to search the knowledge base and spawn a tile from any entry.");
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                        }
                    }
                    if root.active-tab == 10 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Profile + context");
                        Text {
                            text: @tr("Persistent context sent with every AI request — your role, focus areas, vocabulary. Saved to config; applied to new AI calls immediately.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Phase F — multi-profile picker. Row 1: select; row 2:
                        // add/rename/delete (split rows so the buttons never clip).
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Text {
                                text: @tr("Profile:");
                                font-size: 12px;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }
                            if root.profile-names.length > 0 : ComboBox {
                                model: root.profile-names;
                                current-index: root.active-profile-index;
                                min-width: 170px;
                                selected => {
                                    root.active-profile-index = self.current-index;
                                    root.profile-selected(self.current-index);
                                }
                            }
                            if root.profile-names.length == 0 : Text {
                                text: @tr("none yet — name one and Add");
                                font-size: 11px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                placeholder-text: @tr("profile name");
                                text <=> root.profile-name-input;
                                horizontal-stretch: 1;
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Button {
                                text: @tr("Add profile");
                                clicked => {
                                    root.profile-add(root.profile-name-input);
                                    root.profile-name-input = "";
                                }
                            }
                            Button {
                                text: @tr("Rename");
                                enabled: root.active-profile-index >= 0 && root.profile-name-input != "";
                                clicked => {
                                    root.profile-rename(root.profile-name-input);
                                    root.profile-name-input = "";
                                }
                            }
                            Button {
                                text: @tr("Delete");
                                enabled: root.active-profile-index >= 0;
                                clicked => {
                                    root.profile-delete();
                                }
                            }
                        }
                        // Phase E6 v29 — real multi-line editor wired to
                        // cfg.meeting_context (was a dead placeholder box).
                        TextEdit {
                            text <=> root.meeting-context-input;
                            wrap: word-wrap;
                            height: 220px;
                            placeholder-text: @tr("e.g. I'm a Senior SRE interviewing for a platform role. Answer concisely, prefer Kubernetes/AWS examples, Russian output.");
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            // Phase E6 v43 — voice dictation toggle.
                            Button {
                                text: root.context-dictating
                                    ? @tr("Stop recording")
                                    : @tr("Dictate");
                                clicked => { root.context-dictate-clicked(); }
                            }
                            Button {
                                text: @tr("Save context");
                                clicked => { root.meeting-context-save(root.meeting-context-input); }
                            }
                            // Phase E6 v43 — structure the context via AI.
                            Button {
                                text: root.context-processing
                                    ? @tr("Structuring…")
                                    : @tr("Structure via AI");
                                enabled: !root.context-processing;
                                clicked => { root.context-process-clicked(); }
                            }
                            if root.meeting-context-result != "" : Text {
                                text: root.meeting-context-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                        }
                        }
                    }
                    if root.active-tab == 11 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("AI bridge");
                        Text {
                            text: @tr("Where do live answers come from? Pick a type, then configure it.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // ===== TYPE selector — gates everything below =====
                        ComboBox {
                            model: [@tr("Cloud (Claude bridge)"), @tr("Local (llama.cpp / Ollama)")];
                            current-index: root.ai-provider-index;
                            selected => {
                                root.ai-provider-index = self.current-index;
                                root.ai-provider-changed(self.current-index);
                            }
                        }
                        Rectangle { background: Theme.border; height: 1px; }

                        // ============================ CLOUD ============================
                        if root.ai-provider-index == 0 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Cloud bridge");
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.text-primary;
                            }
                            Text {
                                text: @tr("Bearer token:") + " " + root.ai-bearer-status;
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("paste new bearer token then Save");
                                    text <=> root.ai-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-bearer-save(root.ai-bearer-input);
                                        root.ai-bearer-input = "";
                                    }
                                }
                            }
                            Text {
                                text: @tr("Base URL (Claude bridge endpoint):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("http://your.bridge.host:PORT/v1");
                                    text <=> root.ai-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-base-url-save(root.ai-base-url-input);
                                    }
                                }
                            }
                            Text {
                                text: @tr("AI model (Claude full ID):");
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ComboBox {
                                    model: root.ai-models;
                                    current-index: root.ai-model-index;
                                    horizontal-stretch: 1;
                                    selected => {
                                        root.ai-model-selected(self.current-value);
                                    }
                                }
                                Button {
                                    text: @tr("refresh");
                                    clicked => {
                                        root.ai-models-refresh();
                                    }
                                }
                            }
                            if root.ai-models.length == 0 : Text {
                                text: @tr("No models found — check the bridge URL/token, then press refresh.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: @tr("Test AI bridge connection");
                                    clicked => { root.ai-bridge-test-clicked(); }
                                }
                                if root.ai-bridge-test-result != "" : Text {
                                    text: root.ai-bridge-test-result;
                                    font-size: 11px;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }
                            }
                            DarkCheck {
                                text: @tr("Prompt-caching (experimental — needs bridge support)");
                                checked <=> root.ai-prompt-cache;
                                toggled(v) => { root.ai-prompt-cache-changed(v); }
                            }
                            Text {
                                text: @tr("Marks the system prompt as cacheable for faster repeat asks. If your bridge rejects it (AI stops answering), turn this back off.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                        }

                        // ============================ LOCAL ============================
                        if root.ai-provider-index == 1 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Local model");
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.text-primary;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("local URL — http://127.0.0.1:8080/v1 (llama.cpp) or :11434 (Ollama)");
                                    text <=> root.ai-local-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-local-base-url-save(root.ai-local-base-url-input);
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ComboBox {
                                    model: root.ai-local-models;
                                    current-index: root.ai-local-model-index;
                                    horizontal-stretch: 1;
                                    selected => {
                                        root.ai-local-model-selected(self.current-value);
                                    }
                                }
                                Button {
                                    text: @tr("refresh");
                                    clicked => {
                                        root.ai-local-models-refresh();
                                    }
                                }
                            }
                            if root.ai-local-models.length == 0 : Text {
                                text: @tr("No models found — start the local server, then press refresh.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("local server bearer token (optional)");
                                    text <=> root.ai-local-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button {
                                    text: @tr("Save");
                                    clicked => {
                                        root.ai-local-bearer-save(root.ai-local-bearer-input);
                                        root.ai-local-bearer-input = "";
                                    }
                                }
                            }
                            DarkCheck {
                                text: @tr("Local model supports images (vision)");
                                checked <=> root.ai-local-vision;
                                toggled(v) => {
                                    root.ai-local-vision-changed(v);
                                }
                            }
                            DarkCheck {
                                text: @tr("Local model reasoning/thinking (slower, off = faster)");
                                checked <=> root.ai-local-thinking;
                                toggled(v) => {
                                    root.ai-local-thinking-changed(v);
                                }
                            }
                            // ----- v0.18.0 — local model: faster (4B) vs smarter (12B) -----
                            Rectangle { background: Theme.border; height: 1px; }
                            Text {
                                text: @tr("Local model: speed vs quality. Switching restarts the local server (~5s).");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: root.ai-local-quality ? @tr("Faster (4B)") : @tr("● Faster (4B)");
                                    enabled: root.ai-local-quality && !root.quality-downloading && !root.model-switching && !root.local-ai-installing;
                                    clicked => {
                                        root.model-quality-changed(false);
                                    }
                                }
                                if root.quality-model-present : Button {
                                    text: root.ai-local-quality ? @tr("● Smarter (12B)") : @tr("Smarter (12B)");
                                    enabled: !root.ai-local-quality && !root.quality-downloading && !root.model-switching && !root.local-ai-installing;
                                    clicked => {
                                        root.model-quality-changed(true);
                                    }
                                }
                                if !root.quality-model-present : Button {
                                    text: root.quality-downloading ? @tr("Downloading…") : @tr("Download smart model (6 GB)");
                                    enabled: !root.quality-downloading && !root.local-ai-installing;
                                    clicked => {
                                        root.download-quality-clicked();
                                    }
                                }
                                if root.quality-downloading : Button {
                                    text: @tr("Cancel");
                                    clicked => {
                                        root.cancel-local-ai-clicked();
                                    }
                                }
                            }
                            Text {
                                text: @tr("The 12B model is noticeably smarter but ~2× slower and needs ~10 GB of video memory (VRAM). On a weaker GPU keep 4B.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            if root.quality-status != "" : Text {
                                text: root.quality-status;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                            if root.quality-downloading : Rectangle {
                                height: 6px;
                                border-radius: 3px;
                                background: Theme.border;
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    height: parent.height;
                                    width: parent.width * root.quality-progress;
                                    border-radius: 3px;
                                    background: Theme.accent;
                                }
                            }
                            // ----- v0.18.2 — 12B vision (its own gemma4uv projector) -----
                            if root.quality-model-present && root.quality-vision-supported && root.quality-vision-present : Text {
                                text: @tr("12B vision projector installed — used when the 12B is the active model.");
                                font-size: 11px;
                                color: Theme.success;
                                wrap: word-wrap;
                            }
                            if root.quality-model-present && root.quality-vision-supported && !root.quality-vision-present : HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: root.vision12b-downloading ? @tr("Downloading…") : @tr("Enable vision on 12B — download projector (175 MB)");
                                    enabled: !root.vision12b-downloading && !root.quality-downloading && !root.model-switching && !root.local-ai-installing && !root.engine-updating;
                                    clicked => {
                                        root.download-vision12b-clicked();
                                    }
                                }
                                if root.vision12b-downloading : Button {
                                    text: @tr("Cancel");
                                    clicked => {
                                        root.cancel-local-ai-clicked();
                                    }
                                }
                            }
                            if root.quality-model-present && !root.quality-vision-supported : Text {
                                text: @tr("12B vision needs a newer engine — use Update engine below.");
                                font-size: 11px;
                                color: Theme.warning;
                                wrap: word-wrap;
                            }
                            if root.vision12b-status != "" : Text {
                                text: root.vision12b-status;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: @tr("Test local connection");
                                    clicked => {
                                        root.ai-local-test-clicked();
                                    }
                                }
                            }
                            // UI-audit 2026-06-13: the test result is its OWN
                            // row with word-wrap — inside the HorizontalLayout
                            // above (no wrap) a long error (e.g. the raw 503
                            // "Loading model" body) stretched the whole window.
                            if root.ai-local-test-result != "" : Text {
                                text: root.ai-local-test-result;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                            // ----- one-click in-app local-AI installer -----
                            Rectangle { background: Theme.border; height: 1px; }
                            Text {
                                text: @tr("Installs the local stack on this PC (~6 GB total): llama.cpp + Gemma-4-E4B (~5 GB; needs ~6 GB VRAM on GPU), whisper.cpp + Whisper-turbo (~0.9 GB), GigaAM-v3 (~0.2 GB). With NVIDIA it picks the CUDA build, otherwise CPU. Models you already have are reused, not re-downloaded.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: root.local-ai-installing ? @tr("Installing…") : @tr("Install local AI");
                                    enabled: !root.local-ai-installing && !root.quality-downloading && !root.model-switching && !root.engine-updating && !root.vision12b-downloading;
                                    clicked => {
                                        root.install-local-ai-clicked();
                                    }
                                }
                                if root.local-ai-installing : Button {
                                    text: @tr("Cancel");
                                    clicked => {
                                        root.cancel-local-ai-clicked();
                                    }
                                }
                                if root.local-ai-gpu != "" : Text {
                                    text: root.local-ai-gpu;
                                    font-size: 11px;
                                    color: root.local-ai-on-gpu ? Theme.success : Theme.warning;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                            }
                            if root.local-ai-status != "" : Text {
                                text: root.local-ai-status;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                            if root.local-ai-installing : Rectangle {
                                height: 6px;
                                border-radius: 3px;
                                background: Theme.border;
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    height: parent.height;
                                    width: parent.width * root.local-ai-progress;
                                    border-radius: 3px;
                                    background: Theme.accent;
                                }
                            }
                            // ----- v0.18.2 — llama.cpp engine auto-update -----
                            Rectangle { background: Theme.border; height: 1px; }
                            Text {
                                text: @tr("Engine (llama.cpp). The app keeps it up to date automatically (checked weekly) so the local model stays fast and 12B vision works. A new build is verified to run before it replaces the current one.");
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Button {
                                    text: root.engine-updating ? @tr("Updating…") : @tr("Update engine");
                                    enabled: !root.engine-updating && !root.local-ai-installing && !root.quality-downloading && !root.model-switching && !root.vision12b-downloading;
                                    clicked => {
                                        root.update-engine-clicked();
                                    }
                                }
                                if root.engine-build != "" : Text {
                                    text: @tr("Installed: {}", root.engine-build);
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                }
                            }
                            if root.engine-update-status != "" : Text {
                                text: root.engine-update-status;
                                font-size: 11px;
                                color: Theme.accent;
                                wrap: word-wrap;
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }
                        // Text OUTER + TouchArea INNER: a TouchArea is NOT a layout
                        // and doesn't constrain its child's width, so the old
                        // TouchArea>Text rendered this hint on ONE line that ran off
                        // the card edge (clipped — "…перезагрузк"). With the Text
                        // outer, the card's VerticalLayout constrains its width and
                        // word-wrap finally kicks in.
                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\suflyor\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: Theme.accent;
                            wrap: word-wrap;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-data-folder-clicked(); }
                            }
                        }

                        // ===================== VISION (screenshots · F8) =====================
                        Rectangle { background: Theme.border; height: 2px; }
                        Text {
                            text: @tr("Vision (screenshots · F8)");
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        Text {
                            text: @tr("Where F8 screenshots are analysed. SEPARATE from the text model above — a local text model can keep answering while images go to a vision-capable model.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // Local OCR engine (Tesseract) for Shift+Alt+2 / Ctrl+F8
                        // text recognition. Installed on demand (~53 MB), not
                        // bundled in the app installer.
                        Text {
                            text: @tr("Text recognition (OCR) — Shift+Alt+2 reads on-screen text aloud / copies it via a local engine. Without it, OCR falls back to the slower vision model.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        if !root.ocr-installed : HorizontalLayout {
                            alignment: start;
                            Button {
                                text: root.ocr-installing ? @tr("Installing…") : @tr("Install text recognition (OCR)");
                                enabled: !root.ocr-installing;
                                clicked => { root.ocr-install-clicked(); }
                            }
                        }
                        if root.ocr-installed && root.ocr-install-status == "" : Text {
                            text: @tr("Text recognition is installed.");
                            font-size: 11px;
                            color: Theme.text-secondary;
                        }
                        if root.ocr-install-status != "" : Text {
                            text: root.ocr-install-status;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                        }
                        Rectangle { background: Theme.border; height: 1px; }
                        ComboBox {
                            model: [@tr("Off"), @tr("Same as text model above"), @tr("Cloud (Sonnet via bridge)"), @tr("Local (2nd vision server)")];
                            current-index: root.vision-provider-index;
                            selected => {
                                root.vision-provider-index = self.current-index;
                                root.vision-provider-changed(self.current-index);
                            }
                        }
                        if root.vision-provider-index == 2 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("Screenshots are sent to the cloud. Leave a field blank to reuse the text bridge's value.");
                                font-size: 10px;
                                color: Theme.warning;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision base URL (blank = text bridge)");
                                    text <=> root.vision-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-base-url-save(root.vision-base-url-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision bearer (blank = text bridge)");
                                    text <=> root.vision-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-bearer-save(root.vision-bearer-input); root.vision-bearer-input = ""; } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision model (blank = claude-sonnet-4-6)");
                                    text <=> root.vision-model-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-model-save(root.vision-model-input); } }
                            }
                        }
                        if root.vision-provider-index == 3 : VerticalLayout {
                            spacing: 8px;
                            Text {
                                text: @tr("A 2nd local OpenAI-compatible server running a vision model (e.g. Qwen2-VL). Blank = reuse the text-local server.");
                                font-size: 10px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local URL — http://127.0.0.1:8082/v1");
                                    text <=> root.vision-local-base-url-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-base-url-save(root.vision-local-base-url-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local model id");
                                    text <=> root.vision-local-model-input;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-model-save(root.vision-local-model-input); } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: @tr("vision local bearer (optional)");
                                    text <=> root.vision-local-bearer-input;
                                    input-type: password;
                                    horizontal-stretch: 1;
                                }
                                Button { text: @tr("Save"); clicked => { root.vision-local-bearer-save(root.vision-local-bearer-input); root.vision-local-bearer-input = ""; } }
                            }
                        }
                        if root.vision-provider-index >= 2 : HorizontalLayout {
                            spacing: 6px;
                            Button { text: @tr("Test vision connection"); clicked => { root.vision-test-clicked(); } }
                            if root.vision-test-result != "" : Text {
                                text: root.vision-test-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }
                        // v0.11.0 — Test Practice mode for plain F8 (study / self-check):
                        // answer + a short explanation from a screenshot of a PRACTICE
                        // question. For studying, NOT graded exams. Shown when vision is on.
                        if root.vision-provider-index >= 1 : DarkCheck {
                            text: @tr("F8 → Test Practice: answer + short explanation (for practice & self-check)");
                            checked <=> root.vision-test-practice;
                            toggled(v) => {
                                root.vision-test-practice-changed(v);
                            }
                        }
                        // Feature #4 — phonetics in TRANSLATE mode (F8 toggle / Shift+F8).
                        // Shown whenever vision is enabled (any provider).
                        if root.vision-provider-index >= 1 : DarkCheck {
                            text: @tr("Phonetics in F8 translate mode (IPA, e.g. schedule [ˈʃedjuːl])");
                            checked <=> root.vision-phonetics;
                            toggled(v) => {
                                root.vision-phonetics-changed(v);
                            }
                        }
                        }
                    }
                    if root.active-tab == 12 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("STT");

                        // ===== STT engine (Phase E10) =====
                        Text {
                            text: @tr("Speech-to-text engine. Local options run on this PC (no cloud, no Groq key needed).");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Cloud (Groq Whisper)"), @tr("Local GigaAM-v3 (Russian)"), @tr("Local Whisper (whisper.cpp)")];
                            current-index: root.stt-provider-index;
                            selected => {
                                // Write the index back so the conditional engine
                                // fields (GigaAM dir / whisper-server URL) render
                                // immediately on selection instead of only after
                                // re-opening Settings.
                                root.stt-provider-index = self.current-index;
                                root.stt-provider-changed(self.current-index);
                            }
                        }
                        // Recognition language (stt_language) — what the mic is
                        // transcribed as, by default.
                        Text {
                            text: @tr("Recognition language — Auto detects per phrase (Whisper/Groq). GigaAM is Russian-only.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: [@tr("Auto-detect"), @tr("Russian"), @tr("English")];
                            current-index: root.stt-language-index;
                            selected => {
                                root.stt-language-index = self.current-index;
                                root.stt-language-changed(self.current-index);
                            }
                        }
                        if root.stt-provider-index == 1 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("GigaAM model dir — folder with model.int8.onnx + vocab.txt");
                                text <=> root.stt-gigaam-dir-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-gigaam-dir-save(root.stt-gigaam-dir-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 1 : DarkCheck {
                            text: @tr("Use GPU (DirectML) — faster on long audio, ~1s warm-up on first use");
                            checked <=> root.stt-gigaam-gpu;
                            toggled(v) => {
                                root.stt-gigaam-gpu-changed(v);
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server URL — http://127.0.0.1:8081/v1");
                                text <=> root.stt-whisper-url-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-url-save(root.stt-whisper-url-input);
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper-server bearer token (optional)");
                                input-type: password;
                                text <=> root.stt-whisper-bearer-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-bearer-save(root.stt-whisper-bearer-input);
                                    // Clear the secret from the field after Save
                                    // (matches ai-bearer / groq / local-bearer).
                                    root.stt-whisper-bearer-input = "";
                                }
                            }
                        }
                        if root.stt-provider-index == 2 : HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("whisper model — e.g. whisper-large-v3-turbo");
                                text <=> root.stt-whisper-model-input;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.stt-whisper-model-save(root.stt-whisper-model-input);
                                }
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }

                        Text {
                            text: @tr("Groq STT (Whisper) — API key + model. Used only when the engine above is Cloud.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }

                        // ----- groq_api_key -----
                        Text {
                            text: @tr("Groq API key:") + " " + root.groq-api-key-status;
                            font-size: 11px;
                            color: Theme.text-secondary;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            LineEdit {
                                placeholder-text: @tr("paste new Groq key then Save");
                                text <=> root.groq-api-key-input;
                                input-type: password;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("Save");
                                clicked => {
                                    root.groq-api-key-save(root.groq-api-key-input);
                                    root.groq-api-key-input = "";
                                }
                            }
                        }

                        Rectangle { background: Theme.border; height: 1px; }

                        // ----- Connection test (Phase E6 v27) -----
                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: @tr("Test STT connection");
                                clicked => { root.stt-test-clicked(); }
                            }
                            if root.stt-test-result != "" : Text {
                                text: root.stt-test-result;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }

                        // Text OUTER + TouchArea INNER: a TouchArea is NOT a layout
                        // and doesn't constrain its child's width, so the old
                        // TouchArea>Text rendered this hint on ONE line that ran off
                        // the card edge (clipped — "…перезагрузк"). With the Text
                        // outer, the card's VerticalLayout constrains its width and
                        // word-wrap finally kicks in.
                        Text {
                            text: @tr("Tip: Save writes to %APPDATA%\\suflyor\\config.json. Restart binary to re-load.");
                            font-size: 10px;
                            color: Theme.accent;
                            wrap: word-wrap;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-data-folder-clicked(); }
                            }
                        }
                        }
                    }

                    // Phase 3b.3 — 💭 Memory: review curated personal memory.
                    if root.active-tab == 14 : VerticalLayout {
                        spacing: 10px;
                        SettingsCard {
                            title: @tr("Personal memory");
                        Text {
                            text: @tr("Personal memory: approve useful fragments from your sessions. Only APPROVED items are mixed into new AI requests. Stored locally; nothing leaves your machine.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        // v0.16.0 — personal knowledge base: add your own fact
                        // (internal project, term, names). Lands directly in the
                        // approved list below.
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                placeholder-text: @tr("Your fact: project, term, names…");
                                text <=> root.memory-add-text;
                                horizontal-stretch: 1;
                                accepted(t) => { root.memory-add-fact(t); }
                            }
                            Button {
                                text: @tr("Add");
                                clicked => { root.memory-add-fact(root.memory-add-text); }
                            }
                        }
                        Text {
                            text: @tr("Facts also reach the meeting Summary — but only when their terms come up in the conversation.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: @tr("Extract from recent sessions");
                                clicked => { root.memory-extract(); }
                            }
                            if root.memory-status != "" : Text {
                                text: root.memory-status;
                                font-size: 11px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: @tr("Suggestions ({})", root.memory-candidates.length);
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        if root.memory-candidates.length == 0 : Text {
                            text: @tr("No suggestions yet — click Extract after a session.");
                            font-size: 11px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        for c in root.memory-candidates : Rectangle {
                            background: Theme.bg-elevated;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: c.kind + "  " + c.reason;
                                        font-size: 10px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    Button {
                                        text: @tr("Approve");
                                        clicked => { root.memory-approve(c.id); }
                                    }
                                    Button {
                                        text: @tr("Reject");
                                        clicked => { root.memory-reject(c.id); }
                                    }
                                }
                                Text {
                                    text: c.text;
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        Text {
                            text: @tr("Approved memory ({})", root.memory-items.length);
                            font-size: 12px;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }
                        if root.memory-items.length == 0 : Text {
                            text: @tr("No approved memory yet.");
                            font-size: 11px;
                            color: Theme.text-muted;
                        }
                        for m in root.memory-items : Rectangle {
                            background: Theme.bg-elevated;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border;
                            HorizontalLayout {
                                padding: 8px;
                                spacing: 6px;
                                Text {
                                    text: m.kind + "  " + m.text;
                                    font-size: 11px;
                                    color: Theme.text-secondary;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Button {
                                    text: @tr("Delete");
                                    clicked => { root.memory-delete-item(m.id); }
                                }
                            }
                        }
                        }
                    }

                    // Phase E6 v18 — push tab content to TOP of viewport.
                    // Without this, ScrollView lets the VerticalLayout
                    // stretch to fill height, leaving small tabs (Stealth,
                    // Coaching) with their content visually centered/
                    // bottomed instead of starting at the header.
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }
        } // HorizontalLayout

        // Frameless-window close at the TOP-RIGHT corner — mirrors the corner X
        // in every other window (tile / archive / help / …). Declared AFTER the
        // HorizontalLayout so it floats on top; inset 12px to clear the 12px
        // rounded corner. The familiar labelled "Close" at the bottom of the nav
        // stays too — the tester is used to it, so both close affordances coexist.
        CloseButton {
            x: parent.width - self.width - 12px;
            y: 12px;
            clicked => { root.close-clicked(); }
        }
    } // rounded root Rectangle

    pure function tab-name-for(idx: int) -> string {
        return idx == 15 ? @tr("Components") :
               idx == 0 ? @tr("Stealth") :
               idx == 1 ? @tr("Coaching") :
               idx == 2 ? @tr("Hotkeys") :
               idx == 3 ? @tr("Interface") :
               idx == 4 ? @tr("Updates") :
               idx == 5 ? @tr("TTS") :
               idx == 6 ? @tr("Audio") :
               idx == 7 ? @tr("Auto-tiles") :
               idx == 9 ? @tr("Knowledge base") :
               idx == 10 ? @tr("Profile + context") :
               idx == 11 ? @tr("AI bridge") :
               idx == 12 ? @tr("STT") :
               idx == 13 ? @tr("Diagnostics") :
               idx == 14 ? @tr("Memory") :
               "—";
    }
}
