// Phase 2 — Tabbed Settings window.
//
// Custom tab bar + content area: TabWidget std-widget exists but its
// styling clashes with our dark theme, and we want fine-grained
// control of per-tab content rendering for the migration. Tabs are
// indexed 0-12, each a stub for the corresponding React Settings
// panel from the migration plan order:
//
//   0  Stealth          (single toggle — sanity check)
//   1  Coaching         (toggle + numeric input)
//   2  Hotkeys          (table view, no edits)
//   3  Interface        (language switcher → wires gettext)
//   4  Updates          (external URL + diagnostic dump)
//   5  Stats            (read-only dashboard with bars)
//   6  Audio            (device dropdown + level meter + test)
//   7  Auto-tiles       (toggle + chip cloud editor)
//   8  Snippets         (CRUD modal)
//   9  Knowledge base   (search + entry preview)
//  10  Profile+context  (multi-text-field with import/export)
//  11  AI bridge        (probe button + cost cap input)
//  12  STT              (model dropdown + Whisper prompt editor)
//
// Phase 2.x ports each tab one at a time from the React Settings
// panels. Day 2 stub (the original two cross-window toggles) now
// lives inside tab 0 (Stealth).

import { Button, CheckBox, LineEdit, ScrollView, SpinBox, ComboBox } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    title: "overlay-mvp settings (Slint)";
    preferred-width: 720px;
    preferred-height: 480px;
    min-width: 480px;
    min-height: 320px;
    background: #14161e;

    in-out property <int> active-tab: 0;
    // Persisted cross-window toggles (driven by overlay-host).
    in-out property <bool> always-on-top-toggle: true;
    in-out property <bool> stealth-toggle: false;

    callback always-on-top-changed(bool);
    callback stealth-changed(bool);
    callback close-clicked();
    callback tab-selected(int);

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // ----- Sidebar tab list -----
        Rectangle {
            width: 200px;
            background: #0d0f15;
            border-color: #2a2c3a;
            border-width: 0px;

            VerticalLayout {
                padding: 8px;
                spacing: 2px;

                Text {
                    text: "Settings";
                    font-size: 14px;
                    font-weight: 700;
                    color: #e8e8ec;
                    horizontal-alignment: left;
                }
                Rectangle { background: #2a2c3a; height: 1px; }

                for entry[i] in [
                    "🎯 Stealth",
                    "🎯 Coaching",
                    "⌨ Hotkeys",
                    "🌐 Interface",
                    "⬆ Updates",
                    "📊 Stats",
                    "🎤 Audio",
                    "🪟 Auto-tiles",
                    "✂ Snippets",
                    "📚 Knowledge base",
                    "👤 Profile + context",
                    "🧠 AI bridge",
                    "🗣 STT",
                ] : Rectangle {
                    height: 28px;
                    background: i == root.active-tab ? #2a2c3a : transparent;
                    border-radius: 4px;
                    HorizontalLayout {
                        padding-left: 8px;
                        Text {
                            text: entry;
                            font-size: 12px;
                            color: i == root.active-tab ? #6cf : #c8c8cc;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            root.active-tab = i;
                            root.tab-selected(i);
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; }
                Button {
                    text: "✕ Close";
                    clicked => { root.close-clicked(); }
                }
            }
        }

        // ----- Content area -----
        Rectangle {
            horizontal-stretch: 1;
            background: #14161e;
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    // Header
                    Text {
                        text: tab-name-for(root.active-tab);
                        font-size: 18px;
                        font-weight: 700;
                        color: #e8e8ec;
                    }
                    Rectangle { background: #2a2c3a; height: 1px; }

                    // Tab content
                    if root.active-tab == 0 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Stealth mode hides the overlay window from screen capture (Print Screen, Teams/Meet, OBS). Uses WDA_EXCLUDEFROMCAPTURE on Windows 10/11.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        CheckBox {
                            text: "Always on top (HWND_TOPMOST)";
                            checked <=> root.always-on-top-toggle;
                            toggled => { root.always-on-top-changed(self.checked); }
                        }
                        CheckBox {
                            text: "Stealth (hide from screen capture)";
                            checked <=> root.stealth-toggle;
                            toggled => { root.stealth-changed(self.checked); }
                        }
                    }
                    if root.active-tab == 1 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Post-meeting debrief: AI critique of pacing, filler density, key points. Opt-in.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        CheckBox { text: "Enable post-meeting debrief"; }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Min session seconds:";
                                font-size: 11px;
                                color: #c8c8cc;
                                vertical-alignment: center;
                            }
                            SpinBox { minimum: 30; maximum: 3600; value: 60; }
                        }
                    }
                    if root.active-tab == 2 : VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "Global hotkeys (read-only — wire to RegisterHotKey in Phase 2.3):";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        Rectangle { background: #2a2c3a; height: 1px; }
                        for entry in [
                            ["F1",  "Toggle hotkey-hint popover"],
                            ["F2",  "Cycle context profile"],
                            ["F3",  "Ask the AI now"],
                            ["F4",  "Open KB palette"],
                            ["F7",  "Bulk collapse/expand all tiles"],
                            ["F8",  "Push-to-talk (hold)"],
                            ["F9",  "Reload last tile"],
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 12px;
                            Text {
                                text: entry[0];
                                font-size: 11px;
                                font-weight: 700;
                                color: #6cf;
                                width: 40px;
                            }
                            Text {
                                text: entry[1];
                                font-size: 11px;
                                color: #c8c8cc;
                            }
                        }
                    }
                    if root.active-tab == 3 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Interface language. Wires gettext for all UI strings (Phase 6).";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Language:";
                                font-size: 11px;
                                color: #c8c8cc;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                model: ["Русский", "English"];
                                current-index: 0;
                            }
                        }
                    }
                    if root.active-tab == 4 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Check for updates and view diagnostic info.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        Button { text: "Check for updates"; }
                        Button { text: "Save diagnostic dump"; }
                        Text {
                            text: "Version: 0.2.0-slint-pre (slint-experiment branch)";
                            font-size: 10px;
                            color: #666;
                        }
                    }
                    if root.active-tab == 5 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Session stats aggregated across all journals.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        for line in [
                            "Sessions logged:        112",
                            "Total session time:     14h 22m",
                            "AI requests:            1,847",
                            "AI errors:              23 (1.2%)",
                            "Tiles spawned:          612",
                            "Total cost:             $1.84",
                        ] : Text {
                            text: line;
                            font-size: 11px;
                            color: #c8c8cc;
                            font-family: "Consolas";
                        }
                    }
                    if root.active-tab == 6 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Microphone + system audio device selection. Phase 2.7 ports the WASAPI device enumeration + level meter from Audio.tsx.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: ["Default microphone", "USB Mic", "Bluetooth headset"];
                            current-index: 0;
                        }
                        Button { text: "Test microphone (3s record)"; }
                    }
                    if root.active-tab == 7 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Auto-tile triggers — when transcript contains these keywords, spawn an answer tile automatically.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        CheckBox { text: "Enable auto-tile detector"; checked: true; }
                        LineEdit { placeholder-text: "Add keyword..."; }
                    }
                    if root.active-tab == 8 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Custom snippets — invoke via /key in F4 palette to spawn a tile with the snippet body.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        for snip in [
                            ["k8s",       "Kubernetes orchestrator notes"],
                            ["postgres",  "PG cheatsheet"],
                            ["docker",    "Docker reference"],
                        ] : HorizontalLayout {
                            padding: 4px;
                            spacing: 8px;
                            Text {
                                text: "/" + snip[0];
                                font-size: 11px;
                                font-weight: 700;
                                color: #6cf;
                                width: 80px;
                            }
                            Text {
                                text: snip[1];
                                font-size: 11px;
                                color: #c8c8cc;
                            }
                        }
                        Button { text: "+ Add snippet"; }
                    }
                    if root.active-tab == 9 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Embedded knowledge base (1,696 entries: ~53 snippets + 1,643 KB entries across glossary/commands/patterns).";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        LineEdit { placeholder-text: "Search the KB..."; }
                    }
                    if root.active-tab == 10 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Persistent context shared with every AI request — your role, focus areas, vocabulary. Up to 8 KB.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        Rectangle {
                            background: #0d0f15;
                            border-color: #2a2c3a;
                            border-width: 1px;
                            border-radius: 4px;
                            height: 120px;
                            Text {
                                text: "(profile text — multi-line input editor)";
                                color: #666;
                                font-size: 11px;
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Button { text: "Import"; }
                            Button { text: "Export"; }
                        }
                    }
                    if root.active-tab == 11 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Claude AI bridge — bearer token + cost cap. Probe button validates connectivity.";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        LineEdit {
                            placeholder-text: "AI bearer token (masked when set)";
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Session cost cap ($):";
                                font-size: 11px;
                                color: #c8c8cc;
                                vertical-alignment: center;
                            }
                            SpinBox { minimum: 0; maximum: 100; value: 5; }
                        }
                        Button { text: "Probe Claude"; }
                    }
                    if root.active-tab == 12 : VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "Groq STT (Whisper) settings — model + custom Whisper prompt (improves transcription on domain vocabulary).";
                            font-size: 11px;
                            color: #999;
                            wrap: word-wrap;
                        }
                        ComboBox {
                            model: ["whisper-large-v3", "whisper-large-v3-turbo"];
                            current-index: 1;
                        }
                        LineEdit { placeholder-text: "Custom Whisper prompt (domain vocab)..."; }
                    }
                }
            }
        }
    }

    pure function tab-name-for(idx: int) -> string {
        return idx == 0 ? "Stealth" :
               idx == 1 ? "Coaching" :
               idx == 2 ? "Hotkeys" :
               idx == 3 ? "Interface" :
               idx == 4 ? "Updates" :
               idx == 5 ? "Stats" :
               idx == 6 ? "Audio" :
               idx == 7 ? "Auto-tiles" :
               idx == 8 ? "Snippets" :
               idx == 9 ? "Knowledge base" :
               idx == 10 ? "Profile + context" :
               idx == 11 ? "AI bridge" :
               idx == 12 ? "STT" :
               "—";
    }
}
