// Phase 4 — Tile window with markdown body.
//
// Uses the same MarkdownBlock struct as markdown_spike.slint (single
// definition in this file; spike imports from here). Rust side parses
// CommonMark via slint_replay::markdown::parse() and pushes the
// resulting Vec<Block> into the `blocks` property.

import { Button, LineEdit, ScrollView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton, SelectableText } from "controls.slint";

// MarkdownBlock is shared with markdown_spike — defined here in the
// canonical location and re-exported through index.slint.
export struct MarkdownBlock {
    kind: int,
    text: string,
    lang: string,
    // A2 (ТЗ 2026-07-02) — quiet per-block mark for «⭐ В память»; toggled via Rust
    // (toggle-block-marked), reset with the model on each stream re-render.
    marked: bool,
}

// A2 (ТЗ 2026-07-02) — the quiet «⭐ В память» mark: a MUTED outline star (SVG so it
// colorizes — the U+2B50 emoji the tester found "too bright" cannot). Accent + full
// opacity when marked; muted + dim (0.35) at rest; full on hover. Click toggles.
component StarMark inherits Rectangle {
    in property <bool> marked;
    // P5: carries whether SHIFT was held, for range-marking. `clicked` gives no modifiers, so latch
    // the shift state on pointer-DOWN and fire it on `clicked` — this keeps proper click semantics
    // (fires only on down+up BOTH in-area; a drag-release-outside or a cancel does NOT toggle).
    callback clicked(bool /* shift */);
    width: 20px;
    ta := TouchArea {
        property <bool> shift-latched;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                self.shift-latched = e.modifiers.shift;
            }
        }
        clicked => { root.clicked(self.shift-latched); }
    }
    Image {
        source: @image-url("../assets/icons/star.svg");
        colorize: root.marked ? Theme.accent : Theme.text-muted;
        opacity: root.marked ? 1.0 : (ta.has-hover ? 1.0 : 0.35);
        width: 13px;
        height: 13px;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

// `SelectableText` (ТЗ 2026-07-03) now lives in controls.slint — shared with the
// transcript viewer (imported below).

// One row in a tile's «⋯» overflow popup — icon + label, hover-highlighted.
component TileMenuRow inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();
    height: 30px;
    border-radius: 6px;
    background: rowta.has-hover ? Theme.bg-elevated : transparent;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 12px;
        spacing: 8px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            Image {
                source: root.icon;
                colorize: Theme.text-secondary;
                width: 14px;
                height: 14px;
                image-fit: contain;
            }
        }
        Text {
            text: root.label;
            font-size: 11px;
            color: Theme.text-secondary;
            vertical-alignment: center;
        }
    }
    rowta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component TileWindow inherits Window {
    // Phase 4 — keep std-widgets (follow-up LineEdit, ScrollView) dark with
    // the active scheme instead of Slint's light fluent default.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    title: "tile";
    icon: @image-url("../assets/icon.svg");
    background: transparent;
    no-frame: true;
    always-on-top: true;
    preferred-width: 460px;
    preferred-height: 360px;
    // 360 (was 320): the header's fixed-width control cluster (copy/more/speak/maximize/close)
    // + a capped source-label must fit so Close never clips even at the narrowest size.
    min-width: 360px;
    min-height: 200px;

    in-out property <string> tile-title: "Untitled tile";
    in-out property <int> sequence: 0;
    in-out property <[MarkdownBlock]> blocks: [];
    // Source label shown in chrome row (e.g. "ai", "kb", "snippet").
    in-out property <string> source-label: "—";
    // Phase E6 v12 — trigger badge.
    in-out property <string> trigger-label: "";
    in-out property <color> trigger-color: Theme.accent;
    // Phase E6 v17 — pinned bool: changes pin button visual; Rust
    // toggles on click. Maximize bool: Rust resizes window via Win32.
    in-out property <bool> pinned: false;
    in-out property <bool> maximized: false;
    // Phase E6 v20 — body opacity (0.5..1.0). Lets the user see
    // through tiles to the meeting window underneath. Wired to
    // cfg.tile_body_opacity via Settings → Stealth slider.
    // Cherry-picked from Anthropic design bundle 2 (only this prop;
    // no other design changes — see chat thread cycle 26).
    in-out property <float> body-opacity: 1.0;
    // Phase E6 v45 (continue-dialog) — conversation key for this tile.
    // >= 0 means the tile supports follow-up questions (the input row at
    // the bottom is shown). -1 = no dialog (KB / snippet / auto tiles).
    in-out property <int> convo-id: -1;
    // Synchronous per-tile id (set at creation) — the abort-registry key, so a
    // closed/evicted tile can cancel its in-flight AI request even before its
    // HWND is realized (the HWND grab is deferred, which is why keying on it
    // silently lost the registration and aborts missed under spam).
    in-out property <int> tile-id: -1;
    // True while an answer is streaming — disables the follow-up input.
    in-out property <bool> followup-busy: false;
    // V5 — true while the 🎤 voice follow-up is recording the mic (toggles the
    // send-row glyph to ⏹). Driven from Rust (wire_voice_followup).
    in-out property <bool> voice-recording: false;
    // V5 — show the 🔄 regenerate button (vision tiles: re-run the screenshot
    // query for a longer / different answer).
    in-out property <bool> can-regenerate: false;
    // V0.8.0 (Поток D) — show the 🧠 "ask the smart cloud model" button. Re-runs
    // the same question on the cloud model (deeper reasoning) when the local
    // answer was too weak — one-shot, without changing the default provider.
    in-out property <bool> can-escalate: false;
    // V0.8.3 — copy the answer to the clipboard. `can-copy` shows the button
    // (set on conversational tiles); `copied` briefly flips to a check icon.
    in-out property <bool> can-copy: false;
    in-out property <bool> copied: false;
    // C (ТЗ 2026-07-02) — per-code-block copy: index of the code block whose 📋
    // just fired (its icon flips to a check for ~1.5s); -1 = none. Rust-driven,
    // mirroring `copied` above.
    in-out property <int> copied-block-index: -1;
    // A2 (ТЗ 2026-07-02, редизайн) — «⭐ В память»: quiet per-block MARK (toggle),
    // then one bottom «В память (N)» panel. marked-count = how many blocks are marked
    // (Rust-maintained); capture-text = the edit buffer shown only when exactly one is
    // marked (trim-before-save). Each block carries its own `marked`.
    in-out property <int> marked-count: 0;
    // P5: last plain-clicked block index — the anchor a SHIFT+click range-marks up to. A Slint prop
    // (not Rust-only state) so `changed blocks` resets it WITH the marks below — a streaming model
    // swap then can't leave a stale anchor that mis-marks a range on the fresh answer.
    in-out property <int> mark-anchor: -1;
    in-out property <string> capture-text: "";
    // Which single block `capture-text` was seeded from (-1 = none). Lets an
    // in-progress edit survive marking/un-marking OTHER blocks — Rust re-seeds only
    // when the sole-marked block actually changes (review I-1).
    in-out property <int> capture-block-index: -1;
    // P5 (ТЗ 2026-07-03): the bool is whether SHIFT was held. Shift+click range-marks from the
    // last plain-clicked anchor to this block; a plain click toggles + re-anchors. The range/anchor
    // logic lives in Rust (it owns the blocks model) — this just forwards the modifier.
    callback toggle-block-marked(int, bool);
    callback save-marked();
    callback clear-marks();
    // P5 — «Копировать» on the mark bar: copy every marked block's text to the clipboard (marks stay).
    callback copy-marked();
    // ТЗ 2026-07-03 — mouse-selection capture: a right-click «Add selection to memory»
    // on any block raises `capture-pending` and seeds `capture-text` with the selected
    // span (Rust slices block.text by the selection's byte offsets) → the bottom editor
    // bar opens for trim-before-save, independent of the per-block ⭐ marks.
    in-out property <bool> capture-pending: false;
    // (block-index, anchor-byte-offset, cursor-byte-offset) of the right-click selection.
    callback capture-selection(int, int, int);
    // Save the pending selection (edited `capture-text`) as one approved note; discard it.
    callback save-capture();
    callback cancel-capture();
    // R1 (retest v0.28.0) — «Выделить текст» mode restored: swaps the per-block body for ONE
    // SelectableText holding the whole (joined, capped) answer, so text can be dragged / copied /
    // ⭐-captured ACROSS blocks (per-block TextInputs are separate selection islands — Slint can't
    // span them). `select-text` is built in Rust. The overflow that got it deleted was the
    // ContextMenuArea-collapse paint bug, since fixed in SelectableText (Rectangle root).
    in-out property <bool> select-mode: false;
    in-out property <string> select-text: "";
    callback toggle-select-mode();
    // Stale-marker guard: streaming re-renders REPLACE the blocks model on every delta
    // (fresh blocks come with marked=false), so clear the copied-check AND the
    // marked-count on any model swap. A settled answer fires no further set_blocks.
    changed blocks => { root.copied-block-index = -1; root.marked-count = 0; root.mark-anchor = -1; root.capture-block-index = -1; root.capture-text = ""; root.capture-pending = false; root.select-mode = false; }
    // v0.18.6 — «Повторить»: shown on a summary-failure tile that carries a
    // session id. Resumes the summary from the persisted conspect (re-maps only
    // the failed parts, then re-runs the reduce) — see retry_meeting_summary.
    in-out property <bool> can-retry: false;
    // Read-aloud (TTS): show the speaker + pause/resume controls on a tile whose
    // text can be spoken (OCR / answer / summary). `speak-paused` flips the
    // second button's icon between pause (playing) and play (paused).
    in-out property <bool> can-speak: false;
    in-out property <bool> speak-paused: false;
    // Bound to the follow-up LineEdit so do-submit() can read + clear it.
    in-out property <string> followup-text;

    callback close-clicked();
    callback pin-clicked();
    callback maximize-clicked();
    // V5 — re-run the last request and replace the answer (item 4).
    callback regenerate-clicked();
    // V0.8.0 (Поток D) — re-run the same question on the smart cloud model.
    callback escalate-clicked();
    // V0.8.3 — copy the answer text to the clipboard (Rust flashes a check icon).
    callback copy-clicked();
    // C (ТЗ 2026-07-02) — copy ONE fenced code block: (block-index, clean code).
    callback copy-block-clicked(int, string);
    // v0.18.6 — retry a failed meeting summary from its persisted conspect.
    callback retry-clicked();
    // Read-aloud — speak the tile's text aloud / toggle pause-resume.
    callback speak-clicked();
    callback speak-pause-clicked();
    // Phase E6 v22 — manual cursor-delta drag. drag-start-requested
    // fires on pointer-down (records anchor), drag-moved fires on
    // each move while pressed (moves window by delta). Replaces the
    // old WM_NCLBUTTONDOWN modal drag that left TouchArea stuck.
    callback drag-start-requested();
    callback drag-moved();
    // Phase E6 v45 — user submitted a follow-up question (the text).
    callback followup-submitted(string);
    // V5 — user toggled the 🎤 voice follow-up (start/stop mic recording);
    // Rust records → transcribes → submits the recognized text as a follow-up.
    callback followup-voice-toggled();

    // Guarded submit shared by the input's Enter + the send button. No-op
    // while busy or empty; clears the field after firing.
    function do-submit() {
        if (root.followup-busy) {
            return;
        }
        if (root.followup-text == "") {
            return;
        }
        root.followup-submitted(root.followup-text);
        root.followup-text = "";
    }

    Rectangle {
        // Near-opaque (was 0.92): at 8% see-through a tile CASCADED behind this
        // one bled its text through as faint ghosting over the answer (user's
        // screenshot). 0.98 kills the visible bleed but keeps a hint of depth;
        // the body-opacity slider below still gives an INTENTIONAL fade.
        background: Theme.bg-surface.with-alpha(0.98);
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.border;
        opacity: root.body-opacity;

        VerticalLayout {
            padding: 10px;
            spacing: 6px;

            // ===== Chrome row =====
            // Phase E6 v8 — RESTRUCTURED to fix the "pin/X buttons
            // don't fire" bug. The previous version wrapped a
            // TouchArea over the WHOLE chrome row, which captured
            // pointer events even when they overlapped the Button
            // widgets → Button.clicked never fired (TouchArea
            // pointer-event swallows). Now the TouchArea is INSIDE
            // a sub-Rectangle that only covers the title+spacer
            // region; buttons live OUTSIDE that Rectangle so their
            // internal TouchArea is the only one in the click path.
            HorizontalLayout {
                spacing: 6px;
                height: 30px;
                // Title + drag-handle area — stretches to fill
                // remaining width on the LEFT of the source-label +
                // buttons cluster. TouchArea covers ONLY this area
                // so its pointer-event capture doesn't shadow the
                // sibling Button widgets.
                Rectangle {
                    horizontal-stretch: 1;
                    drag-area := TouchArea {
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left
                                && ev.kind == PointerEventKind.down) {
                                root.drag-start-requested();
                            }
                        }
                        moved => {
                            if (self.pressed) { root.drag-moved(); }
                        }
                    }
                    Text {
                        x: 0;
                        text: @tr("#{}  {}", root.sequence, root.tile-title);
                        font-size: 12px;
                        font-weight: 700;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                        overflow: elide;
                        width: parent.width;
                    }
                }
                Rectangle {
                    background: transparent;
                    border-color: Theme.border-strong;
                    border-width: 1px;
                    border-radius: 8px;
                    height: 20px;
                    horizontal-stretch: 0;
                    // Cap + elide: a long source-label (e.g. a full local-model .gguf path)
                    // must NOT push the fixed-width header buttons — including Close — off the
                    // right edge. Bounded here so the window controls always stay visible.
                    max-width: 150px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: root.source-label;
                            font-size: 10px;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
                // Phase E6 v9 — wrap buttons in fixed-min-width Rectangles
                // with explicit TouchArea so the click target is larger
                // than the default Slint Button intrinsic width. User
                // reported "X не работает" on dragged tiles — root
                // cause was pixel-perfect aim required (button ~15 px
                // wide). Now each button is 44 px wide + 28 px tall so
                // off-by-a-few-pixels clicks still land on the button.
                // Pin button removed (audit #135): the `pinned` flag never
                // actually protected a tile from "close all" / the live-tile
                // cap, so the button was a misleading no-op. The property +
                // pin-clicked callback stay declared (Rust handlers reference
                // them) but are now inert.
                // Phase E6 v17 — Maximize button. User: "нет
                // функционала развернуть, нужно отдельной кнопкой
                // или даб-кликом". Win32 SetWindowPos resizes window
                // 460x360 → 800x600 (toggle).
                // V0.8.3 — copy the answer text to the clipboard.
                // Shown on conversational tiles (can-copy).
                if root.can-copy: Rectangle {
                    width: 30px;
                    height: 30px;
                    background: copy-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    copy-touch := TouchArea {
                        clicked => { root.copy-clicked(); }
                    }
                    Image {
                        source: root.copied
                            ? @image-url("../assets/icons/check.svg")
                            : @image-url("../assets/icons/copy.svg");
                        colorize: root.copied ? Theme.success : Theme.text-secondary;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                // «⋯» overflow — 🔄 regenerate + 🧠 escalate moved off the
                // always-on header into a popup menu (Glacier Этап 6). The button
                // shows only when at least one is available; the callbacks and the
                // followup-busy guards are unchanged.
                Rectangle {
                    width: 30px;
                    height: 30px;
                    background: more-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    more-touch := TouchArea {
                        clicked => { overflow-popup.show(); }
                    }
                    Image {
                        source: @image-url("../assets/icons/more.svg");
                        colorize: Theme.text-secondary;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    overflow-popup := PopupWindow {
                        // Right-align the 168px menu under the 30px button, just
                        // below the header row.
                        x: 30px - 168px;
                        y: parent.height + 4px;
                        Rectangle {
                            width: 168px;
                            background: Theme.bg-elevated;
                            border-color: Theme.border-strong;
                            border-width: 1px;
                            border-radius: 8px;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 2px;
                                // R1 (retest v0.28.0) — toggle whole-answer «Выделить текст» mode.
                                TileMenuRow {
                                    icon: @image-url("../assets/icons/select-text.svg");
                                    label: root.select-mode ? @tr("Rich view") : @tr("Select text");
                                    clicked => {
                                        root.toggle-select-mode();
                                        overflow-popup.close();
                                    }
                                }
                                if root.can-regenerate: TileMenuRow {
                                    icon: @image-url("../assets/icons/refresh.svg");
                                    label: @tr("Regenerate");
                                    // Fire the action FIRST, then close — calling
                                    // close() before the callback tears down the
                                    // popup subtree and drops the rest of the
                                    // handler (Slint PopupWindow gotcha).
                                    clicked => {
                                        if (!root.followup-busy) {
                                            root.regenerate-clicked();
                                        }
                                        overflow-popup.close();
                                    }
                                }
                                if root.can-escalate: TileMenuRow {
                                    icon: @image-url("../assets/icons/brain.svg");
                                    label: @tr("Smart cloud");
                                    clicked => {
                                        if (!root.followup-busy) {
                                            root.escalate-clicked();
                                        }
                                        overflow-popup.close();
                                    }
                                }
                            }
                        }
                    }
                }
                // v0.18.6 — «Повторить» on a summary-failure tile. Accent-colored
                // so it reads as the primary action (the body text says «…и
                // попробуйте ещё раз»). Resumes from the persisted conspect.
                if root.can-retry: Rectangle {
                    width: 30px;
                    height: 30px;
                    background: retry-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    accessible-role: button;
                    accessible-label: "Retry";
                    retry-touch := TouchArea {
                        clicked => { root.retry-clicked(); }
                    }
                    Image {
                        source: @image-url("../assets/icons/refresh.svg");
                        colorize: Theme.accent;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                // Read-aloud — 🔊 speak the tile text aloud; ⏯ pause/resume.
                if root.can-speak: Rectangle {
                    width: 30px;
                    height: 30px;
                    background: speak-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    speak-touch := TouchArea {
                        clicked => { root.speak-clicked(); }
                    }
                    Image {
                        source: @image-url("../assets/icons/speaker.svg");
                        colorize: Theme.text-secondary;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                if root.can-speak: Rectangle {
                    width: 30px;
                    height: 30px;
                    background: pausespk-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    pausespk-touch := TouchArea {
                        clicked => { root.speak-pause-clicked(); }
                    }
                    Image {
                        source: root.speak-paused
                            ? @image-url("../assets/icons/play.svg")
                            : @image-url("../assets/icons/pause.svg");
                        colorize: Theme.text-secondary;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                Rectangle {
                    width: 30px;
                    height: 30px;
                    background: max-touch.has-hover ? Theme.border-strong : Theme.border;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-strong;
                    max-touch := TouchArea {
                        clicked => { root.maximize-clicked(); }
                    }
                    Image {
                        source: root.maximized
                            ? @image-url("../assets/icons/restore.svg")
                            : @image-url("../assets/icons/maximize.svg");
                        colorize: Theme.text-primary;
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                CloseButton {
                    box: 30px;
                    glyph: 16px;
                    clicked => { root.close-clicked(); }
                }
            }

            Rectangle {
                background: Theme.border;
                height: 1px;
            }

            // ===== Trigger badge =====
            // Phase E6 v12 — colored pill below chrome row shows what
            // detector trigger spawned this tile (Keyword "docker",
            // Question "...", every-line). Hidden when trigger-label
            // is empty (manual F9 ask or F6 spawn).
            if root.trigger-label != "" : Rectangle {
                height: 22px;
                horizontal-stretch: 1;
                HorizontalLayout {
                    alignment: start;
                    Rectangle {
                        background: root.trigger-color.with-alpha(0.18);
                        border-color: root.trigger-color;
                        border-width: 1px;
                        border-radius: 9px;
                        height: 20px;
                        horizontal-stretch: 0;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            Text {
                                text: root.trigger-label;
                                font-size: 10px;
                                font-weight: 700;
                                color: root.trigger-color;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // ===== Markdown body (kind-discriminant renderer) =====
            // Phase E6 fix — viewport-width and explicit Text width
            // force `wrap: word-wrap` to actually engage. Without the
            // viewport-width hint, ScrollView lets content render
            // unconstrained → long Russian paragraphs overflowed the
            // dark fill area (user complaint "текст выходит за края").
            if !root.select-mode : ScrollView {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                viewport-width: self.width;
                min-height: 0px; // RS2: scroll inside the fixed tile, never grow the window (see below)
                VerticalLayout {
                    spacing: 4px;
                    // A2 fix (retest r2): right inset so the per-block ⭐ gutter clears the
                    // ScrollView scrollbar on long/scrolling answers (tester: the stars
                    // "compete with the scroll" and get hard to click).
                    padding-right: 14px;
                    // Per-block wrapper is a LAYOUT, not a bare Rectangle.
                    // A Rectangle does NOT size its height to non-layout
                    // children, so long Text blocks collapsed to ~0px and
                    // painted on top of the next block. A VerticalLayout
                    // sizes to its one active child → blocks stack cleanly.
                    // User: "текст наслаивается друг на друге".
                    for block[i] in root.blocks: VerticalLayout {

                        // H1
                        if block.kind == 1 : SelectableText {
                            text: block.text;
                            font-size: 18px;
                            font-weight: 700;
                            text-color: Theme.text-primary;
                            wrap: word-wrap;
                            capture(a, c) => { root.capture-selection(i, a, c); }
                        }
                        // H2
                        if block.kind == 2 : SelectableText {
                            text: block.text;
                            font-size: 15px;
                            font-weight: 700;
                            text-color: Theme.text-secondary;
                            wrap: word-wrap;
                            capture(a, c) => { root.capture-selection(i, a, c); }
                        }
                        // H3
                        if block.kind == 3 : SelectableText {
                            text: block.text;
                            font-size: 13px;
                            font-weight: 700;
                            text-color: Theme.text-secondary;
                            wrap: word-wrap;
                            capture(a, c) => { root.capture-selection(i, a, c); }
                        }
                        // Paragraph (+ A2 star gutter on the right)
                        if block.kind == 0 : HorizontalLayout {
                            spacing: 4px;
                            SelectableText {
                                text: block.text;
                                font-size: 12px;
                                text-color: Theme.text-secondary;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                                capture(a, c) => { root.capture-selection(i, a, c); }
                            }
                            StarMark {
                                marked: block.marked;
                                clicked(shift) => { root.toggle-block-marked(i, shift); }
                            }
                        }
                        // Bullet
                        if block.kind == 4 : HorizontalLayout {
                            padding-left: 12px;
                            spacing: 6px;
                            Text {
                                text: "•";
                                font-size: 12px;
                                color: Theme.accent;
                                width: 10px;
                            }
                            SelectableText {
                                text: block.text;
                                font-size: 12px;
                                text-color: Theme.text-secondary;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                                capture(a, c) => { root.capture-selection(i, a, c); }
                            }
                            StarMark {
                                marked: block.marked;
                                clicked(shift) => { root.toggle-block-marked(i, shift); }
                            }
                        }
                        // Code block
                        if block.kind == 5 : Rectangle {
                            background: Theme.code-bg;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Theme.border;
                            clip: true;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                // Header: language label (left) + per-block copy
                                // button (right). The button copies THIS block's
                                // clean code — `block.text` is the fence-stripped
                                // body, so no backticks reach the clipboard.
                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: block.lang;
                                        font-size: 9px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Rectangle {
                                        width: 22px;
                                        height: 18px;
                                        border-radius: 4px;
                                        background: cb-touch.has-hover ? Theme.border-strong : transparent;
                                        cb-touch := TouchArea {
                                            clicked => { root.copy-block-clicked(i, block.text); }
                                        }
                                        Image {
                                            source: root.copied-block-index == i
                                                ? @image-url("../assets/icons/check.svg")
                                                : @image-url("../assets/icons/copy.svg");
                                            colorize: root.copied-block-index == i ? Theme.success : Theme.text-muted;
                                            width: 12px;
                                            height: 12px;
                                            image-fit: contain;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                        }
                                    }
                                    StarMark {
                                        marked: block.marked;
                                        clicked(shift) => { root.toggle-block-marked(i, shift); }
                                    }
                                }
                                // Code keeps no-wrap so commands / YAML / JSON
                                // don't reflow and lose meaning; long lines
                                // clip at the box edge (clip:true) — maximize
                                // the tile (maximize button) to read them in full.
                                SelectableText {
                                    text: block.text;
                                    font-size: 11px;
                                    text-color: Theme.code-text;
                                    mono-family: Theme.font-mono;
                                    wrap: no-wrap;
                                    capture(a, c) => { root.capture-selection(i, a, c); }
                                }
                            }
                        }
                        // HR
                        if block.kind == 6 : Rectangle {
                            background: Theme.border;
                            height: 1px;
                        }
                        // Table (kind 7) — aligned monospace block (#109).
                        // no-wrap preserves column alignment; very wide
                        // tables clip on the right rather than scrambling
                        // (maximize the tile to see them in full).
                        if block.kind == 7 : Rectangle {
                            background: Theme.code-bg;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Theme.border;
                            VerticalLayout {
                                padding: 8px;
                                SelectableText {
                                    text: block.text;
                                    font-size: 11px;
                                    text-color: Theme.code-text;
                                    mono-family: Theme.font-mono;
                                    wrap: no-wrap;
                                    capture(a, c) => { root.capture-selection(i, a, c); }
                                }
                            }
                        }
                    }
                }
            }

            // R1 (retest v0.28.0) — «Выделить текст» mode: the whole answer as ONE selectable field
            // so text can be dragged / copied ACROSS blocks. `select-text` is the joined + capped
            // answer (built in Rust). Same bounded ScrollView shape as the block view above: it clips
            // + scrolls its viewport, so a huge field stays INSIDE the fixed window and can't paint
            // over the buttons below (the overflow that got this deleted; also fixed in SelectableText).
            if root.select-mode : ScrollView {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                viewport-width: self.width;
                // RS2 (retest): min-height 0 so the tall joined field SCROLLS inside the fixed-height
                // tile instead of forcing the window taller — which pushed «В память»/«Отмена» (and
                // «Продолжить диалог») off the bottom until the user deleted text. The window sizes to
                // its content's min-height (no window max-height); without this the field's full height
                // propagates up as the window min. vertical-stretch then gives it the leftover space.
                min-height: 0px;
                VerticalLayout {
                    padding-right: 14px;
                    // Proportional + word-wrap: ONE mixed prose+code buffer, so code loses
                    // monospace/no-wrap here — the accepted cost of a single joined field.
                    SelectableText {
                        text: root.select-text;
                        font-size: 12px;
                        text-color: Theme.text-secondary;
                        wrap: word-wrap;
                        capture(a, c) => { root.capture-selection(-1, a, c); }
                    }
                }
            }

            // A2 (ТЗ 2026-07-02) — «⭐ В память» action bar: shows once ≥1 block is
            // marked. N==1 exposes the edit buffer (trim-before-save, the flow the
            // tester accepted on the transcript); N>1 saves each marked block as its
            // own fact (edit later in Настройки → Память).
            if root.marked-count >= 1 || root.capture-pending : VerticalLayout {
                spacing: 4px;
                // Editor: the single-mark trim buffer OR a pending mouse-selection.
                if root.marked-count == 1 || root.capture-pending : LineEdit {
                    text <=> root.capture-text;
                }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: root.capture-pending ? @tr("To memory") : @tr("To memory ({})", root.marked-count);
                        clicked => {
                            if (root.capture-pending) { root.save-capture(); }
                            else { root.save-marked(); }
                        }
                    }
                    // P5 — copy the marked blocks (only when marking, not for a pending selection
                    // which the user can already Ctrl+C from the editor above).
                    if root.marked-count >= 1 : Button {
                        text: @tr("Copy");
                        clicked => { root.copy-marked(); }
                    }
                    Button {
                        text: @tr("Cancel");
                        clicked => {
                            if (root.capture-pending) { root.cancel-capture(); }
                            else { root.clear-marks(); }
                        }
                    }
                }
            }

            // ===== Follow-up input — continue the dialog in this tile =====
            // Phase E6 v45 — only shown for tiles that carry a conversation
            // (F9 / push-to-record answers; convo-id >= 0). Enter or the
            // → button sends; both are disabled while the answer streams.
            // User: "нет возможности продолжить диалог в рамках тайла".
            if root.convo-id >= 0 : HorizontalLayout {
                spacing: 6px;
                LineEdit {
                    placeholder-text: @tr("Continue the dialog…");
                    text <=> root.followup-text;
                    enabled: !root.followup-busy;
                    horizontal-stretch: 1;
                    accepted => {
                        root.do-submit();
                    }
                }
                // V0.8.4 — voice follow-up with the SAME Telegram-style swipe-up-to-
                // lock gesture as the bar's record chips: hold 🎤 to record, release
                // to send; drag up past 24px → hands-free (releasing keeps recording;
                // click ⏹ to stop + send). Drives the existing toggle at press (start)
                // / stop; the release-stop is gated on voice-recording so a mic-busy
                // tap can't spuriously start a recording on release. Border colour
                // marks state: grey idle · amber holding · red locked.
                voicebtn := Rectangle {
                    property <bool> v-locked: false;
                    property <length> v-press-y;
                    property <bool> v-swallow: false;
                    property <bool> v-rec: root.voice-recording;
                    width: 36px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: voicebtn.v-locked ? Theme.danger
                        : (root.voice-recording ? Theme.warning : Theme.border);
                    changed v-rec => {
                        if (!voicebtn.v-rec) {
                            voicebtn.v-locked = false;
                        }
                    }
                    // Idle = mic icon; recording states use SVG stop / arrow-up
                    // icons for font-independent rendering.
                    if !root.voice-recording && !voicebtn.v-locked : Image {
                        source: @image-url("../assets/icons/mic.svg");
                        colorize: Theme.text-secondary;
                        width: 15px;
                        height: 15px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    if root.voice-recording || voicebtn.v-locked : Image {
                        source: voicebtn.v-locked
                            ? @image-url("../assets/icons/stop.svg")
                            : @image-url("../assets/icons/arrow-up.svg");
                        colorize: voicebtn.v-locked ? Theme.danger : Theme.warning;
                        width: 15px;
                        height: 15px;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    vtouch := TouchArea {
                        mouse-cursor: pointer;
                        enabled: !root.followup-busy || root.voice-recording;
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left) {
                                if (ev.kind == PointerEventKind.down) {
                                    if (voicebtn.v-locked) {
                                        // Fresh click while locked = stop + send.
                                        voicebtn.v-locked = false;
                                        voicebtn.v-swallow = true;
                                        root.followup-voice-toggled();
                                    } else {
                                        voicebtn.v-press-y = self.mouse-y;
                                        voicebtn.v-swallow = false;
                                        root.followup-voice-toggled();
                                    }
                                }
                                if (ev.kind == PointerEventKind.up) {
                                    if (voicebtn.v-swallow) {
                                        voicebtn.v-swallow = false;
                                    } else if (!voicebtn.v-locked && root.voice-recording) {
                                        root.followup-voice-toggled();
                                    }
                                    // locked && !swallow = the release after a lock →
                                    // keep recording hands-free (do nothing).
                                }
                            }
                        }
                        moved => {
                            if (self.pressed && root.voice-recording && !voicebtn.v-locked
                                && voicebtn.v-press-y - self.mouse-y > 24px) {
                                voicebtn.v-locked = true;
                            }
                        }
                    }
                }
                Button {
                    text: root.followup-busy ? "…" : "→";
                    enabled: !root.followup-busy;
                    clicked => {
                        root.do-submit();
                    }
                }
            }
        }
    }
}
