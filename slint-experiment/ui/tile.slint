// =====================================================================
// Tile window — floating card with streamed AI answer.
//
// Phase E6 v15 — integrated Anthropic-design redesign. Visual rules:
//   - kind colour shows on border + top accent strip + bullets only
//     (never on title text or large fills — peripheral-friendly)
//   - markdown body stays neutral; code blocks neutral charcoal
//   - trigger badge (Phase E6 v12) preserved below chrome row
//   - ScrollView (std-widgets) wraps body so scrollbar is visible
//     when content overflows (user complaint: "нет скролла")
//
// Public API (UNCHANGED — overlay_host.rs continues to use):
//   struct MarkdownBlock { kind: int, text: string, lang: string }
//   props:     tile-title, sequence, blocks, source-label,
//              trigger-label, trigger-color
//   callbacks: close-clicked, pin-clicked, drag-start-requested
//
// New optional props (default-safe — won't break existing call sites):
//   kind         "auto" | "system" | "mic" | "manual" | "ai"
//   pinned       bool — pin icon flips state when true
//   live         bool — shows "● live" indicator next to title
//   ai-status    string — "asking…" / "done (stop)" etc.
// =====================================================================

import { ScrollView } from "std-widgets.slint";
import { Theme } from "tokens.slint";

// MarkdownBlock — canonical definition, re-exported via index.slint.
export struct MarkdownBlock {
    kind: int,
    text: string,
    lang: string,
}

// ----- Small chip used in the chrome row (source label / status) -----
component MetaChip inherits Rectangle {
    in property <string> text;
    in property <color>  accent: Theme.text-mute;
    in property <bool>   filled: false;

    height: 18px;
    border-radius: 4px;
    border-width: 1px;
    background: root.filled ? root.accent.with-alpha(0.18) : transparent;
    border-color: root.filled
        ? root.accent.with-alpha(0.45)
        : Theme.border;
    horizontal-stretch: 0;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        alignment: center;
        Text {
            text: root.text;
            font-size: 10px;
            font-weight: 500;
            color: root.filled ? root.accent : Theme.text-mute;
            vertical-alignment: center;
        }
    }
}

// ----- Tiny ghost button used in chrome (pin, close) -----------------
// Phase E6 v15 — wider hit-box than Slint's std-widgets Button so
// off-by-a-few-pixel clicks still register. User feedback from cycle
// 14: "close не сработал не сразу одит где был ответ так и не закрылся".
component ChromeBtn inherits Rectangle {
    in property <string> glyph;
    in property <bool>   destructive: false;
    in property <bool>   active: false;       // pin = filled when pinned
    callback clicked();

    width: 28px;
    height: 22px;
    border-radius: Theme.r-1;
    background: root.active
        ? Theme.warn.with-alpha(0.18)
        : (ta.has-hover
            ? (root.destructive
                ? Theme.error.with-alpha(0.18)
                : Theme.bg-3.with-alpha(0.7))
            : transparent);
    border-width: 1px;
    border-color: root.active
        ? Theme.warn.with-alpha(0.5)
        : (ta.has-hover ? Theme.border-strong : transparent);
    animate background, border-color { duration: Theme.dur-base; }

    Text {
        text: root.glyph;
        font-size: 11px;
        font-weight: 600;
        color: root.active
            ? Theme.warn
            : (ta.has-hover
                ? (root.destructive ? Theme.error : Theme.text)
                : Theme.text-mute);
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: Theme.dur-base; }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

// =====================================================================
// TileWindow
// =====================================================================

export component TileWindow inherits Window {
    title: "tile";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    preferred-width: 460px;
    preferred-height: 360px;
    min-width: 320px;
    min-height: 200px;

    // ===== Public state (kept compatible) =============================
    in-out property <string> tile-title: "Untitled tile";
    in-out property <int>    sequence: 0;
    in-out property <[MarkdownBlock]> blocks: [];
    in-out property <string> source-label: "—";
    // Phase E6 v12 — trigger badge from auto-detector / F9 hotkey.
    in-out property <string> trigger-label: "";
    in-out property <color>  trigger-color: Theme.auto;

    // ===== New optional state (default-safe) ==========================
    // "auto" | "system" | "mic" | "manual" | "ai"  → drives kind colour.
    in-out property <string> kind: "auto";
    in-out property <bool>   pinned: false;
    in-out property <bool>   live: false;
    in-out property <string> ai-status: "";

    // ===== Callbacks (unchanged) ======================================
    callback close-clicked();
    callback pin-clicked();
    callback drag-start-requested();

    // ----- Derived: kind colour --------------------------------------
    property <color> accent:
        root.kind == "system" ? Theme.system :
        root.kind == "mic"    ? Theme.mic    :
        root.kind == "manual" ? Theme.manual :
        root.kind == "ai"     ? Theme.ai     :
        /* default — "auto" */  Theme.auto;

    // ----- Shell -----------------------------------------------------
    Rectangle {
        background: Theme.glass-strong;
        border-radius: Theme.r-4;
        border-width: 1px;
        border-color: root.accent.with-alpha(0.55);
        drop-shadow-blur: 28px;
        drop-shadow-offset-y: 10px;
        drop-shadow-color: #00000099;

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // ===== Top accent strip (slim kind-colour bar) ===========
            Rectangle {
                height: 3px;
                background: root.accent;
            }

            // ===== Chrome row =======================================
            // Phase E6 v10 — drag-area TouchArea inside title sub-
            // rectangle (NOT wrapping whole chrome row) so chrome
            // buttons (pin/X) fire independently.
            chrome := Rectangle {
                height: 30px;
                background: root.accent.with-alpha(0.10);

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 6px;
                    spacing: 6px;
                    alignment: start;

                    // Title + drag handle area
                    Rectangle {
                        horizontal-stretch: 1;
                        drag-area := TouchArea {
                            pointer-event(ev) => {
                                if (ev.button == PointerEventButton.left
                                    && ev.kind == PointerEventKind.down) {
                                    root.drag-start-requested();
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            // Sequence number — monospace, accent-coloured.
                            Text {
                                text: "#" + root.sequence;
                                font-family: "Consolas";
                                font-size: Theme.fs-11;
                                font-weight: 600;
                                color: root.accent;
                                vertical-alignment: center;
                            }
                            // Title — neutral white, elide.
                            Text {
                                text: root.tile-title;
                                font-size: Theme.fs-12;
                                font-weight: 600;
                                color: Theme.text;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                    }

                    // Live dot + "live" label
                    if root.live: HorizontalLayout {
                        spacing: 4px;
                        alignment: center;
                        Rectangle {
                            width: 6px; height: 6px;
                            border-radius: 3px;
                            background: Theme.mic;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "live";
                            font-size: 10px;
                            font-weight: 500;
                            color: Theme.mic;
                            vertical-alignment: center;
                        }
                    }

                    // source-label meta chip (filled — wears kind colour)
                    MetaChip {
                        text: root.source-label;
                        accent: root.accent;
                        filled: true;
                    }

                    // Pin
                    ChromeBtn {
                        glyph: "pin";
                        active: root.pinned;
                        clicked => { root.pin-clicked(); }
                    }

                    // Close
                    ChromeBtn {
                        glyph: "X";
                        destructive: true;
                        clicked => { root.close-clicked(); }
                    }
                }
            }

            // ===== Divider ==========================================
            Rectangle {
                height: 1px;
                background: Theme.border-soft;
            }

            // ===== Trigger badge =====================================
            // Phase E6 v12 — shows what spawned this tile: keyword /
            // question / manual F9. Hidden when empty (KB-palette).
            if root.trigger-label != "" : Rectangle {
                height: 24px;
                horizontal-stretch: 1;
                HorizontalLayout {
                    alignment: start;
                    padding-left: 10px;
                    padding-top: 3px;
                    Rectangle {
                        background: root.trigger-color.with-alpha(0.18);
                        border-color: root.trigger-color;
                        border-width: 1px;
                        border-radius: 9px;
                        height: 18px;
                        horizontal-stretch: 0;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            Text {
                                text: root.trigger-label;
                                font-size: 10px;
                                font-weight: 700;
                                color: root.trigger-color;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // ===== Markdown body (kind-discriminant renderer) =======
            // Phase E6 v15 — std-widgets ScrollView (shows visible
            // scrollbar on overflow). User complaint: "нет скролла".
            ScrollView {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    spacing: 6px;

                    // Empty-state placeholder
                    if root.blocks.length == 0: Rectangle {
                        HorizontalLayout {
                            alignment: center;
                            padding: 18px;
                            Text {
                                text: root.ai-status != ""
                                    ? "⏳  " + root.ai-status
                                    : "(no content yet)";
                                font-size: Theme.fs-12;
                                color: Theme.text-mute;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    for block[i] in root.blocks: Rectangle {
                        background: transparent;
                        horizontal-stretch: 1;

                        // H1
                        if block.kind == 1 : Text {
                            text: block.text;
                            font-size: Theme.fs-14;
                            font-weight: 700;
                            color: Theme.text;
                            wrap: word-wrap;
                            width: parent.width;
                        }
                        // H2
                        if block.kind == 2 : Text {
                            text: block.text;
                            font-size: Theme.fs-13;
                            font-weight: 700;
                            color: Theme.text;
                            wrap: word-wrap;
                            width: parent.width;
                        }
                        // H3
                        if block.kind == 3 : Text {
                            text: block.text;
                            font-size: Theme.fs-13;
                            font-weight: 600;
                            color: Theme.text-mute;
                            wrap: word-wrap;
                            width: parent.width;
                        }
                        // Paragraph
                        if block.kind == 0 : Text {
                            text: block.text;
                            font-size: Theme.fs-13;
                            color: Theme.text;
                            wrap: word-wrap;
                            width: parent.width;
                        }
                        // Bullet
                        if block.kind == 4 : HorizontalLayout {
                            padding-left: 4px;
                            spacing: 8px;
                            Text {
                                text: "•";
                                font-size: Theme.fs-13;
                                color: root.accent;
                                width: 10px;
                            }
                            Text {
                                text: block.text;
                                font-size: Theme.fs-13;
                                color: Theme.text;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                        }
                        // Code block — neutral charcoal (not kind-tinted).
                        if block.kind == 5 : Rectangle {
                            background: Theme.bg-0.with-alpha(0.6);
                            border-radius: Theme.r-2;
                            border-width: 1px;
                            border-color: Theme.border-soft;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 2px;
                                if block.lang != "" : Text {
                                    text: block.lang;
                                    font-size: 9px;
                                    font-family: "Consolas";
                                    color: Theme.text-dim;
                                }
                                Text {
                                    text: block.text;
                                    font-size: Theme.fs-12;
                                    color: Theme.text;
                                    font-family: "Consolas";
                                    wrap: word-wrap;
                                    width: parent.width;
                                }
                            }
                        }
                        // HR
                        if block.kind == 6 : Rectangle {
                            background: Theme.border-soft;
                            height: 1px;
                        }
                    }
                }
            }
        }
    }
}
