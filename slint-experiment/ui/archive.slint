// Session-archive browser (Phase 3a of the personal-memory architecture —
// docs/personal-memory-and-session-store-architecture.md). A frameless,
// stealth-aware window over the SQLite session catalog: it lists past sessions
// (newest first) and full-text-searches their transcript + AI Q&A (FTS5/BM25).
// Activating a row spawns a read-only tile with that session's content.
//
// overlay_host.rs owns the wiring: the F7 hotkey (toggle, like F4/F1), the
// `overlay_backend::persistence::Store` queries (list / search / detail), and
// the tile spawn. Structurally a sibling of palette.slint (searchable list).
//
// i18n: the DATA rows are language-NEUTRAL (emoji-coded counts/status, built in
// Rust) so there is no per-row translation; only the window CHROME (title,
// search placeholder, empty / hint strings) is `@tr`, with the msgid as English
// and the Russian in translations/ru/.../slint-replay.po.

import { LineEdit, ScrollView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CloseButton } from "controls.slint";
import { Metrics } from "metrics.slint";

// One archive row — a past SESSION or a SEARCH HIT (the Rust side fills both
// shapes into this struct; the UI renders them identically).
export struct ArchiveRow {
    id: string,        // session id (file stem) — passed back on activation
    title: string,     // session: "Обзор функций" or "2026-06-04 10:00:00"; hit: the snippet header
    subtitle: string,  // session: "💬 12 · 🤖 3 · model"; hit: the matched snippet
    meta: string,      // session: cost (e.g. "$0.024"); hit: kind emoji
    has-recordings: bool, // v0.14.0 — recordings/<id>/ exists → show "↻ Summary"
    name: string,      // v0.22.0 — the raw editable session name ("" if unnamed) — pre-fills the inline rename field
    has-data: bool,    // F4 — has a saved transcript OR recording → "↻ Summary" is actionable
    has-summary: bool, // a conspect sidecar exists → row offers "Просмотреть", else "Сформировать"
}

// v0.22.0 — a compact 24px icon action button for archive rows (rename ✎,
// confirm ✓, cancel ✗). Sits ON TOP of the row's activation TouchArea.
component RowIcon inherits Rectangle {
    in property <image> icon;
    in property <string> a11y;
    callback clicked();
    width: 24px;
    height: 24px;
    border-radius: 5px;
    background: t.has-hover ? Theme.accent.with-alpha(0.20) : transparent;
    accessible-role: button;
    accessible-label: root.a11y;
    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                source: root.icon;
                colorize: Theme.text-secondary;
                width: 13px;
                height: 13px;
                image-fit: contain;
            }
        }
    }
    t := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component ArchiveWindow inherits Window {
    // Keep std-widgets (the search LineEdit) on the active scheme rather than
    // Slint's light fluent default — same trick as palette / settings.
    property <bool> widgets-light: Theme.is-light;
    init => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }
    changed widgets-light => { Palette.color-scheme = root.widgets-light ? ColorScheme.light : ColorScheme.dark; }

    title: "Session archive";
    icon: @image-url("../assets/icon.svg");
    // Solid opaque background (NOT transparent) — a transparent + WS_EX_LAYERED
    // frameless window alpha-clamps text to invisible (the palette learned this
    // the hard way in Phase E6). Frame off for the floating-window feel.
    background: Theme.bg-surface;
    no-frame: true;
    always-on-top: true;
    preferred-width: 720px;
    preferred-height: 540px;
    min-width: 480px;
    min-height: 320px;

    in-out property <string> query: "";
    in-out property <[ArchiveRow]> results: [];
    in-out property <int> selected-index: 0;
    // Header summary (Rust-built, language-neutral count, e.g. "128 · 5304💬").
    in-out property <string> summary: "";
    // True ONLY when the catalog can't be opened — an @tr'd message replaces the
    // list so the window degrades gracefully (never a blank panel).
    in-out property <bool> unavailable: false;

    // v0.14.0 — re-transcribe a session's saved recordings offline → better
    // transcript → fresh Summary tile. Busy/status drive the one-job-at-a-time
    // header indicator; the per-row "↻ Summary" button fires the request.
    in-out property <bool> retranscribe-busy: false;
    in-out property <string> retranscribe-status: "";
    // True when STT resolves to the cloud (Groq). Drives the egress note below:
    // "↻ Summary" then re-uploads this session's SAVED audio off-box, so we warn
    // (mirrors the Vision panel's "Screenshots are sent to the cloud." note).
    in-out property <bool> stt-is-cloud: false;

    // v0.22.0 — inline session rename. `renaming-index` is the row being edited
    // (-1 = none); `rename-text` is the editable buffer (Rust pre-fills it from
    // the row's `name` when ✎ is clicked).
    in-out property <int> renaming-index: -1;
    in-out property <string> rename-text: "";

    callback query-changed(string);
    callback result-activated(int);
    callback retranscribe-requested(int);
    // A row WITH a saved summary opens it READ-ONLY (re-shown as a tile, no AI
    // call) via this; regeneration stays the (confirmed) retranscribe-requested.
    callback view-summary-requested(int);
    // v0.22.0 — rename: ✎ opens the field (Rust sets renaming-index + rename-text
    // from the current name); ✓ / Enter confirms; ✗ cancels. Regen re-asks the
    // local model for a fresh title from the saved transcript.
    callback rename-requested(int, string);
    callback rename-confirmed(int);
    callback rename-cancelled();
    callback regen-name-requested(int);
    // ТЗ2a — 🗑 delete: Rust validates (active-session guard), then shows the in-app
    // confirm overlay below. F2: a native modal crashed nested in the event loop.
    callback delete-requested(int);
    // F2 — in-app delete confirmation. Rust sets confirm-delete-index (+ -title) to
    // show the overlay; its buttons fire delete-confirmed(idx) / delete-cancelled.
    in-out property <int> confirm-delete-index: -1;
    in-out property <string> confirm-delete-title: "";
    callback delete-confirmed(int);
    callback delete-cancelled();
    // F3 — re-create-summary confirmation (mirrors the delete confirm). Rust sets
    // confirm-resummary-index (+ -title) when a summary already exists (a conspect on
    // disk); the overlay's buttons fire resummary-confirmed(idx) / resummary-cancelled.
    in-out property <int> confirm-resummary-index: -1;
    in-out property <string> confirm-resummary-title: "";
    callback resummary-confirmed(int);
    callback resummary-cancelled();
    // ТЗ1 — 📄 opens the structured read-only transcript window for this session.
    callback transcript-requested(int);
    callback close-requested();
    // v0.17.1 — frameless window drag by the header (mirrors the tile drag:
    // pointer-down records the anchor, moved-while-pressed moves the HWND).
    callback drag-start-requested();
    callback drag-moved();

    // Focus the search box on open so the user can type immediately AND so Esc
    // has a focused element to bubble up from to the FocusScope (same wiring as
    // the palette — a hotkey-spawned always-on-top window starts unfocused).
    forward-focus: search-input;

    Rectangle {
        background: Theme.bg-surface.with-alpha(0.95);
        border-radius: Metrics.radius-panel;
        border-width: Metrics.border-thin;
        border-color: Theme.border;

        FocusScope {
            width: 100%;
            height: 100%;
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    // Esc dismisses an open confirm / in-progress rename first, then
                    // (nothing pending) closes the window. F3 resummary-confirm and
                    // F2 delete-confirm both just cancel; symmetry with the buttons.
                    if (root.confirm-resummary-index != -1) {
                        root.resummary-cancelled();
                        return accept;
                    }
                    if (root.confirm-delete-index != -1) {
                        root.delete-cancelled();
                        return accept;
                    }
                    if (root.renaming-index != -1) {
                        root.rename-cancelled();
                        return accept;
                    }
                    root.close-requested();
                    return accept;
                }
                return reject;
            }

            VerticalLayout {
                padding: Metrics.space-md;
                spacing: Metrics.space-sm;

                // ── Header: icon · title · summary (DRAG handle) · close ──
                HorizontalLayout {
                    spacing: Metrics.space-sm;
                    // Drag area covers the icon + title + summary, NOT the close
                    // button (a sibling below), so dragging never eats the X.
                    Rectangle {
                        horizontal-stretch: 1;
                        TouchArea {
                            pointer-event(ev) => {
                                if (ev.button == PointerEventButton.left
                                    && ev.kind == PointerEventKind.down) {
                                    root.drag-start-requested();
                                }
                            }
                            moved => { if (self.pressed) { root.drag-moved(); } }
                        }
                        HorizontalLayout {
                            spacing: Metrics.space-sm;
                            Image {
                                source: @image-url("../assets/icons/archive.svg");
                                colorize: Theme.text-primary;
                                width: 18px;
                                height: 18px;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Session archive");
                                font-size: Metrics.font-heading;
                                font-weight: 700;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.summary;
                                font-size: Metrics.font-caption;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                    CloseButton {
                        clicked => { root.close-requested(); }
                    }
                }

                // ── Search box (FTS over transcript + AI answers) ──
                search-input := LineEdit {
                    placeholder-text: @tr("search transcript + AI answers…");
                    text <=> root.query;
                    edited(t) => {
                        root.query-changed(t);
                        root.selected-index = 0;
                    }
                    accepted => {
                        if (root.results.length > 0) {
                            root.result-activated(root.selected-index);
                        }
                    }
                }

                Rectangle {
                    background: Theme.border;
                    height: Metrics.border-thin;
                }

                // ── Re-transcribe progress (one job at a time) ──
                if root.retranscribe-busy : Text {
                    text: root.retranscribe-status;
                    font-size: Metrics.font-caption;
                    color: Theme.accent;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // ── Cloud-STT egress note (only when "Summary" would upload) ──
                if root.stt-is-cloud && !root.retranscribe-busy : Text {
                    text: @tr("Re-Summary uploads this session's saved audio to the cloud STT.");
                    font-size: Metrics.font-caption;
                    color: Theme.warning;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // ── Error state: catalog unavailable ──
                if root.unavailable : Text {
                    text: @tr("The session archive is unavailable.");
                    font-size: Metrics.font-label;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                // ── Results list ──
                if !root.unavailable : ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px;
                        if root.results.length == 0 : Text {
                            text: root.query == ""
                                ? @tr("No archived sessions yet.")
                                : @tr("No matches for \"{}\".", root.query);
                            font-size: Metrics.font-label;
                            color: Theme.text-muted;
                            horizontal-alignment: center;
                        }
                        for row[i] in root.results : Rectangle {
                            background: i == root.selected-index ? Theme.accent-subtle : transparent;
                            border-radius: 4px;
                            border-color: i == root.selected-index ? Theme.accent : transparent;
                            border-width: Metrics.border-thin;
                            height: 50px;

                            // Activation layer (bottom) — clicking the row body
                            // opens the read-only session tile. Declared FIRST so
                            // the "↻ Summary" button below sits on top of it.
                            TouchArea {
                                clicked => { root.result-activated(i); }
                            }

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: Metrics.space-md;

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 1px;
                                    HorizontalLayout {
                                        spacing: Metrics.space-sm;
                                        // ── Inline rename (v0.22.0): field + ✓ / ✗ for THIS row ──
                                        if root.renaming-index == i : LineEdit {
                                            text <=> root.rename-text;
                                            placeholder-text: @tr("Session name");
                                            horizontal-stretch: 1;
                                            accepted => { root.rename-confirmed(i); }
                                        }
                                        if root.renaming-index == i : RowIcon {
                                            icon: @image-url("../assets/icons/check.svg");
                                            a11y: "Save name";
                                            clicked => { root.rename-confirmed(i); }
                                        }
                                        if root.renaming-index == i : RowIcon {
                                            icon: @image-url("../assets/icons/x.svg");
                                            a11y: "Cancel rename";
                                            clicked => { root.rename-cancelled(); }
                                        }
                                        // ── Normal: title + meta + ✎ rename ──
                                        if root.renaming-index != i : Text {
                                            text: row.title;
                                            font-size: Metrics.font-body;
                                            font-weight: 700;
                                            color: i == root.selected-index ? Theme.accent : Theme.text-secondary;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }
                                        if root.renaming-index != i : Text {
                                            text: row.meta;
                                            font-size: Metrics.font-caption;
                                            color: Theme.text-muted;
                                            vertical-alignment: center;
                                        }
                                        if root.renaming-index != i : RowIcon {
                                            icon: @image-url("../assets/icons/pencil.svg");
                                            a11y: "Rename session";
                                            clicked => { root.rename-requested(i, row.name); }
                                        }
                                        if root.renaming-index != i : RowIcon {
                                            icon: @image-url("../assets/icons/ai.svg");
                                            a11y: "Regenerate name from transcript";
                                            clicked => { root.regen-name-requested(i); }
                                        }
                                        if root.renaming-index != i : RowIcon {
                                            icon: @image-url("../assets/icons/trash.svg");
                                            a11y: "Delete session";
                                            clicked => { root.delete-requested(i); }
                                        }
                                        if root.renaming-index != i : RowIcon {
                                            icon: @image-url("../assets/icons/bubble.svg");
                                            a11y: "View transcript";
                                            clicked => { root.transcript-requested(i); }
                                        }
                                    }
                                    Text {
                                        text: row.subtitle;
                                        font-size: Metrics.font-caption;
                                        color: Theme.text-muted;
                                        overflow: elide;
                                    }
                                }

                                // ── "↻ Summary" — generate/regenerate the session
                                //    summary (shown when no job is running). Sessions
                                //    WITH recordings re-STT the saved audio; those
                                //    without summarize from the saved transcript /
                                //    journal prompts (ТЗ3).
                                // F4 — actionable only with data (a transcript or a
                                // recording); see the inert hint sibling below.
                                // Summary action (3-state): has a summary → "View"
                                // (re-show the saved recap as a tile, NO AI) + a
                                // secondary ↻ (regenerate, confirmed); has data but no
                                // summary → "Generate"; no data → the inert hint (F4).
                                if !root.retranscribe-busy && row.has-data : HorizontalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    horizontal-stretch: 0;
                                    Rectangle {
                                        width: 96px;
                                        height: 26px;
                                        border-radius: Metrics.radius-control;
                                        border-width: Metrics.border-thin;
                                        border-color: Theme.accent;
                                        background: pill-ta.has-hover ? Theme.accent.with-alpha(0.28) : Theme.accent-subtle;
                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 5px;
                                            VerticalLayout {
                                                alignment: center;
                                                Image {
                                                    source: row.has-summary
                                                        ? @image-url("../assets/icons/summary.svg")
                                                        : @image-url("../assets/icons/refresh.svg");
                                                    colorize: Theme.accent;
                                                    width: 13px;
                                                    height: 13px;
                                                    image-fit: contain;
                                                }
                                            }
                                            Text {
                                                text: row.has-summary ? @tr("View") : @tr("Generate");
                                                font-size: Metrics.font-caption;
                                                color: Theme.accent;
                                                vertical-alignment: center;
                                            }
                                        }
                                        pill-ta := TouchArea {
                                            clicked => {
                                                if (row.has-summary) {
                                                    root.view-summary-requested(i);
                                                } else {
                                                    root.retranscribe-requested(i);
                                                }
                                            }
                                        }
                                    }
                                    // Secondary ↻ — regenerate an EXISTING summary
                                    // (confirmed via the resummary overlay). Shown only
                                    // when there's a summary to overwrite.
                                    if row.has-summary : Rectangle {
                                        width: 26px;
                                        height: 26px;
                                        border-radius: Metrics.radius-control;
                                        border-width: Metrics.border-thin;
                                        border-color: Theme.border;
                                        background: redo-ta.has-hover ? Theme.accent.with-alpha(0.18) : transparent;
                                        VerticalLayout {
                                            alignment: center;
                                            HorizontalLayout {
                                                alignment: center;
                                                Image {
                                                    source: @image-url("../assets/icons/refresh.svg");
                                                    colorize: Theme.text-secondary;
                                                    width: 13px;
                                                    height: 13px;
                                                    image-fit: contain;
                                                }
                                            }
                                        }
                                        redo-ta := TouchArea {
                                            clicked => { root.retranscribe-requested(i); }
                                        }
                                    }
                                }
                                // F4 — no transcript AND no recording: nothing to
                                // summarize, so an inert hint instead of a dead button.
                                if !root.retranscribe-busy && !row.has-data : VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 0;
                                    Text {
                                        width: 96px;
                                        text: @tr("Not enough data");
                                        font-size: Metrics.font-caption;
                                        color: Theme.text-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: @tr("Esc to close · Enter / click to open a session");
                    font-size: 9px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                }
            }
        }

        // F2 — in-app delete confirmation (replaces the native modal that crashed
        // nested in the event loop). Scrim blocks + dims the window; the card is
        // centered; scrim-click / Cancel / Esc dismiss, Delete confirms.
        if root.confirm-delete-index != -1 : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.scrim;
            TouchArea {
                clicked => { root.delete-cancelled(); }
            }
            Rectangle {
                width: 380px;
                height: 184px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.bg-surface;
                border-radius: Metrics.radius-panel;
                border-width: Metrics.border-thin;
                border-color: Theme.border-strong;
                // Swallow clicks on the card so they don't reach the scrim (cancel).
                TouchArea { }
                VerticalLayout {
                    padding: Metrics.space-md;
                    spacing: Metrics.space-sm;
                    Text {
                        text: @tr("Delete session?");
                        font-size: Metrics.font-heading;
                        font-weight: 700;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: root.confirm-delete-title;
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    Text {
                        text: @tr("Irreversible — transcript, audio and summary are erased.");
                        font-size: Metrics.font-caption;
                        color: Theme.warning;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: Metrics.space-sm;
                        alignment: center;
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            background: cancel-ta.has-hover ? Theme.bg-elevated : transparent;
                            cancel-ta := TouchArea {
                                clicked => { root.delete-cancelled(); }
                            }
                            Text {
                                text: @tr("Cancel");
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            background: del-ta.pressed
                                ? Theme.danger.with-alpha(0.7)
                                : del-ta.has-hover ? Theme.danger : Theme.danger.with-alpha(0.88);
                            del-ta := TouchArea {
                                clicked => {
                                    root.delete-confirmed(root.confirm-delete-index);
                                }
                            }
                            Text {
                                text: @tr("Delete");
                                color: #ffffff;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // F3 — re-create-summary confirmation (mirrors the delete confirm above).
        // Shown when a summary already exists (a conspect on disk): Recreate
        // overwrites it, Cancel / scrim-click / Esc leave it untouched.
        if root.confirm-resummary-index != -1 : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.scrim;
            TouchArea {
                clicked => { root.resummary-cancelled(); }
            }
            Rectangle {
                width: 380px;
                height: 184px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.bg-surface;
                border-radius: Metrics.radius-panel;
                border-width: Metrics.border-thin;
                border-color: Theme.border-strong;
                // Swallow clicks on the card so they don't reach the scrim (cancel).
                TouchArea { }
                VerticalLayout {
                    padding: Metrics.space-md;
                    spacing: Metrics.space-sm;
                    Text {
                        text: @tr("Recreate summary?");
                        font-size: Metrics.font-heading;
                        font-weight: 700;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: root.confirm-resummary-title;
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    Text {
                        text: @tr("A summary already exists — recreate it?");
                        font-size: Metrics.font-caption;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: Metrics.space-sm;
                        alignment: center;
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            background: rs-cancel-ta.has-hover ? Theme.bg-elevated : transparent;
                            rs-cancel-ta := TouchArea {
                                clicked => { root.resummary-cancelled(); }
                            }
                            Text {
                                text: @tr("Cancel");
                                color: Theme.text-primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 132px;
                            height: 32px;
                            border-radius: 6px;
                            background: rs-ok-ta.pressed
                                ? Theme.accent.with-alpha(0.7)
                                : rs-ok-ta.has-hover ? Theme.accent : Theme.accent.with-alpha(0.88);
                            rs-ok-ta := TouchArea {
                                clicked => {
                                    root.resummary-confirmed(root.confirm-resummary-index);
                                }
                            }
                            Text {
                                text: @tr("Recreate");
                                color: Theme.on-accent;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
